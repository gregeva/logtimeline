# GROUP SIMILAR MESSAGES TOGETHER (Issue #96) #
unless( $group_similar_sensitivity eq "none" ) {


    $start_time = [gettimeofday];
    group_similar_messages();
    $end_time = [gettimeofday];
    $elapsed_group_similar_messages = tv_interval($start_time, $end_time);

    # message-grouping verbose diagnostics (Issue #96).
    if (section_requested('message-grouping')) {
        push @verbose_output, "";
        push @verbose_output, "=== message-grouping ===";
        push @verbose_output, sprintf("  Threshold: %d%%  Trigger: %d  Ceiling: %d  Final pass: %s",
            $consolidation_threshold, $consolidation_trigger, $consolidation_occurrence_ceiling,
            $consolidation_final_pass ? "on (threshold=${consolidation_final_threshold}%, ceiling=${consolidation_final_ceiling})" : "off");

        my ($grand_keys, $grand_s1, $grand_s2, $grand_s3, $grand_s4, $grand_s5, $grand_s6, $grand_fc) = (0,0,0,0,0,0,0,0);
        my $grand_checkpoints = 0;
        my $grand_patterns = 0;

        # Total patterns across all cat_gk groups (final count after both phases)
        my $total_patterns_all = 0;
        for my $cat_gk (keys %consolidation_patterns) {
            $total_patterns_all += scalar @{$consolidation_patterns{$cat_gk}};
        }

        for my $cat_gk (sort keys %consolidation_cat_stats) {
            my $s = $consolidation_cat_stats{$cat_gk};
            my $keys_seen = $s->{keys_seen} // 0;
            next unless $keys_seen > 0;

            my ($category_part) = split(/\|/, $cat_gk, 2);

            # --- Streaming phase ---
            my $checkpoints = $s->{checkpoints} // 0;
            my $patterns = $s->{patterns_final} // 0;
            my $evicted = $s->{evicted} // 0;

            # S2/S5: saved before final pass reset (or computed from current unmatched if no final pass)
            my $ceiling_filtered;
            my $genuinely_unmatched;
            if ($consolidation_final_pass && exists $s->{streaming_s2}) {
                $ceiling_filtered = $s->{streaming_s2};
                $genuinely_unmatched = $s->{streaming_s5};
            } else {
                # No final pass — compute from current %consolidation_unmatched
                $ceiling_filtered = 0;
                $genuinely_unmatched = 0;
                for my $key (keys %{$consolidation_unmatched{$cat_gk} // {}}) {
                    my $occ = $log_messages{$category_part}{$key}{occurrences} // 1;
                    if ($occ >= $consolidation_occurrence_ceiling) { $ceiling_filtered++; } else { $genuinely_unmatched++; }
                }
            }

            push @verbose_output, "";
            push @verbose_output, sprintf("  --- %s: Streaming Phase ---", $cat_gk);
            push @verbose_output, sprintf("    Keys seen:             %d  (%d checkpoints, %d patterns)", $keys_seen, $checkpoints, $patterns);
            push @verbose_output, sprintf("    S1 Inline match:       %d", $s->{s1_inline} // 0);
            push @verbose_output, sprintf("    S2 Ceiling filter:     %d  (occurrences >= %d)", $ceiling_filtered, $consolidation_occurrence_ceiling);
            push @verbose_output, sprintf("    S3 Checkpoint match:   %d", $s->{s3_checkpoint} // 0);
            push @verbose_output, sprintf("    S4 Pairwise discovery: %d", $s->{s4_pairwise} // 0);
            push @verbose_output, sprintf("    S4 Re-scan absorbed:   %d", $s->{s4_rescan} // 0);
            push @verbose_output, sprintf("    S5 Unmatched:          %d", $genuinely_unmatched);
            push @verbose_output, sprintf("    S6 Evicted:            %d", $evicted);
            my $ema_pct = ($s->{absorption_ema} // 0) * 100;
            my $ms = $s->{max_survivals} // 0;
            push @verbose_output, sprintf("    Eviction:              EMA=%.1f%%, max_survivals=%d", $ema_pct, $ms);
            push @verbose_output, sprintf("    find_candidates calls: %d", $s->{fc_calls} // 0);
            push @verbose_output, sprintf("    S3 attempts:           %d  (skipped: %d, match rate: %.1f%%)",
                $s->{s3_calls} // 0, $s->{s3_skipped} // 0,
                ($s->{s3_calls} // 0) > 0 ? (($s->{s3_checkpoint} // 0) / ($s->{s3_calls} // 1)) * 100 : 0);
            push @verbose_output, sprintf("    Cross-cluster merges:  %d", $s->{cross_cluster_merges} // 0);
            push @verbose_output, sprintf("    Cleanup keys scanned:  %d  (cumulative across %d checkpoints)",
                $s->{cleanup_keys_scanned} // 0, $checkpoints);

            # Streaming tracking invariant
            my $accounted = ($s->{s1_inline} // 0) + $ceiling_filtered + ($s->{s3_checkpoint} // 0) + ($s->{s4_pairwise} // 0) + ($s->{s4_rescan} // 0) + $genuinely_unmatched + $evicted;
            if ($accounted != $keys_seen) {
                push @verbose_output, sprintf("    [WARN] Tracking mismatch: %d accounted vs %d seen (delta %d)",
                    $accounted, $keys_seen, $keys_seen - $accounted);
            }

            $grand_keys += $keys_seen;
            $grand_s1 += ($s->{s1_inline} // 0);
            $grand_s2 += $ceiling_filtered;
            $grand_s3 += ($s->{s3_checkpoint} // 0);
            $grand_s4 += ($s->{s4_pairwise} // 0) + ($s->{s4_rescan} // 0);
            $grand_s5 += $genuinely_unmatched;
            $grand_s6 += $evicted;
            $grand_fc += ($s->{fc_calls} // 0);
            $grand_checkpoints += $checkpoints;
            $grand_patterns += $patterns;

            # --- Final pass phase (2-pass architecture) ---
            my $fp_keys = $s->{fp_keys_seen} // 0;
            if ($fp_keys > 0) {
                my $fp_p1_s3 = $s->{fp_p1_s3} // 0;
                my $fp_p1_ceiling = $s->{fp_p1_s2_ceiling} // 0;
                my $fp_p1_windows = $s->{fp_p1_windows} // 0;
                my $fp_p1_s4_pair = $s->{fp_p1_s4_pairwise} // 0;
                my $fp_p1_s4_rescan = $s->{fp_p1_s4_rescan} // 0;
                my $fp_p1_patterns = $s->{fp_p1_patterns} // 0;
                my $fp_p1_fc = $s->{fp_p1_fc_calls} // 0;
                my $fp_p1_cross = $s->{fp_p1_cross_merges} // 0;
                my $fp_p2_s3 = $s->{fp_p2_s3} // 0;

                push @verbose_output, sprintf("  --- %s: Final Pass (2-pass) ---", $cat_gk);
                push @verbose_output, sprintf("    Keys seen:             %d", $fp_keys);
                push @verbose_output, sprintf("    Pass 1:");
                push @verbose_output, sprintf("      S3 Pattern match:      %d", $fp_p1_s3);
                push @verbose_output, sprintf("      S2 Ceiling skipped:    %d  (occurrences >= %d)", $fp_p1_ceiling, $consolidation_final_ceiling);
                push @verbose_output, sprintf("      Windows processed:     %d  (capacity 1000)", $fp_p1_windows);
                push @verbose_output, sprintf("      S4 Pairwise discovery: %d", $fp_p1_s4_pair);
                push @verbose_output, sprintf("      S4 Re-scan absorbed:   %d", $fp_p1_s4_rescan);
                push @verbose_output, sprintf("      New patterns created:  %d", $fp_p1_patterns);
                push @verbose_output, sprintf("      find_candidates calls: %d", $fp_p1_fc);
                push @verbose_output, sprintf("      Cross-cluster merges:  %d", $fp_p1_cross);
                push @verbose_output, sprintf("    Pass 2:");
                push @verbose_output, sprintf("      S3 Absorbed (cleanup): %d", $fp_p2_s3);

                # Tracking invariant: all keys accounted for
                my $fp_absorbed = $fp_p1_s3 + $fp_p1_s4_pair + $fp_p1_s4_rescan + $fp_p2_s3;
                my $fp_remaining = $fp_keys - $fp_absorbed - $fp_p1_ceiling;
                push @verbose_output, sprintf("    Remaining unmatched:   %d", $fp_remaining);

                my $fp_accounted = $fp_p1_s3 + $fp_p1_ceiling + $fp_p1_s4_pair + $fp_p1_s4_rescan + $fp_p2_s3 + $fp_remaining;
                if ($fp_accounted != $fp_keys) {
                    push @verbose_output, sprintf("    [WARN] Tracking mismatch: %d accounted vs %d seen (delta %d)",
                        $fp_accounted, $fp_keys, $fp_keys - $fp_accounted);
                }
            }

            # Combined reduction: streaming keys_seen → final remaining
            my $final_remaining;
            if ($fp_keys > 0) {
                my $fp_absorbed = ($s->{fp_p1_s3} // 0) + ($s->{fp_p1_s4_pairwise} // 0) + ($s->{fp_p1_s4_rescan} // 0) + ($s->{fp_p2_s3} // 0);
                my $combined_patterns = exists $consolidation_patterns{$cat_gk} ? scalar @{$consolidation_patterns{$cat_gk}} : 0;
                $final_remaining = $fp_keys - $fp_absorbed - ($s->{fp_p1_s2_ceiling} // 0) + $combined_patterns;
                push @verbose_output, sprintf("    Reduction: %d -> %d (%.1f%%)",
                    $keys_seen, $final_remaining,
                    (1 - $final_remaining / ($keys_seen || 1)) * 100);
            } else {
                $final_remaining = $genuinely_unmatched + $evicted + $ceiling_filtered + $patterns;
                push @verbose_output, sprintf("    Reduction: %d -> %d (%.1f%%)",
                    $keys_seen, $final_remaining,
                    (1 - $final_remaining / ($keys_seen || 1)) * 100);
            }
        }

        if (scalar keys %consolidation_cat_stats > 1) {
            push @verbose_output, "";
            push @verbose_output, "=== message-grouping / grand-totals ===";
            push @verbose_output, sprintf("    Total keys seen:       %d", $grand_keys);
            push @verbose_output, sprintf("    Total S1 Inline:       %d", $grand_s1);
            push @verbose_output, sprintf("    Total S2 Ceiling:      %d", $grand_s2);
            push @verbose_output, sprintf("    Total S3 Checkpoint:   %d", $grand_s3);
            push @verbose_output, sprintf("    Total S4 Pairwise:     %d", $grand_s4);
            push @verbose_output, sprintf("    Total S5 Unmatched:    %d", $grand_s5);
            push @verbose_output, sprintf("    Total S6 Evicted:      %d", $grand_s6);
            push @verbose_output, sprintf("    Total checkpoints:     %d", $grand_checkpoints);
            push @verbose_output, sprintf("    Total patterns:        %d", $grand_patterns);
            push @verbose_output, sprintf("    Total fc calls:        %d", $grand_fc);
            push @verbose_output, "=== END message-grouping / grand-totals ===";
        }
        push @verbose_output, "=== END message-grouping ===";
        push @verbose_output, "";
    }
}

