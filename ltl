# Issue #45: Measure all data structures and update high-water marks
# Called after each major subroutine to capture peak memory usage
sub measure_memory_structures {
    # Always capture RSS high-water mark
    $current_memory_usage = get_memory_usage();
    if ($current_memory_usage > $max_memory_usage) {
        $max_memory_usage = $current_memory_usage;
    }

    # Only measure individual structures when -mem flag is used
    return unless $show_memory;

    my %current_sizes = named_structure_sizes();

    # Update high-water marks (only if current value is larger)
    for my $struct (keys %current_sizes) {
        my $current = $current_sizes{$struct};
        my $hwm = $memory_high_water_marks{$struct} // 0;
        if ($current > $hwm) {
            $memory_high_water_marks{$struct} = $current;
        }
    }
}

# -mem debug (Issue #356): per-phase memory diagnostics emitted on STDERR as
# TSV MEMDIAG lines. memory_debug_sample() is the cheap RSS-only probe safe
# to call from hot loops at a coarse cadence (each call is a syscall/exec on
# some platforms); memory_debug_decomposition() additionally walks the
# named-structure map (Devel::Size) and reports the unattributed remainder
# (RSS minus the sum of live named structures), so it runs only at phase
# boundaries. Diagnostic lines never carry the " at <file> line <N>" suffix
# reserved for interpreter warnings (tests/HARNESS-DESIGN.md § Runtime-warning
# cleanliness).
my $memory_debug_epoch;
my $memory_debug_key_samples = 0;   # shared cadence counter across per-key loops
sub memory_debug_sample {
    return unless $show_memory_debug;
    my ($tag) = @_;
    $memory_debug_epoch //= Time::HiRes::time();
    printf STDERR "MEMDIAG\t%.3f\t%s\trss=%d\n",
        Time::HiRes::time() - $memory_debug_epoch, $tag, get_memory_usage() // 0;
}
sub memory_debug_decomposition {
    return unless $show_memory_debug;
    my ($tag) = @_;
    $memory_debug_epoch //= Time::HiRes::time();
    my $rss = get_memory_usage() // 0;
    my %sizes = named_structure_sizes();
    my $named_sum = 0;
    $named_sum += $_ for values %sizes;
    my $unattributed = $rss - $named_sum;
    $unattributed = 0 if $unattributed < 0;
    printf STDERR "MEMDIAG-FULL\t%.3f\t%s\trss=%d\tnamed_sum=%d\tunattributed=%d\n",
        Time::HiRes::time() - $memory_debug_epoch, $tag, $rss, $named_sum, $unattributed;
    for my $struct (sort { $sizes{$b} <=> $sizes{$a} || $a cmp $b } keys %sizes) {
        last if $sizes{$struct} < 1_048_576;
        printf STDERR "MEMDIAG-STRUCT\t%s\t%s\t%d\n", $tag, $struct, $sizes{$struct};
    }
}

sub convert_bytes {
    my ($input_value, $input_unit) = @_;
    my ($value, $unit);

    if( defined( $input_unit ) ) {
        $value = $input_value;
        $unit = $input_unit;
    } else {
        ( $value, $unit ) = $input_value =~ /^(\d+)[ ]?(\w+)$/;
    }

    my %units = (
        'B'  => 1,
        'b'  => 1,
        'kB' => 1000,
        'k'  => 1000,
        'MB' => 1000**2,
        'M'  => 1000**2,
        'GB' => 1000**3,
        'G'  => 1000**3,
        'TB' => 1000**4,
        'T'  => 1000**4,
        'KB'  => 1024,
        'K'   => 1024,
        'KiB' => 1024,
        'MiB' => 1024**2,
        'GiB' => 1024**3,
        'TiB' => 1024**4,
    );

    my $bytes = $value * $units{$unit};

    return $bytes;
}

sub format_bytes {
    my ($value, $unit, $decimals) = @_;
    $decimals = 1 if !defined $decimals;
    my %units = (
        'b'  => 1,
        'B'  => 1,
        'KiB' => 1024,
        'MiB' => 1024**2,
        'GiB' => 1024**3,
        'TiB' => 1024**4,
    );

    return undef unless defined $value;

    my $bytes = $value * $units{$unit};
    my $bytes_int = int($bytes);  # Use integer for unit comparison to avoid float string length issues

    my @unit_order = ('B', 'KiB', 'MiB', 'GiB', 'TiB');
    my $formatted_value = $bytes;
    my $formatted_unit = 'B';

    foreach my $u (@unit_order) {                                           # Determine the most relevant unit
        if( length( $bytes_int ) >= length( $units{$u} ) ) {
# TO DO: 1000kB should convert to MB
        #if ($bytes >= $units{$u}) {
            $formatted_value = $bytes / $units{$u};
            $formatted_unit = $u;
        } else {
            last;
        }
    }

    $formatted_value = sprintf("%.${decimals}f", $formatted_value);
    $formatted_value =~ s/\.0+(?=\s|$)//;             # remove trailing .0 if followed by space or end of string

    return "$formatted_value $formatted_unit";
}

# Build CSV output filename with truncation to avoid filesystem errors
sub build_csv_filename {
    my ($file_type) = @_;  # 'STATS' or 'MESSAGES'
    my ($sec, $min, $hour, $mday, $mon, $year) = localtime();
    my $timestamp = sprintf("%04d-%02d-%02d_%02d%02d%02d", $year + 1900, $mon + 1, $mday, $hour, $min, $sec);

    # Sanitize args: replace special characters with underscores
    my $safe_args = $csv_file_args;
    $safe_args =~ tr/!@#\$%\^&*()_+{}|:"<>?[\];',.\/\\`~ /_/;

    # Build base filename
    my $base = "${timestamp}-LTL-${file_type}-${safe_args}";
    my $extension = ".csv";

    # Truncate if exceeds max length (accounting for extension)
    my $max_base_length = $csv_filename_max_length - length($extension);
    if (length($base) > $max_base_length) {
        $base = substr($base, 0, $max_base_length - 3) . '...';
    }

    return "${base}${extension}";
}

# Wrap text to fit within max_width, breaking on spaces
# Returns array of lines
sub wrap_text {
    my ($text, $max_width) = @_;
    return ($text) if length($text) <= $max_width;

    my @words = split /\s+/, $text;
    my @lines;
    my $current_line = '';

    foreach my $word (@words) {
        if ($current_line eq '') {
            $current_line = $word;
        } elsif (length($current_line) + 1 + length($word) <= $max_width) {
            $current_line .= ' ' . $word;
        } else {
            push @lines, $current_line;
            $current_line = $word;
        }
    }
    push @lines, $current_line if $current_line ne '';

    return @lines;
}

# Shorten filename to fit within max_length, keeping start and end with '...' in middle
# If $strip_path is true, removes directory path first (keeps only basename)
sub shorten_filename {
    my ($filename, $max_length, $strip_path) = @_;

    # Optionally strip directory path, keeping only the filename
    if ($strip_path) {
        $filename =~ s{.*/}{};  # Remove everything up to and including last /
        $filename =~ s{.*\\}{}; # Also handle Windows backslashes
    }

    return $filename if length($filename) <= $max_length;
    return $filename if $max_length < 10;  # Too short to meaningfully shorten

    my $ellipsis = '...';
    my $available = $max_length - length($ellipsis);
    my $left_len = int($available / 2);
    my $right_len = $available - $left_len;

    return substr($filename, 0, $left_len) . $ellipsis . substr($filename, -$right_len);
}

sub format_number {
    my ($value, $space, $decimals) = @_;
    my %units = (
        '1'  => 1,
        'k' => 1000,
        'Mil' => 1000**2,
        'Bil' => 1000**3,
        'Tril' => 1000**4,
    );

    my @unit_order = ('1', 'k', 'Mil', 'Bil', 'Tril');
    my $formatted_value = $value;
    my $formatted_unit = '';
    $decimals = 1 if !defined $decimals;

    foreach my $u (@unit_order) {                  # Determine the most relevant unit
        if ($value >= $units{$u}) {
            $formatted_value = $value / $units{$u};
            $formatted_unit = $u;
        } else {
            last;
        }
    }

    $formatted_value = sprintf("%.${decimals}f%s%s", $formatted_value, defined($space) ? " " : "", $formatted_unit eq "1" ? "" : $formatted_unit );
    $formatted_value =~ s/\.0+(?=\s|$)//;             # remove trailing .0 if followed by space or end of string

    return $formatted_value;
}

sub format_time {
    my ($value, $unit, $format, $space) = @_;
    my %units = (
        'us' => 1,                      # Microseconds
        'ms' => 1000,                   # Milliseconds
        's'  => 1000000,                # Seconds
        'm'  => 60 * 1000000,           # Minutes
        'h'  => 60 * 60 * 1000000,      # Hours
        'D'  => 24 * 60 * 60 * 1000000, # Days
    );

    my %unit_names = (
        'us' => { short => 'us', medium => 'usec', long => 'microseconds' },
        'ms' => { short => 'ms', medium => 'msec', long => 'milliseconds' },
        's'  => { short => 's',  medium => 'sec',      long => 'seconds' },
        'm'  => { short => 'm',  medium => 'min',      long => 'minutes' },
        'h'  => { short => 'h',  medium => 'hr',       long => 'hours' },
        'D'  => { short => 'd',  medium => 'day',      long => 'days' },
    );

    $format = "short" if !defined $format;

    my $microseconds = $value * $units{$unit};


    my @unit_order = ('us', 'ms', 's', 'm', 'h', 'D');
    my $formatted_value = $microseconds;
    my $formatted_unit = 'us';

    foreach my $u (@unit_order) {          # Determine the most relevant unit
        if ($microseconds >= $units{$u}) {
            $formatted_value = $microseconds / $units{$u};
            $formatted_unit = $u;
        } else {
            last;
        }
    }

    $formatted_value = sprintf("%.1f", $formatted_value);
    $formatted_value =~ s/\.0+(?=\s|$)//;                                                    # remove trailing .0 if followed by space or end of string
    

    my $unit_name = $unit_names{$formatted_unit}{$format};                                  # Get the appropriate unit name based on format
    $unit_name =~ s/s$// if $formatted_value == 1 && $format eq 'long';                     # Singular units for long format
    $unit_name = " " . $unit_name if defined( $space );

    return defined $value ? "$formatted_value$unit_name" : undef;
}

# Render a duration statistic (millisecond-valued) for terminal display. A
# millisecond-precision source cannot resolve finer than 1 ms, so synthesized
# sub-grid values (the bin-counter percentile path interpolates inside a
# log-spaced bin and lands off the integer-ms grid) are first rounded to the
# source's native resolution before format_time auto-scales the unit. The value
# always passes through format_time so the unit is always present — there is no
# bare-number bypass for small magnitudes.
my %duration_display_decimals = ( ns => 6, us => 3, ms => 0, s => 0 );
# Render a millisecond-valued duration for display. With $max_chars set, the
# result is guaranteed to fit that many characters: if the auto-scaled value
# carries a fractional digit that pushes it over budget (e.g. "264.4ms" = 7 in
# a 6-char cell under -du us), the decimal is dropped to fit ("264ms" = 5)
# rather than clipping the unit and rendering a misleading "264.4m". The
# fractional digit is the only expendable part — the unit is never truncated.
# Callers that lay out fixed-width columns (the latency-stats cells) pass their
# per-cell budget so the column stays aligned regardless of magnitude.
sub format_duration {
    my ($value, $max_chars) = @_;
    return "" unless defined $value;
    my $unit = $duration_unit_resolved // 'ms';
    # format_time auto-scales 0 down to the smallest unit (0us); render zero in
    # the source's resolved unit instead so it reads as "zero <source unit>".
    return "0$unit" if $value == 0;
    my $decimals = $duration_display_decimals{$unit} // 0;
    my $rounded  = sprintf( "%.${decimals}f", $value );
    my $out = format_time( $rounded, 'ms', 'short' );
    # Fit the budget by shedding the fractional digit before any clipping.
    if (defined $max_chars && length($out) > $max_chars && $out =~ /\.\d/) {
        (my $no_frac = $out) =~ s/\.\d+//;
        $out = $no_frac if length($no_frac) <= $max_chars;
    }
    return $out;
}

