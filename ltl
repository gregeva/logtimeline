# so the two always agree on what counts as an informational invocation. Version
# is not suppressed: --version keeps the normal title banner. This runs before
# the -?/help alias remap in adapt_to_command_line_options(), so it relies on the
# classifier recognizing the raw -?, /help, /? aliases directly.
my $_help_or_explain_invoked = grep {
    my $info = classify_informational_arg($_);
    $info && ($info->{kind} eq 'help' || $info->{kind} eq 'explain');
} @ARGV;
