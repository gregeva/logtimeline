    printf "CONFIG\tterminal_width\t%d\n", $terminal_width;
    printf "CONFIG\tterminal_height\t%d\n", $terminal_height;
    printf "CONFIG\tmax_log_message_length\t%d\n", $max_log_message_length;
    printf "CONFIG\ttime_bucket_size\t%d\n", $time_bucket_size;
    printf "CONFIG\tbucket_size_seconds\t%.2f\n", $bucket_size_seconds;

    print "=== END benchmark-data ===\n";
}

sub print_bar_graph {
    my $lines_printed = 0;
    my @csv_data;

    if( $total_lines_included ) {
        print "\n$colors{'bright-black'}" . "─" x $terminal_width . "$colors{'NC'}\n";

        print $colors{'bright-black'};

        for my $col (grep { $_->{visible} } @column_layout) {
            my $col_w = $col->{width} // 0;

            if ($col->{type} eq 'separator') {
                # Separators render as whitespace in headers
                print ' ' x (($col->{spacing_before}//0) + $col_w + ($col->{spacing_after}//0));
                next;
            }

            # Print spacing before column
            print ' ' x ($col->{spacing_before} // 0);

            # Get column name, truncate to width
            my $name = $col->{name} // '';
            $name =~ s/^udm_//;
            $name = substr($name, 0, $col_w) if $col_w > 0 && length($name) > $col_w;

            # Center the name within column width
            my $padding = $col_w - length($name);
            $padding = 0 if $padding < 0;
            my $left_pad  = int( $padding / 2 + 0.5 );
            my $right_pad = $padding - $left_pad;

            print ' ' x $left_pad if $left_pad > 0;
            print $name;
            print ' ' x $right_pad if $right_pad > 0;

            # Print spacing after column
            print ' ' x ($col->{spacing_after} // 0);
        }

        print "\n$colors{'bright-black'}" . "─" x $terminal_width . "$colors{'NC'}\n";
        $lines_printed++;

        # Under a week/workweek profile, the weekday name prefixes only the
        # first bucket of each day; repeated rows within the same day blank it
        # (replaced with equal-width spaces so the column stays aligned), acting
        # as a date-change marker. %a is 3 chars wide; the format is "%a %H:%M".
        my $profile_week_fold = ($profile_mode && $output_timestamp_format =~ /%a/) ? 1 : 0;
        my $prev_fold_wday;
        foreach my $bucket (sort { $a <=> $b } keys %log_occurrences) {
            my $bucket_time_str;
            if ($print_milliseconds) {
                # Bucket is integer milliseconds - convert to seconds for gmtime, extract ms part
                $bucket_time_str = strftime($output_timestamp_format, gmtime($bucket / 1000));
                $bucket_time_str .= sprintf ".%03d", $bucket % 1000;
            } else {
                $bucket_time_str = strftime($output_timestamp_format, gmtime($bucket));
            }
            # Blanking the repeated weekday is a terminal-display affordance only.
            # The CSV must keep the full folded timestamp on every row so each
            # row is self-describing (a blanked "    10:00" would be ambiguous to
            # a consumer), so the blank is applied to a separate display copy and
            # $bucket_time_str — the value pushed to the CSV row below — is left
            # whole.
            my $bucket_time_display = $bucket_time_str;
            if ($profile_week_fold) {
                my $wday = (gmtime($print_milliseconds ? $bucket / 1000 : $bucket))[6];
                if (defined $prev_fold_wday && $wday == $prev_fold_wday) {
                    substr($bucket_time_display, 0, 3) = '   ';   # blank the repeated weekday
                }
                $prev_fold_wday = $wday;
            }
            my $total_occurrences = 0;

            my $log_details = "";
            my $rate_metrics = "";
            my $legend_length_bucket = 0;
            my %output_columns;
            my $scaled_occurrences_total = 0;

            ## LOOP THROUGH LOG CATEGORY BUCKETS AND BUILD PER ROW LEGEND COUNTS
            foreach my $category_bucket (@log_levels) {
                if (exists $log_occurrences{$bucket}{$category_bucket}) {
                    my $occurrences = $log_occurrences{$bucket}{$category_bucket}{occurrences};
                    my $color = $colors{$category_bucket} // $colors{'NC'};

                    # Always accumulate total occurrences for CSV output, regardless of display options.
                    # Highlighted lines are counted only under their '-HL' key (the suffix replaces
                    # the key at the highlight tag point), so plain and '-HL' keys partition the
                    # bucket: both must be summed for the total to equal all lines in the bucket.
                    # Only the derived rate rows and the normalization placeholder are excluded.
                    $total_occurrences += $occurrences if $category_bucket !~ /^(err-rate|msg-rate|empty)$/;

                    next if $omit_values && $category_bucket !~ /^(err-rate|msg-rate)$/;	# we don't want to count data that won't be printed
                    next if $category_bucket =~ /^(err|msg)-rate$/ && $log_occurrences{$bucket}{'err-rate'}{occurrences} == 0 && $log_occurrences{$bucket}{'msg-rate'}{occurrences} == 0;

                    if( $category_bucket =~ /(-HL|err-rate|msg-rate)$/ ) {
                        if( $category_bucket =~ /^err-rate$/ ) {
                            $rate_metrics .= " " if !$omit_values;
                            $rate_metrics .= "${color}" . format_number( $occurrences ) . "$colors{'NC'}";
                            $rate_metrics .= "$colors{'bright-black'}:$colors{'NC'}";
                            $legend_length_bucket += length( " " ) if !$omit_values;
                            $legend_length_bucket += length( format_number( $occurrences ) . ":" );
                        } elsif( $category_bucket =~ /^msg-rate$/ ) {
                            $rate_metrics .= "${color}" . format_number( $occurrences ) . "$colors{'NC'}";
                            $rate_metrics .= "$colors{'bright-black'}$rate_suffix{$rate_unit}$colors{'NC'} ";
                            $legend_length_bucket += length( format_number( $occurrences ) . "$rate_suffix{$rate_unit} " );
                        } else {
                            $log_details .= "${color}$occurrences$colors{'NC'}" . " " if $category_bucket =~ /-HL$/;
                            $legend_length_bucket += length("$occurrences ");
                        }
                    } elsif( $occurrences < 1 ) {					 		# don't include the empty bucket who's purpose is to normalize the buckets represented
                        next;
                    } else {
                        $log_details .= "$color$category_bucket: $occurrences$colors{'NC'} ";
                        $legend_length_bucket += length("$category_bucket: $occurrences ");
                    }

                    $output_columns{$category_bucket} = $occurrences;
# 2026-01-04 TO DO: this may not be required, test after fixing the count and byte metric collection with no duration stats
                } else {
                    $output_columns{$category_bucket} = 0;                                  # push empty value to CSV data list
                }
            }

            # Add the log level message counts to the output CSV file
            foreach my $category_bucket ( @output_columns ) {
               next if $category_bucket =~ /^timestamp$/;								# skip the first column and get to the counts
               last if $category_bucket =~ /^occurrences$/;								# only fill in empty values up to the occurrences column

               if( exists $output_columns{$category_bucket} ) {								# if there was a count for this log level, add it to the list
                   # Issue #268: level-family columns (log-level counts and
                   # rate columns) route through format_csv_value() so the
                   # --csv-precision mode controls emit. Rate columns get a
                   # per-column override of 1 decimal in default mode.
                   push @csv_data, format_csv_value($output_columns{$category_bucket}, $category_bucket);

# 2026-01-04 TO DO: this may not be required, test after fixing the count and byte metric collection with no duration stats
               } else {
                   push @csv_data, undef;										# if there wasn't a count for this log level, add a blank column
               }
            }

            push @csv_data, format_csv_value($total_occurrences, 'occurrences');			# add the total message count to the output CSV data

            ## RENDER ROW BY ITERATING @column_layout
            for my $col (grep { $_->{visible} } @column_layout) {
                my $col_id   = $col->{id};
                my $col_type = $col->{type};
                my $col_w    = $col->{width} // 0;

                # Print spacing before this column
                print " " x ($col->{spacing_before} // 0);

                if ($col_id eq 'timestamp') {
                    # Emphasize the weekday token on the day-boundary rows of a
                    # week/workweek fold: bold + upper-cased (MON, TUE, ...),
                    # leaving the time and the blanked-weekday rows plain. Uses
                    # the display copy (whose repeated weekday is blanked); the
                    # full mixed-case $bucket_time_str goes to the CSV. The
                    # upper-cased token is the same 3 chars, so column alignment
                    # is unchanged.
                    if ($profile_week_fold && $bucket_time_display =~ /^([A-Z][a-z][a-z])(\s.*)$/) {
                        print "\033[1m" . uc($1) . "$colors{'NC'}$2";
                    } else {
                        print $bucket_time_display;
                    }

                } elsif ($col_id eq 'legend') {
                    print $log_details unless $omit_values;
                    my $padding = $legend_length - $legend_length_bucket;
                    print " " x ($padding > 0 ? $padding : 0);
                    print $rate_metrics unless $omit_rate;

                } elsif ($col_type eq 'separator') {
                    print "$colors{'bright-black'}│$colors{'NC'}";

                } elsif ($col_id eq 'occurrences') {
                    # Print category-colored blocks
                    foreach my $category_bucket (@log_levels) {
                        next unless $category_bucket !~ /^empty|err-rate|msg-rate$/;
                        if (exists $log_occurrences{$bucket}{$category_bucket}) {
                            my $scaled_occurrences = $log_occurrences{$bucket}{$category_bucket}{scaled_occurrences};
                            $scaled_occurrences = 0 if $scaled_occurrences < 0;
                            my $color = $colors{$category_bucket} // $colors{'NC'};
                            print "$color" . $blocks{$default_chart_block} x $scaled_occurrences . "$colors{'NC'}";
                            $scaled_occurrences_total += $scaled_occurrences;
                        }
                    }
                    # Fill remaining width with spaces
                    my $remaining = $col_w - $scaled_occurrences_total;
                    print " " x $remaining if $remaining > 0;

                } elsif ($col_type eq 'proportional' && $col_id ne 'occurrences') {
                    # Secondary metric bar (duration, bytes, count, UDMs, threadpools)
                    my $key = $col_id;
                    my $scaled_trend_key = "scaled_${key}";
                    my $scaled_trend_key_highlight = "${scaled_trend_key}-HL";
                    my $scaled_trend_value = $log_stats{$bucket}{$scaled_trend_key};
                    my $trend_value = $log_stats{$bucket}{$key};

                    if( defined $log_stats{$bucket}{$key} ) {
                        # Issue #289: this branch now computes $trend_value for terminal
                        # DISPLAY only. CSV emission of the proportional-metric columns
                        # moved to the visibility-independent post-loop builder below
                        # (build_proportional_csv_data), so an auto-hidden or
                        # heatmap-replaced column no longer drops its CSV value or
                        # misaligns the row (mirrors the latency-stats block's design).
                        if( $key =~ /^(time|duration)$/i ) {
                            my $time_format = $col_w >= 15 ? 'long' : ($col_w >= 10 ? 'medium' : 'short');
                            my $time_space = $time_format eq 'short' ? undef : ' ';
                            $trend_value = " " . format_time( $log_stats{$bucket}{$key}, 'ms', $time_format, $time_space );
                        } elsif( $key =~ /^bytes$/i ) {
                            $trend_value = " " . format_bytes( $log_stats{$bucket}{$key}, 'B' );
                        } elsif( $key =~ /^count$/i ) {
                            $trend_value = " " . format_number( $log_stats{$bucket}{$key}, ' ', 2);
                        } elsif( $key =~ /^udm_(.+)$/ ) {
                            my $metric_name = $1;
                            my ($config) = grep { $_->{name} eq $metric_name } @udm_configs;
                            if ($config) {
                                my $unit_type = $config->{unit_type};
                                if ($unit_type eq 'time') {
                                    my $fmt = $col_w >= 15 ? 'long' : ($col_w >= 10 ? 'medium' : 'short');
                                    my $spc = $fmt eq 'short' ? undef : ' ';
                                    $trend_value = " " . format_time($log_stats{$bucket}{$key}, 'ms', $fmt, $spc);
                                } elsif ($unit_type eq 'bytes') {
                                    $trend_value = " " . format_bytes($log_stats{$bucket}{$key}, 'B');
                                } else {
                                    $trend_value = " " . format_number($log_stats{$bucket}{$key}, ' ', 2);
                                    $trend_value .= $rate_suffix{$rate_unit}
                                        if $config->{aggregation} =~ /^(rate|drate)$/;
                                }
                            }
                        } else {
                            my $decimals = $col_w > 10 ? 2 : ($col_w > 8 ? 1 : 0);
                            $trend_value = defined $log_stats{$bucket}{$key} ? " " . format_number( $log_stats{$bucket}{$key}, ' ', $decimals) : "";
                        }

                        # Render the metric bar using color from column layout
                        my $col_color = $col->{color};
                        print $col_color->{highlighted_bg};

                        for my $i ( 0 .. $col_w - 1) {
                            my $value_char = (split //, $trend_value )[$i];

                            if( defined $log_stats{$bucket}{$scaled_trend_key_highlight} && $log_stats{$bucket}{$scaled_trend_key_highlight} == $i ) {
                                print $col_color->{plain_bg};
                            }

                            if( defined $scaled_trend_value && $i == $scaled_trend_value ) {
                                print $col_color->{fg};
                            }

                            print length( $value_char ) ? $value_char : " ";
                        }

                        print "$colors{'NC'}\033[0m";

                    } else {
                        # No data for this column in this bucket — print empty space
                        print " " x $col_w;
                    }

                } elsif ($col_id eq 'latency') {
                    # Duration statistics — terminal display only. CSV emission of
                    # these stats happens after the column loop, independent of
                    # whether this column is visible (so auto-hide on narrow
                    # terminals does not silently drop the values from -o output).
                    if( defined $log_stats{$bucket}{bytes} || defined $log_stats{$bucket}{p50} || defined $log_stats{$bucket}{p95} || defined $log_stats{$bucket}{p99} || defined $log_stats{$bucket}{p999} || defined $log_stats{$bucket}{cv} ) {
                        my $cv_color = defined $log_stats{$bucket}{cv} && $log_stats{$bucket}{cv} >= 20 ? 'WARN-HL' : 'white-underline';

                        # Each percentile cell occupies a fixed slot so the
                        # column stays aligned within the reserved latency width
                        # (P50/P95/P99 = 11 chars: "Pxx:" + 6 value + space;
                        # P999 = 12: "P999:" + 6 value + space; CV = 7).
                        # format_duration is given the 6-char value budget so it
                        # sheds the fractional digit to fit (e.g. 264.4ms -> 264ms)
                        # rather than overflowing; %-6.6s is the final guard.
                        defined $log_stats{$bucket}{p50} ? printf( "$colors{'cyan'}P50:%-6.6s$colors{'NC'} ", format_duration( $log_stats{$bucket}{p50}, 6 ) ) : printf( " " x 11 );
                        defined $log_stats{$bucket}{p95} ? printf( "$colors{'yellow'}P95:%-6.6s$colors{'NC'} ", format_duration( $log_stats{$bucket}{p95}, 6 ) ) : printf( " " x 11 );
                        defined $log_stats{$bucket}{p99} ? printf( "$colors{'bright-yellow'}P99:%-6.6s$colors{'NC'} ", format_duration( $log_stats{$bucket}{p99}, 6 ) ) : printf( " " x 11 );
                        defined $log_stats{$bucket}{p999} ? printf( "$colors{'red'}P999:%-6.6s$colors{'NC'} ", format_duration( $log_stats{$bucket}{p999}, 6 ) ) : printf( " " x 12 );
                        defined $log_stats{$bucket}{cv} ? printf( "$colors{$cv_color}CV:%4.4s$colors{'NC'}", format_cv_display( $log_stats{$bucket}{cv} ) ) : printf ( " " x 7 );
                    }

                } elsif ($col_id eq 'heatmap') {
                    print_heatmap_row($bucket);
                }

                # Print spacing after this column
                print " " x ($col->{spacing_after} // 0);
            }

            # Issue #289: emit the proportional-metric CSV columns independent of
            # @column_layout render visibility. The previous in-loop pushes only
            # fired for VISIBLE columns, so a metric column that was auto-hidden
            # (narrow terminal) or replaced by the heatmap row silently dropped its
            # CSV value and shifted every subsequent column. This builder walks
            # @populated_graph_columns in the SAME order as the @output_columns
            # header build (normalize_data_for_output) so header and data stay
            # aligned by construction. _nice columns use a stable, width-independent
            # format (the CSV is not terminal-geometry-bound; the rendered bar still
            # formats per column width above).
            foreach my $key (@populated_graph_columns) {
                if( $key =~ /^(time|duration)$/i ) {
                    push @csv_data,
                        (defined $log_stats{$bucket}{$key} ? ltrim(format_time($log_stats{$bucket}{$key}, 'ms', 'medium', ' ')) : undef),
                        format_csv_value( $log_stats{$bucket}{$key}, 'duration' );
                } elsif( $key =~ /^bytes$/i ) {
                    push @csv_data,
                        (defined $log_stats{$bucket}{$key} ? format_bytes($log_stats{$bucket}{$key}, 'B') : undef),
                        format_csv_value( $log_stats{$bucket}{$key}, 'bytes' );
                } elsif( $key =~ /^count$/i ) {
                    next if $omit_count;
                    foreach my $metric ( qw( occurrences min mean max sum ) ) {
                        push @csv_data, format_csv_value( $log_stats{$bucket}{"count_${metric}"}, "count_${metric}" );
                    }
                } elsif( $key =~ /^udm_(.+)$/ ) {
                    my $metric_name = $1;
                    my ($config) = grep { $_->{name} eq $metric_name } @udm_configs;
                    if ($config && ($config->{agg_kind} eq 'counting' || $config->{name} ne $config->{base_name})) {
                        # Single value column: counting aggregation (#313) or
                        # disambiguated metric (#99)
                        push @csv_data, format_csv_value( $log_stats{$bucket}{$key}, $key );
                    } else {
                        foreach my $metric ( qw( occurrences min mean max sum ) ) {
                            push @csv_data, format_csv_value( $log_stats{$bucket}{"${key}_${metric}"}, "${key}_${metric}" );
                        }
                    }
                } else {
                    push @csv_data, format_csv_value( $log_stats{$bucket}{$key}, $key );
                }
            }

            # Append latency stats to CSV data. The header lists these columns
            # under the same shared predicate (see normalize_data_for_output),
            # so rows always match the header regardless of whether the latency
            # *display column* was auto-hidden by terminal width (Issue #263)
            # or replaced by the heatmap row on the terminal surface (Issue #289).
            if( stats_csv_duration_columns_active() ) {
                foreach my $stat ( qw( min mean max std_dev p1 p5 p10 p25 p50 p75 iqr p90 p95 p99 p999 p9999 p99999 cv skewness kurtosis bimodality_coef ) ) {
                    push @csv_data, format_csv_value( $log_stats{$bucket}{$stat}, $stat );
                }
            }

            # Print statistics for time-bucket statistics to the CSV file if activated
            if( $write_messages_to_csv && defined $csv_fh ) {
                # Pad row to header width so every row has the same field count.
                # Trailing empties (percentile/shape cols on no-duration buckets)
                # would otherwise emit short rows that misalign downstream consumers.
                my @row = ( $bucket_time_str, @csv_data );
                my $target_width = scalar @output_columns;
                push @row, (undef) x ( $target_width - scalar @row ) if scalar @row < $target_width;
                $csv->print($csv_fh, \@row);
            }

            undef @csv_data;

            print "\n";
            pause_for_keypress() if( $pause_output && $lines_printed++ > 1 && $lines_printed % ( $terminal_height - 1 ) == 0 );
        }

        # Print footer line - with embedded heatmap scale if enabled
        if ($heatmap_enabled) {
            print_heatmap_footer_scale();
        } else {
            print "$colors{'bright-black'}" . "─" x $terminal_width . "$colors{'NC'}\n";
        }
    } else {
        printf "Read $total_lines_read lines, however no lines matched any of the patterns within the timeframe.\n";
    }
    return;
}

# ============================================================================
# HISTOGRAM RENDERING FUNCTIONS (Issue #25)
# ============================================================================

# Main histogram printing function
sub print_histograms {
    return unless $histogram_enabled;

    my $layout = calculate_histogram_layout();
    return unless $layout->{histogram_count};

    my @metrics = @{$layout->{active_metrics}};
    my $height = $layout->{height};
    my $bar_width = $layout->{bar_area_width};
    my $single_width = $layout->{single_width};
    my $centering_offset = $layout->{centering_offset};
    my $gap = $histogram_gap;

    # Get box drawing characters for current weight setting
    my %box = %{$histogram_box_sets{$histogram_box_weight}};

    print "\n";  # Separator from bar graph

    # Build all histogram output line by line for side-by-side rendering
    my @all_lines = ();

    # For each metric, pre-calculate display data
    my %metric_data = ();
    for my $metric (@metrics) {
        my $boundaries = $histogram_boundaries{$metric};
        my @buckets = @{$histogram_buckets{$metric}};
        my $bucket_count = scalar(@buckets);
        my $stats = $histogram_stats{$metric};

        # Calculate display scaling
        my @display_buckets = calculate_histogram_display_buckets(\@buckets, $bar_width);

        # Issue #42: Calculate highlight display buckets if highlight data exists
        my @display_buckets_hl = ();
        my $stats_hl = undef;
        if ($highlight_active && @{$histogram_buckets_hl{$metric}}) {
            @display_buckets_hl = calculate_histogram_display_buckets($histogram_buckets_hl{$metric}, $bar_width);
            $stats_hl = $histogram_stats_hl{$metric};
        }

        # Find max for scaling
        my $max_bucket = 0;
        for my $b (@display_buckets) {
            $max_bucket = $b if $b > $max_bucket;
        }
        $max_bucket = 1 if $max_bucket == 0;

        # Calculate Y-axis tick positions
        my $y_ticks = calculate_histogram_y_ticks($height);

        # Calculate X-axis labels
        my $x_labels = calculate_histogram_x_labels($boundaries, $bar_width, $metric);

        # Issue #185: precompute the percentile set shared by the legend and the axis ticks
        my ($selected_pcts, $pct_separator) = select_histogram_percentiles($stats, $bar_width, $metric);
        my $percentile_cols = calculate_histogram_percentile_ticks($selected_pcts, $boundaries, $bar_width);

        $metric_data{$metric} = {
            display_buckets    => \@display_buckets,
            display_buckets_hl => \@display_buckets_hl,
            max_bucket         => $max_bucket,
            y_ticks            => $y_ticks,
            x_labels           => $x_labels,
            boundaries         => $boundaries,
            stats              => $stats,
            stats_hl           => $stats_hl,
            selected_pcts      => $selected_pcts,
            pct_separator      => $pct_separator,
            percentile_cols    => $percentile_cols,
        };
    }

    # Title row - center title within each histogram's single_width
    my $title_line = " " x $centering_offset;
    for my $i (0 .. $#metrics) {
        my $metric = $metrics[$i];
        my $title = (grep { $_->{name} eq $metric } @histogram_udm_configs)
            ? "$metric Distribution"
            : ucfirst($metric) . " Distribution";
        my $title_padding_left = int(($single_width - length($title)) / 2);
        $title_padding_left = 0 if $title_padding_left < 0;
        my $title_padding_right = $single_width - $title_padding_left - length($title);
        $title_padding_right = 0 if $title_padding_right < 0;
        $title_line .= " " x $title_padding_left . $title . " " x $title_padding_right;
        $title_line .= " " x $gap if $i < $#metrics;
    }
    push @all_lines, $title_line;

    # Column headers (Count / %) - "Count" over left Y-axis, "%" over right Y-axis
    # Left Y-axis area: 7 chars (6 digits + 1 space) + 1 tick = 8 chars, "Count" is 5 chars
    # Right Y-axis area: 1 tick + 5 chars (space + 3 digits + %) = 6 chars, "%" is 1 char
    my $header_line = " " x $centering_offset;
    for my $i (0 .. $#metrics) {
        # Center "Count" in left margin (8 chars): pad to center 5-char word
        my $count_label = " Count  ";  # 8 chars total
        # Bar area
        my $bar_area = " " x $bar_width;
        # Center "%" in right margin (6 chars): pad to center 1-char symbol
        my $pct_label = "   %  ";  # 6 chars total
        $header_line .= $count_label . $bar_area . $pct_label;
        $header_line .= " " x $gap if $i < $#metrics;
    }
    push @all_lines, $header_line;

    # Bar rows (top to bottom)
    for my $row (reverse 0 .. $height - 1) {
        my $row_line = " " x $centering_offset;

        for my $i (0 .. $#metrics) {
            my $metric = $metrics[$i];
            my $data = $metric_data{$metric};
            my $row_str = render_histogram_row(
                $metric, $row, $height, $bar_width,
                $data->{display_buckets}, $data->{display_buckets_hl},
                $data->{max_bucket}, $data->{y_ticks}, \%box
            );
            $row_line .= $row_str;
            $row_line .= " " x $gap if $i < $#metrics;
        }

        push @all_lines, $row_line;
    }

    # X-axis line
    my $xaxis_line = " " x $centering_offset;
    for my $i (0 .. $#metrics) {
        my $metric = $metrics[$i];
        my $data = $metric_data{$metric};
        my $xaxis_str = render_histogram_x_axis($bar_width, $data->{x_labels}, \%box, $data->{percentile_cols});
        $xaxis_line .= $xaxis_str;
        $xaxis_line .= " " x $gap if $i < $#metrics;
    }
    push @all_lines, $xaxis_line;

    # X-axis labels
    my $xlabel_line = " " x $centering_offset;
    for my $i (0 .. $#metrics) {
        my $metric = $metrics[$i];
        my $data = $metric_data{$metric};
        my $xlabel_str = render_histogram_x_labels($bar_width, $data->{x_labels}, $single_width);
        $xlabel_line .= $xlabel_str;
        $xlabel_line .= " " x $gap if $i < $#metrics;
    }
    push @all_lines, $xlabel_line;

    # Legend (percentiles) - may have 1 or 2 lines depending on highlight data
    my $legend_line = " " x $centering_offset;
    my $legend_line_hl = " " x $centering_offset;
    my $has_any_highlight = 0;

    for my $i (0 .. $#metrics) {
        my $metric = $metrics[$i];
        my $data = $metric_data{$metric};
        my ($legend_str, $legend_str_hl) = render_histogram_legend($metric, $data->{selected_pcts}, $data->{pct_separator}, $data->{stats_hl}, $bar_width, $single_width);
        $legend_line .= $legend_str;
        $legend_line .= " " x $gap if $i < $#metrics;
        if (defined $legend_str_hl) {
            $legend_line_hl .= $legend_str_hl;
            $has_any_highlight = 1;
        } else {
            $legend_line_hl .= " " x $single_width;
        }
        $legend_line_hl .= " " x $gap if $i < $#metrics;
    }

    # Add spacing before legend
    for (1 .. $histogram_legend_spacing) {
        push @all_lines, "";
    }
    push @all_lines, $legend_line;
    push @all_lines, $legend_line_hl if $has_any_highlight;

    # Print all lines
    for my $line (@all_lines) {
        print "$line\n";
    }

    return;
}

# Calculate display buckets (scale statistical buckets to display width)
sub calculate_histogram_display_buckets {
    my ($buckets_ref, $bar_width) = @_;
    my @buckets = @$buckets_ref;
    my $bucket_count = scalar(@buckets);

    my @display_buckets;
    my $cols_per_bucket = $bar_width / $bucket_count;

    if ($cols_per_bucket >= 1) {
        # Expand: each bucket maps to one or more display columns
        for my $i (0 .. $bar_width - 1) {
            my $bucket_idx = int($i / $cols_per_bucket);
            $bucket_idx = $bucket_count - 1 if $bucket_idx >= $bucket_count;
            push @display_buckets, $buckets[$bucket_idx];
        }
    } else {
        # Compress: multiple buckets aggregate to each display column
        my $buckets_per_col = $bucket_count / $bar_width;
        for my $i (0 .. $bar_width - 1) {
            my $start_bucket = int($i * $buckets_per_col);
            my $end_bucket = int(($i + 1) * $buckets_per_col) - 1;
            $end_bucket = $bucket_count - 1 if $end_bucket >= $bucket_count;
            my $sum = 0;
            for my $j ($start_bucket .. $end_bucket) {
                $sum += $buckets[$j];
            }
            push @display_buckets, $sum;
        }
    }

    return @display_buckets;
}

# Calculate Y-axis tick positions
sub calculate_histogram_y_ticks {
    my ($height) = @_;

    # Determine number of ticks based on height to produce clean percentage intervals
    # Heights chosen to work well with these tick counts:
    #   height 4:  2 ticks → 50%, 100%
    #   height 5:  5 ticks → 20%, 40%, 60%, 80%, 100%
    #   height 6:  3 ticks → 33%, 67%, 100% (not ideal) or 2 ticks
    #   height 8:  4 ticks → 25%, 50%, 75%, 100%
    #   height 10: 5 ticks → 20%, 40%, 60%, 80%, 100%
    #   height 12: 4 ticks → 25%, 50%, 75%, 100%
    #   height 15: 5 ticks → 20%, 40%, 60%, 80%, 100%
    # Note: 0% is on the X-axis, not counted as a data row tick
    my $num_ticks;
    if ($height <= 4) {
        $num_ticks = 2;      # 50%, 100%
    } elsif ($height == 5) {
        $num_ticks = 5;      # 20%, 40%, 60%, 80%, 100%
    } elsif ($height <= 7) {
        $num_ticks = 3;      # 33%, 67%, 100%
    } elsif ($height <= 9) {
        $num_ticks = 4;      # 25%, 50%, 75%, 100%
    } elsif ($height <= 14) {
        $num_ticks = 5;      # 20%, 40%, 60%, 80%, 100%
    } else {
        $num_ticks = 5;      # Keep at 5 for 15+ rows (20% intervals)
    }

    # Calculate percentage interval
    my $pct_interval = 100 / $num_ticks;

    # Build lookup: row -> percentage value
    # Ticks are at pct_interval, 2*pct_interval, ... num_ticks*pct_interval (=100%)
    my %y_tick_info = ();
    for my $i (1 .. $num_ticks) {
        my $pct = $i * $pct_interval;
        # Map percentage to row: 100% = row height-1 (top), lower percentages map proportionally
        my $row = int(($pct / 100) * $height - 0.5);
        $row = 0 if $row < 0;
        $row = $height - 1 if $row > $height - 1;
        $y_tick_info{$row} = {
            pct            => int($pct + 0.5),
            count_fraction => $pct / 100,
        };
    }

    return \%y_tick_info;
}

# Calculate X-axis label positions
sub calculate_histogram_x_labels {
    my ($boundaries_ref, $bar_width, $metric) = @_;

    my $min_val = $boundaries_ref->[0];
    my $max_val = $boundaries_ref->[-1];

    # Dynamic tick count based on width
    my $target_spacing = 12;
    my $num_ticks = int($bar_width / $target_spacing) + 1;
    $num_ticks = 5 if $num_ticks < 5;

    # Generate evenly spaced positions
    my @positions;
    for my $i (0 .. $num_ticks - 1) {
        push @positions, $i / ($num_ticks - 1);
    }

    # Calculate values at each position (logarithmic scale)
    my @label_info;
    for my $pos (@positions) {
        my $value = $min_val * (($max_val / $min_val) ** $pos);
        my $label = format_heatmap_value($value, $metric);
        my $col = int($pos * ($bar_width - 1));
        push @label_info, { pos => $pos, col => $col, value => $value, label => $label };
    }

    # Filter out overlapping labels
    my @filtered;
    my $min_gap = 2;

    for my $info (@label_info) {
        my $label_len = length($info->{label});
        my $start_col = $info->{col};

        # Center label on tick (except edges)
        if ($info->{pos} > 0 && $info->{pos} < 1) {
            $start_col = $info->{col} - int($label_len / 2);
        } elsif ($info->{pos} == 1) {
            $start_col = $info->{col} - $label_len + 1;
        }

        $start_col = 0 if $start_col < 0;
        my $end_col = $start_col + $label_len - 1;

        # Check overlap
        my $overlaps = 0;
        for my $existing (@filtered) {
            if ($start_col <= $existing->{end_col} + $min_gap &&
                $end_col >= $existing->{start_col} - $min_gap) {
                $overlaps = 1;
                last;
            }
        }

        unless ($overlaps) {
            $info->{start_col} = $start_col;
            $info->{end_col} = $end_col;
            push @filtered, $info;
        }
    }

    return \@filtered;
}

# Render a single histogram row (Issue #42: supports stacked highlight bars)
sub render_histogram_row {
    my ($metric, $row, $height, $bar_width, $display_buckets, $display_buckets_hl, $max_bucket, $y_ticks, $box) = @_;

    my $row_threshold = ($row + 1) / $height;
    my $row_bottom = $row / $height;

    my $has_tick = exists $y_ticks->{$row};
    my ($left_tick, $right_tick) = get_histogram_y_tick_chars($has_tick, $box);

    # Left Y-axis label - use format_number for large values
    # Format: 6 chars right-justified + 1 space = 7 chars, then tick
    my ($y_label, $y_pct);
    if ($has_tick) {
        my $pct_val = $y_ticks->{$row}{pct};
        my $count_val = int($max_bucket * $y_ticks->{$row}{count_fraction} + 0.5);
        my $count_str = format_number($count_val, undef, 0);  # No space, 0 decimals
        $y_label = sprintf("%6s ", $count_str);  # 6 chars + space = 7
        $y_pct = sprintf(" %3d%%", $pct_val);
    } else {
        $y_label = sprintf("%6s ", "");
        $y_pct = sprintf(" %4s", "");
    }

    my $result = $y_label . $left_tick;

    # Get colors for this metric
    my $base_color = $histogram_base_colors{$metric};
    my $highlight_color = $histogram_highlight_colors{$metric};
    my $gradient = $histogram_color_gradients{$metric};
    my $has_highlight = defined $display_buckets_hl && @$display_buckets_hl;

    # Render bar characters
    for my $col (0 .. $bar_width - 1) {
        last if $col >= scalar(@$display_buckets);

        my $total_count = $display_buckets->[$col];
        my $hl_count = ($has_highlight && $col < scalar(@$display_buckets_hl)) ? $display_buckets_hl->[$col] : 0;

        my $total_fill = $total_count / $max_bucket;
        my $hl_fill = $hl_count / $max_bucket;

        # Determine what portion of this row is filled and with what color
        # Highlighted portion fills from bottom (row 0), non-highlighted on top
        my $char;
        my $color;

        if ($total_fill <= $row_bottom) {
            # Row is entirely empty - check for gridline
            if ($histogram_gridlines_enabled && $has_tick) {
                $result .= "\e[38;5;${histogram_gridline_color}m─\e[0m";
                next;
            }
            $char = ' ';
            $result .= $char;
            next;
        }

        # Determine which color region this row falls into
        # - Rows below hl_fill: highlighted color
        # - Rows above hl_fill but below total_fill: base color
        # - Rows spanning boundaries: partial blocks with appropriate colors

        if ($hl_fill >= $row_threshold) {
            # Row is entirely within highlighted region
            $color = $has_highlight ? $highlight_color : $base_color;
            $char = $histogram_block_chars[8];  # Full block
        } elsif ($hl_fill > $row_bottom && $hl_fill < $row_threshold) {
            # Row spans the highlight/non-highlight boundary
            # We need to render a partial block for highlight, then partial for non-highlight
            # Since we can only output one character, we use the lower half block technique

            # Calculate highlight partial fill within this row
            my $hl_partial = ($hl_fill - $row_bottom) / (1 / $height);
            my $hl_index = int($hl_partial * 8 + 0.5);
            $hl_index = 8 if $hl_index > 8;
            $hl_index = 0 if $hl_index < 0;

            if ($total_fill >= $row_threshold) {
                # Total fills the row completely, highlight fills partially
                # Use lower half block for highlight, upper half shows non-highlight
                if ($hl_index >= 4 && $has_highlight) {
                    # More than half is highlight - use lower half block with highlight fg, base bg
                    $result .= "\e[38;5;${highlight_color};48;5;${base_color}m▄\e[0m";
                } elsif ($hl_index > 0 && $has_highlight) {
                    # Less than half is highlight - use upper half block with base fg, highlight bg
                    $result .= "\e[38;5;${base_color};48;5;${highlight_color}m▀\e[0m";
                } else {
                    # No highlight in this row, full base color
                    $result .= "\e[38;5;${base_color};48;5;${base_color}m█\e[0m";
                }
                next;
            } else {
                # Total doesn't fill the row completely
                # Render highlight partial block
                $char = $histogram_block_chars[$hl_index];
                $color = $has_highlight ? $highlight_color : $base_color;
            }
        } elsif ($total_fill >= $row_threshold) {
            # Row is entirely above highlight region but within total
            $color = $base_color;
            $char = $histogram_block_chars[8];  # Full block
        } elsif ($total_fill > $row_bottom) {
            # Row is partially filled with non-highlighted (above highlight region)
            my $partial = ($total_fill - $row_bottom) / (1 / $height);
            my $index = int($partial * 8 + 0.5);
            $index = 8 if $index > 8;
            $index = 0 if $index < 0;
            $char = $histogram_block_chars[$index];
            $color = $base_color;
        } else {
            # Should not reach here (handled above)
            $char = ' ';
            $result .= $char;
            next;
        }

        # Apply gradient if enabled (only for non-highlight)
        if ($histogram_color_gradient_enabled && $color == $base_color) {
            my $intensity = int($total_fill * 7);
            $intensity = 7 if $intensity > 7;
            $color = $gradient->[$intensity];
        }

        if ($char eq $histogram_block_chars[8]) {
            # Full block: fg+bg color to eliminate gaps
            $result .= "\e[38;5;${color};48;5;${color}m${char}\e[0m";
        } elsif ($char ne ' ') {
            # Partial block: fg only
            $result .= "\e[38;5;${color}m${char}\e[0m";
        } else {
            $result .= $char;
        }
    }

    # Right Y-axis
    $result .= "\e[0m" . $right_tick . $y_pct;

    return $result;
}

# Get Y-axis tick characters
sub get_histogram_y_tick_chars {
    my ($has_tick, $box) = @_;

    if (!$has_tick) {
        return ($box->{v_line}, $box->{v_line});
    }

    # Ticks pointing into chart
    return ($box->{t_right}, $box->{t_left});
}

# Issue #185: Select percentiles to show in legend, ordered by SRE priority then sorted ascending.
# Shared between render_histogram_legend and the x-axis tick computation so both are
# guaranteed to use the same set — orphaned ticks (no matching legend entry) would be confusing.
sub select_histogram_percentiles {
    my ($stats, $bar_width, $metric) = @_;

    my @percentile_priority = (
        { key => 'p50',   label => 'P50',    sort_order => 50 },
        { key => 'p99',   label => 'P99',    sort_order => 99 },
        { key => 'p999',  label => 'P99.9',  sort_order => 99.9 },
        { key => 'p95',   label => 'P95',    sort_order => 95 },
        { key => 'p90',   label => 'P90',    sort_order => 90 },
        { key => 'p75',   label => 'P75',    sort_order => 75 },
        { key => 'p9999', label => 'P99.99', sort_order => 99.99 },
        { key => 'p25',   label => 'P25',    sort_order => 25 },
        { key => 'p10',   label => 'P10',    sort_order => 10 },
        { key => 'p1',    label => 'P1',     sort_order => 1 },
    );

    my $separator = "   ";
    my @all_entries;
    for my $pct (@percentile_priority) {
        my $value     = $stats->{$pct->{key}};
        my $value_str = format_heatmap_value($value, $metric);
        my $entry_str = $pct->{label} . ": " . $value_str;
        push @all_entries, {
            key        => $pct->{key},
            label      => $pct->{label},
            sort_order => $pct->{sort_order},
            value      => $value,
            str        => $entry_str,
            len        => length($entry_str),
        };
    }

    my $max_entries = 0;
    my $total_len   = 0;
    for my $i (0 .. $#all_entries) {
        my $needed = $all_entries[$i]{len};
        $needed += length($separator) if $i > 0;
        if ($total_len + $needed <= $bar_width) {
            $total_len += $needed;
            $max_entries = $i + 1;
        } else {
            last;
        }
    }

    return ([], $separator) unless $max_entries > 0;

    my @selected = @all_entries[0 .. $max_entries - 1];
    @selected = sort { $a->{sort_order} <=> $b->{sort_order} } @selected;
    return (\@selected, $separator);
}

# Issue #185: Map each selected percentile to a column index on the log-scaled x-axis.
# Uses the same logarithmic mapping as calculate_histogram_x_labels() to stay aligned
# with bucket boundaries and labels.
sub calculate_histogram_percentile_ticks {
    my ($selected, $boundaries_ref, $bar_width) = @_;

    my %cols;
    return \%cols unless $selected && @$selected;

    my $min_val = $boundaries_ref->[0];
    my $max_val = $boundaries_ref->[-1];
    return \%cols if !defined $min_val || !defined $max_val || $min_val <= 0 || $max_val <= $min_val;

    my $log_range = log($max_val / $min_val);
    for my $entry (@$selected) {
        my $value = $entry->{value};
        next unless defined $value && $value > 0;
        my $pos = log($value / $min_val) / $log_range;
        $pos = 0 if $pos < 0;
        $pos = 1 if $pos > 1;
        my $col = int($pos * ($bar_width - 1));
        $cols{$col} = 1;
    }
    return \%cols;
}

# Render X-axis line
sub render_histogram_x_axis {
    my ($bar_width, $x_labels, $box, $percentile_cols) = @_;

    my %tick_positions = map { $_->{col} => 1 } @$x_labels;
    $percentile_cols ||= {};

    # Left side: "     0 " + corner (6 chars + space = 7 to match Y-axis labels)
    my $result = sprintf("%6s ", "0") . $box->{corner_bl};

    # Issue #185: tick chars (┴/┻ and ┼/╋) match the colour of the rest of the
    # axis frame (┗ ━ ┳ ┛). Those characters are emitted without any ANSI
    # wrapping, so the ticks are emitted the same way — whatever colour the
    # terminal renders the axis line in, the ticks render identically.
    for my $col (0 .. $bar_width - 1) {
        my $is_bucket = exists $tick_positions{$col};
        my $is_pct    = exists $percentile_cols->{$col};

        if ($is_bucket && $is_pct) {
            $result .= $box->{cross};
        } elsif ($is_pct) {
            $result .= $box->{t_up};
        } elsif ($is_bucket) {
            $result .= $box->{t_down};
        } else {
            $result .= $box->{h_line};
        }
    }

    # Right side: corner + " 0%"
    $result .= $box->{corner_br} . sprintf(" %3d%%", 0);

    return $result;
}

# Render X-axis labels
sub render_histogram_x_labels {
    my ($bar_width, $x_labels, $single_width) = @_;

    my $left_margin = 8;  # "     0 " + corner
    my @label_line = (' ') x ($single_width);

    for my $info (@$x_labels) {
        my $start = $left_margin + $info->{start_col};
        for my $i (0 .. length($info->{label}) - 1) {
            my $pos = $start + $i;
            $label_line[$pos] = substr($info->{label}, $i, 1) if $pos < scalar(@label_line);
        }
    }

    return join('', @label_line);
}

# Render legend with percentiles (Issue #42: supports highlight stats)
# Returns ($legend_line, $legend_line_hl) where $legend_line_hl is undef if no highlight data
# Issue #185: $selected (precomputed by select_histogram_percentiles) is used so the legend
# and the x-axis ticks are guaranteed identical.
sub render_histogram_legend {
    my ($metric, $selected, $separator, $stats_hl, $bar_width, $single_width) = @_;

    return (" " x $single_width, undef) unless $selected && @$selected;

    my $legend_line = join($separator, map { $_->{str} } @$selected);

    # Center within single_width, apply base metric color
    my $left_margin = 8;
    my $legend_padding = $left_margin + int(($bar_width - length($legend_line)) / 2);
    $legend_padding = 0 if $legend_padding < 0;

    my $base_color = $histogram_base_colors{$metric};
    my $result = " " x $legend_padding . "\e[38;5;${base_color}m" . $legend_line . "\e[0m";
    # Pad to single_width (account for ANSI codes not taking visual width)
    my $visual_len = $legend_padding + length($legend_line);
    $result .= " " x ($single_width - $visual_len) if $visual_len < $single_width;

    # Issue #42: Build highlight legend line if highlight stats exist.
    # Same percentile selection as main legend (sort_order/key from $selected) so the two
    # rows align column-for-column.
    my $result_hl = undef;
    if (defined $stats_hl && defined $stats_hl->{count} && $stats_hl->{count} > 0) {
        my $highlight_color = $histogram_highlight_colors{$metric};

        my @selected_hl;
        for my $entry (@$selected) {
            my $value_str = format_heatmap_value($stats_hl->{$entry->{key}}, $metric);
            my $entry_str = $entry->{label} . ": " . $value_str;
            push @selected_hl, { str => $entry_str };
        }

        my $legend_line_hl = join($separator, map { $_->{str} } @selected_hl);

        # Center with highlight background color and black/white foreground (like bar charts)
        my $hl_padding = $left_margin + int(($bar_width - length($legend_line_hl)) / 2);
        $hl_padding = 0 if $hl_padding < 0;

        # Use black foreground on dark terminals, white on light terminals
        # Add space padding before and after text for highlighter effect
        my $fg_color = $heatmap_light_bg ? 15 : 0;  # 15 = white, 0 = black
        my $hl_text_with_padding = " " . $legend_line_hl . " ";  # space before and after for highlighter effect
        $result_hl = " " x ($hl_padding - 1) . "\e[48;5;${highlight_color}m\e[38;5;${fg_color}m" . $hl_text_with_padding . "\e[0m";
        # Pad to single_width (account for reduced left padding and added highlighter padding)
        my $visual_len = ($hl_padding - 1) + length($hl_text_with_padding);
        $result_hl .= " " x ($single_width - $visual_len) if $visual_len < $single_width;
    }

    return ($result, $result_hl);
}

sub print_summary_table {
    my $category_column_width = 30;
    my $occurrences_column_width = 10;
    my $table_padding = 2;
    my $padding = " " x $table_padding;
    my $column_padding = " " x 1;
    my $table_format = "$padding%-${category_column_width}s %${occurrences_column_width}d$padding\n";
    my $summary_table_width = $table_padding + $category_column_width + 1 + $occurrences_column_width + $table_padding;
    my $file_detail_width = $terminal_width - ( $summary_table_width + $table_padding * 2 );
    my ( @summary_table, @file_details );
    my ( @match_char ) = ( "$colors{'red'}χ", "$colors{'green'}√", "$colors{'green-HL'}√" );

    ## FORMAT MIN/MAX LOG TIMESTAMPS FOR THE SUMMARY ##
    my $min_timestamp_str = strftime($output_timestamp_format, gmtime($output_timestamp_min));
    my $max_timestamp_str = strftime($output_timestamp_format, gmtime($output_timestamp_max));
    $min_timestamp_str .= sprintf ".%03d", ($output_timestamp_min-int($output_timestamp_min))*1000 if $print_milliseconds;
    $max_timestamp_str .= sprintf ".%03d", ($output_timestamp_max-int($output_timestamp_max))*1000 if $print_milliseconds;

    ## PRINT COMMAND AND ARGUMENTS ##
    if ($ltl_config_raw ne '') {
        print "\n$colors{'bright-black'}environment options: $ltl_config_raw$colors{'NC'}";
    }
    my %argv_hash = map { $_ => 1 } @ARGV;
    my $cli_options = '';
    for (my $i = 0; $i < @ORIGINAL_ARGV; $i++) {
        my $arg = $ORIGINAL_ARGV[$i];
        next if exists $argv_hash{$arg};  # Skip log files

        # Handle pattern file options with indicators
        if ($arg =~ /^(-ef|--exclude-file)$/ && $i + 1 < @ORIGINAL_ARGV) {
            my $file = $ORIGINAL_ARGV[$i + 1];
            my $indicator = get_pattern_file_indicator('exclude', $file);
            $cli_options .= "$arg $file$indicator ";
            $i++;  # Skip the filename in next iteration
        } elsif ($arg =~ /^(-if|--include-file)$/ && $i + 1 < @ORIGINAL_ARGV) {
            my $file = $ORIGINAL_ARGV[$i + 1];
            my $indicator = get_pattern_file_indicator('include', $file);
            $cli_options .= "$arg $file$indicator ";
            $i++;  # Skip the filename in next iteration
        } elsif ($arg =~ /^(-hf|--highlight-file)$/ && $i + 1 < @ORIGINAL_ARGV) {
            my $file = $ORIGINAL_ARGV[$i + 1];
            my $indicator = get_pattern_file_indicator('highlight', $file);
            $cli_options .= "$arg $file$indicator ";
            $i++;  # Skip the filename in next iteration
        } else {
            $cli_options .= "$arg ";
        }
    }
    if ($cli_options ne '') {
        print "\n$colors{'bright-black'}command-line options: $cli_options$colors{'NC'}";
    }
    print "\n";

    return if $omit_summary;

    ## START SUMMARY STATISTIC TABLE ##
    push @summary_table, sprintf( "\n  " . "─" x ( $category_column_width + $occurrences_column_width + 1 ) . "$padding\n" );
    push @summary_table, sprintf( "  " . "%-${category_column_width}s %${occurrences_column_width}s$padding\n", "Category", "Total" ); 
    push @summary_table, sprintf( "  " . "─" x ( $category_column_width + $occurrences_column_width + 1 ) . "$padding\n" );

    foreach my $category_bucket (@log_levels) {
        next if $category_bucket =~ /^(empty|err-rate|msg-rate)$/;
        next unless $category_totals{$category_bucket};
	
        my ( $legend_title ) =  "$category_bucket:" . " " x ( 14 - length( $category_bucket ) );
        push @summary_table, sprintf( $table_format, $category_bucket, $category_totals{$category_bucket} ); 
    }

    push @summary_table, sprintf( "$padding" . "─" x ( $category_column_width + $occurrences_column_width + 1 ) . "$padding\n" );
    push @summary_table, sprintf( $table_format, "HIGHLIGHTED", $total_lines_highlighted ) if $highlight_active;
    push @summary_table, sprintf( $table_format, "LINES INCLUDED", $total_lines_included ); 
    push @summary_table, sprintf( $table_format, "LINES READ", $total_lines_read ); 
    push @summary_table, sprintf( "$padding%-${category_column_width}s %${occurrences_column_width}s$padding\n", "FILE PROCESSING TIME", format_time( $elapsed_read_files, 's', 'medium', " " ) );
    push @summary_table, sprintf( "$padding%-${category_column_width}s %${occurrences_column_width}s$padding\n", "INITIALIZE EMPTY BUCKETS", format_time( $elapsed_initialize_empty_time_windows, 's', 'medium', " " ) );
    push @summary_table, sprintf( "$padding%-${category_column_width}s %${occurrences_column_width}s$padding\n", "GROUP SIMILAR MESSAGES", format_time( $elapsed_group_similar_messages, 's', 'medium', " " ) ) unless $group_similar_sensitivity =~ /^none$/;
    push @summary_table, sprintf( "$padding%-${category_column_width}s %${occurrences_column_width}s$padding\n", "CALCULATE STATISTICS", format_time( $elapsed_calculate_statistics, 's', 'medium', " " ) );
    push @summary_table, sprintf( "$padding%-${category_column_width}s %${occurrences_column_width}s$padding\n", "HEATMAP STATISTICS", format_time( $elapsed_heatmap_statistics, 's', 'medium', " " ) ) if $heatmap_enabled;
    push @summary_table, sprintf( "$padding%-${category_column_width}s %${occurrences_column_width}s$padding\n", "HISTOGRAM STATISTICS", format_time( $elapsed_histogram_statistics, 's', 'medium', " " ) ) if $histogram_enabled;
    push @summary_table, sprintf( "$padding%-${category_column_width}s %${occurrences_column_width}s$padding\n", "SCALE DATA TO TERMINAL", format_time( $elapsed_normalize_data, 's', 'medium', " " ) );
    push @summary_table, sprintf( "$padding%-${category_column_width}s %${occurrences_column_width}s$padding\n", "TOTAL TIME", format_time( $elapsed_total, 's', 'medium', " " ) );
    push @summary_table, sprintf( "$padding%-${category_column_width}s %${occurrences_column_width}s$padding\n", "MAXIMUM MEMORY USED", format_bytes( $max_memory_usage, 'B' ) );

    # Add structural breakdown if -mem flag used and we have high-water mark data
    if ($show_memory && %memory_high_water_marks) {
            # Skip structures with only empty hash/array overhead (< 1KB means effectively empty)
            my $min_size_threshold = 1024;

            # Issue #356 (S3): the breakdown accounts against the peak RSS
            # itself. Percentages are shares of MAXIMUM MEMORY USED, and the
            # remainder no structure walk can attribute (interpreter baseline,
            # allocator-retained transients, allocation slack) is surfaced as
            # an explicit 'unattributed' row so the displayed rows reconcile
            # to the peak. Structure values are high-water marks captured at
            # different instants, so the subtraction is floored at zero. The
            # unattributed value subtracts the FULL sum of high-water marks
            # (not the >=1KB-filtered display set) so hidden near-empty
            # structures are not misreported as unattributed memory.
            my $total_hwm = 0;
            $total_hwm += $_ for values %memory_high_water_marks;
            my $unattributed = $max_memory_usage - $total_hwm;
            $unattributed = 0 if $unattributed < 0;

            # Sort by size descending, skip empty structures
            my @sorted = sort { $memory_high_water_marks{$b} <=> $memory_high_water_marks{$a} || ($a cmp $b) }
                         grep { $memory_high_water_marks{$_} >= $min_size_threshold }
                         keys %memory_high_water_marks;

            my $emit_breakdown_row = sub {
                my ($label, $size) = @_;
                my $category_width = $category_column_width + 2;
                my $occurrences_width = $occurrences_column_width - 2;
                my $pct = $max_memory_usage > 0 ? ($size / $max_memory_usage) * 100 : 0;
                my $pct_str = $pct < 1 ? "(<1%)" : sprintf("(%2.0f%%)", $pct);

                my $indented_label = sprintf(" %-25s %5s", $label, $pct_str);
                push @summary_table, sprintf( "$padding%-${category_width}s %${occurrences_width}s$padding\n", $indented_label, format_bytes( $size, 'B', 0 ) );
            };

            $emit_breakdown_row->($_, $memory_high_water_marks{$_}) for @sorted;
            $emit_breakdown_row->('unattributed', $unattributed);
    }
    push @summary_table, sprintf( "$padding" . "─" x ( $category_column_width + $occurrences_column_width + 1 ) . "$padding\n" );

    push @file_details, "\n";

    # Wrap heading text if it exceeds available width
    my $heading_text = $profile_mode
        ? "These file(s) were processed with analysis folded onto a single $profile_mode profile, spanning $min_timestamp_str to $max_timestamp_str"
        : "These file(s) were processed with analysis including results between $min_timestamp_str and $max_timestamp_str";
    my $heading_content_width = $file_detail_width - length($column_padding) - length($padding);
    if ($heading_content_width > 20) {
        my @heading_lines = wrap_text($heading_text, $heading_content_width);
        for my $idx (0 .. $#heading_lines) {
            my $line = $heading_lines[$idx];
            # Apply underline to text only (not padding), reset immediately after text
            push @file_details, "$column_padding$padding$colors{'white-underline'}$line$colors{'NC'}\n";
        }
    } else {
        # Terminal too narrow - just truncate
        my $truncated = substr($heading_text, 0, $heading_content_width > 0 ? $heading_content_width : 1);
        push @file_details, "$column_padding$padding$colors{'white-underline'}$truncated$colors{'NC'}\n";
    }

    push @file_details, "\n";
    foreach my $in_file (@files_processed) {
         my $filename_max_length = $file_detail_width - length($column_padding) - length($padding) - 4;  # -4 for '[x] '
         $filename_max_length = 10 if $filename_max_length < 10;  # Minimum reasonable length
         my $filename = shorten_filename($in_file, $filename_max_length);
         push @file_details, sprintf("$column_padding$padding$colors{'white'}\[%s$colors{'NC'}$colors{'white'}\] %-${filename_max_length}s$colors{'NC'}\n", $match_char[$in_files_matched{$in_file}], $filename);
    }

    for (my $i = 0; $i < max(scalar @summary_table, scalar @file_details); $i++) {
        if( $i >= scalar @summary_table ) {
            print " " x $summary_table_width . $column_padding;
        } else {
            chomp $summary_table[$i];
            print "$summary_table[$i]$column_padding";
        }

        if( $i >= scalar @file_details ) {
            print "\n";
        } else {
            print $file_details[$i];
        }
    }

    return;
}

sub print_message_summary {
    # Table variant: the statistics variant appends the Min/P50/P99.9/CV %/
    # Duration columns to the occurrences column; the basic variant carries
    # occurrences only. A statistics table needs both an active consumer of
    # per-key statistics (demand) and at least one observed duration.
    my $statistics_variant = ( $message_duration_stats_demand && $durations_observed ) ? 1 : 0;

    # Define the relative size of each column as a percentage
    my %col_relative_size;

    print "\n";

    if( $statistics_variant ) {
        %col_relative_size = (
            1 => 65,
            2 => 6,
            3 => 5,
            4 => 5,
            5 => 5,
            6 => 5,
            7 => 9,
        );
    } else {
        %col_relative_size = (
            1 => 94,
            2 => 6,
        );
    }

    # Initialize the hash to store the character width of each column
    my %col_width;
    my %col_names = (
        "message" => "Message",
        "occurrences" => "Occurrences",
        "min" => "Min",
        "p50" => "P50",
        "p999" => "P99.9",
        "cv" => "CV %",
        "time" => "Duration",
    );
    my $truncate_chars = 2;
    my @column_list = ( "message", "occurrences", "min", "p50", "p999", "cv", "time" );
    my @header_title_text = (
        "TOP HIGHLIGHTED MESSAGES (lines matching the highlight criteria)",
        "TOP OVERALL MESSAGES (retained for after inclusion, exclusion, time range, and duration filters)"
    );

    my $table_padding_outer = 1;
    my $table_padding_inner = 1;

    # Calculate the total table width after applying outer padding
    my $table_width = $terminal_width - (2 * $table_padding_outer);

    # Calculate the absolute width for each column based on the relative size and inner padding and truncate where necessary
    foreach my $column (keys %col_relative_size) {
        $col_width{$column} = int($table_width * $col_relative_size{$column} / 100) - (2 * $table_padding_inner);
        if ( length( $col_names{$column_list[$column-1]} ) > $col_width{$column} - $truncate_chars ) {
            $col_names{$column_list[$column-1]} = substr( $col_names{$column_list[$column-1]}, 0, $col_width{$column} - $truncate_chars);
            $col_names{$column_list[$column-1]} .= "." unless $col_names{$column_list[$column-1]} =~ /\.$/;
        } elsif ( $column == "1" ) {
            foreach my $i ( 0 .. $#header_title_text ) {
                my $title_text_length = length( $header_title_text[$i] );
                if ( $title_text_length > $col_width{$column} - ( $truncate_chars + 2 ) ) {
                    my $target_length = $col_width{$column} - ( $truncate_chars + 2 );
                    $header_title_text[$i] = substr( $header_title_text[$i], 0, $target_length );
                    $header_title_text[$i] .= " ...";
                }
            }
        }
    }

    ### DETERMINE CUT OF HIGHLIGHTED VS PLAIN MESSAGES TO PRINT ###
    # Step 1: Sort and store available messages for each category in a hash of arrays
    my %sorted_keys = ( 'highlight' => [], 'plain' => [] );

    foreach my $grouping ( qw( highlight plain ) ) {
        # The display ordering is computed exactly once, in
        # calculate_all_statistics, for every sort type — the available-value
        # pool selection (#302) or the calculated-statistic two-pass
        # selection (#303) — and reused here: same keys, same comparator,
        # same result. A grouping with no message keys has no recorded order.
        $sorted_keys{$grouping} = $message_key_order{$grouping} // [];
    }

    # Initialize the hash to store top message counts
    my %top_message_occurrences = (
        'highlight' => 0,
        'plain' => 0,
    );

    foreach my $grouping ( qw( highlight plain ) ) {
        for my $i (0 .. $#{$sorted_keys{$grouping}}) {
            last if $i >= $top_n_messages;
            $top_message_occurrences{$grouping}++;
        }
    }

    # Step 2: Determine how many messages to print from each category
    my $half_top_n = int($top_n_messages / 2);

    # Initialize the hash to store the number of messages to print
    my %messages_to_print = (
        'highlight' => $half_top_n,
        'plain' => $half_top_n,
    );

    $messages_to_print{'highlight'}++ if $top_n_messages % 2 != 0;		# if halving doesn't equate to Top N, then add another row to highlighted messages

    # Step 3: Adjust if one category has fewer messages than needed, ensuring the total remains $top_n_messages
    if ($top_message_occurrences{'highlight'} < $messages_to_print{'highlight'}) {
        $messages_to_print{'highlight'} = $top_message_occurrences{'highlight'};
        $messages_to_print{'plain'} = $top_n_messages - $messages_to_print{'highlight'};
    } elsif ($top_message_occurrences{'plain'} < $messages_to_print{'plain'}) {
        $messages_to_print{'plain'} = $top_message_occurrences{'plain'};
        $messages_to_print{'highlight'} = $top_n_messages - $messages_to_print{'plain'};
    }

    foreach my $grouping ( qw( highlight plain ) ) {
        my $messages_printed = 0;

        # Ensure the grouping exists and is a hash reference
        if (exists $log_messages{$grouping} && ref($log_messages{$grouping}) eq 'HASH') {
            my @top_keys = @{$sorted_keys{$grouping}}[0 .. min($#{$sorted_keys{$grouping}}, $top_n_messages - 1)] if scalar( @{$sorted_keys{$grouping}} ) > 0;
            next unless scalar(@top_keys) > 0;			# skip to the next category if their are no top message keys
            my $header_title = " ";

            if( $grouping eq "highlight" ) {
                $header_title = " " x $table_padding_outer . "$colors{'bright-yellow-HL'}" . " " x $table_padding_inner . sprintf( "%-$col_width{1}s", $header_title_text[0] ) . " " x $table_padding_inner;

                $header_title .= " " x $table_padding_inner . sprintf( "%$col_width{2}s", $col_names{'occurrences'} ) . " " x $table_padding_inner;
                if( $statistics_variant ) {
                    $header_title .= " " x $table_padding_inner . sprintf( "%$col_width{3}s", $col_names{'min'} ) . " " x $table_padding_inner;
                    $header_title .= " " x $table_padding_inner . sprintf( "%$col_width{4}s", $col_names{'p50'} ) . " " x $table_padding_inner;
                    $header_title .= " " x $table_padding_inner . sprintf( "%$col_width{5}s", $col_names{'p999'} ) . " " x $table_padding_inner;
                    $header_title .= " " x $table_padding_inner . sprintf( "%$col_width{6}s", $col_names{'cv'} ) . " " x $table_padding_inner;
                    $header_title .= " " x $table_padding_inner . sprintf( "%$col_width{7}s", $col_names{'time'} ) . " " x $table_padding_inner;
                }

                $header_title .= "$colors{'NC'}$colors{'bright-yellow'}";
            } elsif( $grouping eq "plain" ) {
                $header_title = " " x $table_padding_outer . "$colors{'bright-cyan-HL'}" . " " x $table_padding_inner . sprintf( "%-$col_width{1}s", $header_title_text[1] ) . " " x $table_padding_inner;

                $header_title .= " " x $table_padding_inner . sprintf( "%$col_width{2}s", $col_names{'occurrences'} ) . " " x $table_padding_inner;
                if( $statistics_variant ) {
                    $header_title .= " " x $table_padding_inner . sprintf( "%$col_width{3}s", $col_names{'min'} ) . " " x $table_padding_inner;
                    $header_title .= " " x $table_padding_inner . sprintf( "%$col_width{4}s", $col_names{'p50'} ) . " " x $table_padding_inner;
                    $header_title .= " " x $table_padding_inner . sprintf( "%$col_width{5}s", $col_names{'p999'} ) . " " x $table_padding_inner;
                    $header_title .= " " x $table_padding_inner . sprintf( "%$col_width{6}s", $col_names{'cv'} ) . " " x $table_padding_inner;
                    $header_title .= " " x $table_padding_inner . sprintf( "%$col_width{7}s", $col_names{'time'} ) . " " x $table_padding_inner;
                }

                $header_title .= "$colors{'NC'}$colors{'bright-cyan'}";
            }

            print "$header_title\n";
            print " " x $table_padding_outer . "─" x $table_width . "$colors{'NC'}\n";

            # Print the top messages
            foreach my $key (@top_keys) {
                memory_debug_sample("message_summary_keys") if $show_memory_debug && ++$memory_debug_key_samples % 10000 == 0;
                next if $messages_printed++ >= $messages_to_print{$grouping};
                next if !defined $key;
                my $is_consolidated = ($log_messages{$grouping}{$key}{is_consolidated} // 0);
                my $row = $is_consolidated ? "~" : " " x $table_padding_outer;

                if (defined $key && exists $log_messages{$grouping}{$key}) {
                    my $message = substr( $key, 0, $col_width{1} );                         # truncate message for printing if too long to fit in column
                    my $occurrences = $log_messages{$grouping}{$key}{occurrences};
                    my $count_occurrences = $log_messages{$grouping}{$key}{count_occurrences};
                    my $count_min = $log_messages{$grouping}{$key}{count_min};
                    my $count_mean = $log_messages{$grouping}{$key}{count_mean};
                    my $count_max = $log_messages{$grouping}{$key}{count_max};
                    my $count_sum = $log_messages{$grouping}{$key}{count_sum};
                    my $total_bytes_num = $log_messages{$grouping}{$key}{total_bytes};
                    my $total_bytes = format_bytes( $total_bytes_num,'B' );
                    # BUG/ WRONG!!! below assumes all lines have bytes, but not really
                    my $mean_bytes = int( $total_bytes_num / $occurrences + 0.5 ) if defined $total_bytes_num; 
                    my $min = $log_messages{$grouping}{$key}{min};
                    my $mean = $log_messages{$grouping}{$key}{mean};
                    my $max = $log_messages{$grouping}{$key}{max};
                    my $std_dev = $log_messages{$grouping}{$key}{std_dev};
                    my $impact = $log_messages{$grouping}{$key}{impact};
                    my $p1 = $log_messages{$grouping}{$key}{p1};
                    my $p5 = $log_messages{$grouping}{$key}{p5};
                    my $p10 = $log_messages{$grouping}{$key}{p10};
                    my $p25 = $log_messages{$grouping}{$key}{p25};
                    my $p50 = $log_messages{$grouping}{$key}{p50};
                    my $p75 = $log_messages{$grouping}{$key}{p75};
                    my $iqr = $log_messages{$grouping}{$key}{iqr};
                    my $p90 = $log_messages{$grouping}{$key}{p90};
                    my $p95 = $log_messages{$grouping}{$key}{p95};
                    my $p99 = $log_messages{$grouping}{$key}{p99};
                    my $p999 = $log_messages{$grouping}{$key}{p999};
                    my $p9999 = $log_messages{$grouping}{$key}{p9999};
                    my $p99999 = $log_messages{$grouping}{$key}{p99999};
                    my $cv = $log_messages{$grouping}{$key}{cv};
                    my $skewness = $log_messages{$grouping}{$key}{skewness};
                    my $kurtosis = $log_messages{$grouping}{$key}{kurtosis};
                    my $bimodality_coef = $log_messages{$grouping}{$key}{bimodality_coef};
                    my $total_duration_num = $log_messages{$grouping}{$key}{total_duration_num};
                    my $total_duration = $log_messages{$grouping}{$key}{total_duration};

                    if( $statistics_variant && ( defined $log_messages{$grouping}{$key}{p50} || defined $log_messages{$grouping}{$key}{cv} || defined $log_messages{$grouping}{$key}{total_duration} ) ) {
                        $row .= " " x $table_padding_inner . sprintf( "%-$col_width{1}s", $message ) . " " x $table_padding_inner; 
                        $row .= " " x $table_padding_inner . sprintf( "%$col_width{2}s", $occurrences ) . " " x $table_padding_inner; 
                        $row .= " " x $table_padding_inner . sprintf( "%$col_width{3}s", format_duration( $min, $col_width{3} ) ) . " " x $table_padding_inner;
                        $row .= " " x $table_padding_inner . sprintf( "%$col_width{4}s", format_duration( $p50, $col_width{4} ) ) . " " x $table_padding_inner;
                        $row .= " " x $table_padding_inner . sprintf( "%$col_width{5}s", format_duration( $p999, $col_width{5} ) ) . " " x $table_padding_inner;
                        $row .= " " x $table_padding_inner . sprintf( "%$col_width{6}s", format_cv_display( $cv ) ) . " " x $table_padding_inner; 
                        $row .= " " x $table_padding_inner . sprintf( "%$col_width{7}s", defined $total_duration ? $total_duration : "" ) . " " x $table_padding_inner; 
                    } else {
                        $row .= " " x $table_padding_inner . sprintf( "%-$col_width{1}s", $message ) . " " x $table_padding_inner; 
                        $row .= " " x $table_padding_inner . sprintf( "%$col_width{2}s", $occurrences ) . " " x $table_padding_inner; 
                    }

                    # Separated conditions for CSV output from printed column data
                    if( $write_messages_to_csv && defined $csv_fh ) {
                        # Issue #268: UDM values route through format_csv_value()
                        # like every other numeric column at this emission site.
                        # Column names mirror the MESSAGES header construction so
                        # each value resolves to the same precision family as its
                        # header column.
                        my @udm_csv_values;
                        foreach my $config (@udm_configs) {
                            my $name = $config->{name};
                            my $csv_prefix = $config->{unit} ? "${name}_$config->{unit}" : $name;
                            if ($config->{agg_kind} eq 'counting') {
                                # count -> per-message occurrences; distinct/ratio/rate/drate
                                # have no per-message value (distinct sets are bucket-scoped)
                                my $col = "$config->{base_name}_$config->{aggregation}";
                                $col .= $rate_csv_suffix{$rate_unit} if $config->{aggregation} =~ /^(rate|drate)$/;
                                push @udm_csv_values, $config->{aggregation} eq 'count'
                                    ? format_csv_value($log_messages{$grouping}{$key}{"udm_${name}_occurrences"}, $col)
                                    : undef;
                            } elsif ($config->{name} ne $config->{base_name}) {
                                # Disambiguated metric: single aggregated value (#99)
                                my $stat_key = $config->{aggregation};
                                push @udm_csv_values, format_csv_value(
                                    $log_messages{$grouping}{$key}{"udm_${name}_${stat_key}"}, $csv_prefix);
                            } else {
                                push @udm_csv_values,
                                    map { format_csv_value($log_messages{$grouping}{$key}{"udm_${name}_$_"}, "${csv_prefix}_$_") }
                                        qw(occurrences min mean max sum);
                            }
                        }
                        # Issue #268: format each numeric column per the resolved
                        # --csv-precision mode. Column names mirror the header at
                        # ltl:11541 so format_csv_value() can resolve each value's
                        # family. Pre-formatted strings (bytes_nice, duration_nice)
                        # and metadata pass through unchanged.
                        $csv->print($csv_fh, [
                            $grouping,
                            $key,
                            format_csv_value($occurrences,       'occurrences'),
                            format_csv_value($mean_bytes,        'mean_bytes'),
                            format_csv_value($total_bytes_num,   'bytes'),
                            $total_bytes,
                            format_csv_value($count_occurrences, 'count_occurrences'),
                            format_csv_value($count_min,         'count_min'),
                            format_csv_value($count_mean,        'count_mean'),
                            format_csv_value($count_max,         'count_max'),
                            format_csv_value($count_sum,         'count_sum'),
                            format_csv_value($min,               'min'),
                            format_csv_value($mean,              'mean'),
                            format_csv_value($max,               'max'),
                            format_csv_value($std_dev,           'std_dev'),
                            format_csv_value($p1,                'p1'),
                            format_csv_value($p5,                'p5'),
                            format_csv_value($p10,               'p10'),
                            format_csv_value($p25,               'p25'),
                            format_csv_value($p50,               'p50'),
                            format_csv_value($p75,               'p75'),
                            format_csv_value($iqr,               'iqr'),
                            format_csv_value($p90,               'p90'),
                            format_csv_value($p95,               'p95'),
                            format_csv_value($p99,               'p99'),
                            format_csv_value($p999,              'p999'),
                            format_csv_value($p9999,             'p9999'),
                            format_csv_value($p99999,            'p99999'),
                            format_csv_value($cv,                'cv'),
                            format_csv_value($skewness,          'skewness'),
                            format_csv_value($kurtosis,          'kurtosis'),
                            format_csv_value($bimodality_coef,   'bimodality_coef'),
                            format_csv_value($total_duration_num,'duration'),
                            $total_duration,
                            format_csv_value($impact,            'impact'),
                            @udm_csv_values,
                        ]);
                    }

                    print "$row\n";
                }
            }

            print "\n";
        }
    }

    return;
}

sub print_threadpool_summary {
    # Define the relative size of each column as a percentage
    my %col_relative_size;

    print "\n";

    %col_relative_size = (
       1 => 94,
       2 => 6,
    );

    # Initialize the hash to store the character width of each column
    my %col_width;

    # Define the terminal width and padding values
    my $table_padding_outer = 1;
    my $table_padding_inner = 1;

    # Calculate the total table width after applying outer padding
    my $table_width = $terminal_width - (2 * $table_padding_outer);

    # Calculate the absolute width for each column based on the relative size and inner padding
    foreach my $column (keys %col_relative_size) {
        $col_width{$column} = int($table_width * $col_relative_size{$column} / 100) - (2 * $table_padding_inner);
    }

    ### DETERMINE CUT OF HIGHLIGHTED VS PLAIN MESSAGES TO PRINT ###
    # Step 1: Sort and store available messages for each category in a hash of arrays
    my %sorted_keys = ( 'highlight' => [], 'plain' => [] );
    foreach my $grouping ( qw( highlight plain ) ) {
        my @sorted_keys = sort {
            my $occurrences_a = scalar keys %{$threadpool_activity{$grouping}{$a}} // 0;
            my $occurrences_b = scalar keys %{$threadpool_activity{$grouping}{$b}} // 0;
            ($sort_ascending
                ? ($occurrences_a <=> $occurrences_b)
                : ($occurrences_b <=> $occurrences_a))
            || ($a cmp $b);
        } keys %{$threadpool_activity{$grouping}};

        $sorted_keys{$grouping} = \@sorted_keys;
    }

    # Initialize the hash to store top message counts
    my %top_message_occurrences = (
        'highlight' => 0,
        'plain' => 0,
    );

    foreach my $grouping ( qw( highlight plain ) ) {
        for my $i (0 .. $#{$sorted_keys{$grouping}}) {
            last if $i >= $top_n_messages;
            $top_message_occurrences{$grouping}++;
        }
    }

    # Step 2: Determine how many messages to print from each category
    my $half_top_n = int($top_n_messages / 2);

    # Initialize the hash to store the number of messages to print
    my %messages_to_print = (
        'highlight' => $half_top_n,
        'plain' => $half_top_n,
    );

    $messages_to_print{'highlight'}++ if $top_n_messages % 2 != 0;		# if halving doesn't equate to Top N, then add another row to highlighted messages

    # Step 3: Adjust if one category has fewer messages than needed, ensuring the total remains $top_n_messages
    if ($top_message_occurrences{'highlight'} < $messages_to_print{'highlight'}) {
        $messages_to_print{'highlight'} = $top_message_occurrences{'highlight'};
        $messages_to_print{'plain'} = $top_n_messages - $messages_to_print{'highlight'};
    } elsif ($top_message_occurrences{'plain'} < $messages_to_print{'plain'}) {
        $messages_to_print{'plain'} = $top_message_occurrences{'plain'};
        $messages_to_print{'highlight'} = $top_n_messages - $messages_to_print{'plain'};
    }

    foreach my $grouping ( qw( highlight plain ) ) {
        my $messages_printed = 0;

        # Ensure the grouping exists and is a hash reference
        if (exists $threadpool_activity{$grouping} && ref($threadpool_activity{$grouping}) eq 'HASH') {
            my @top_keys = @{$sorted_keys{$grouping}}[0 .. min($#{$sorted_keys{$grouping}}, $top_n_messages - 1)] if scalar( @{$sorted_keys{$grouping}} ) > 0;

            next unless scalar(@top_keys) > 0;			# skip to the next category if their are no top message keys

            my $header_title = " ";

            if( $grouping eq "highlight" ) {
                $header_title = " " x $table_padding_outer . "$colors{'bright-yellow-HL'}" . " " x $table_padding_inner . sprintf( "%-$col_width{1}s", "TOP HIGHLIGHTED THREAD POOLS ─ ACTIVE THREADS" ) . " " x $table_padding_inner;
                $header_title .= " " x $table_padding_inner . sprintf( "%$col_width{2}s", "Count" ) . " " x $table_padding_inner; 
                $header_title .= "$colors{'NC'}$colors{'bright-yellow'}";
            } elsif( $grouping eq "plain" ) {
                $header_title = " " x $table_padding_outer . "$colors{'bright-magenta-HL'}" . " " x $table_padding_inner . sprintf( "%-$col_width{1}s", "TOP OVERALL THREAD POOLS ─ ACTIVE THREADS" ) . " " x $table_padding_inner;
                $header_title .= " " x $table_padding_inner . sprintf( "%$col_width{2}s", "Count" ) . " " x $table_padding_inner; 
                $header_title .= "$colors{'NC'}$colors{'bright-magenta'}";
            }

            print "$header_title\n";
            print " " x $table_padding_outer . "─" x $table_width . "$colors{'NC'}\n";

            # Print the top thread pools
            foreach my $key (@top_keys) {
                next if $messages_printed++ >= $messages_to_print{$grouping};
 
                my $row = " " x $table_padding_outer;

                if (defined $key && exists $threadpool_activity{$grouping}{$key}) {
                    my $message = substr( $key, 0, $col_width{1} );
                    my $occurrences = scalar keys %{$threadpool_activity{$grouping}{$key}};

                    $row .= " " x $table_padding_inner . sprintf( "%-$col_width{1}s", $message ) . " " x $table_padding_inner; 
                    $row .= " " x $table_padding_inner . sprintf( "%$col_width{2}s", $occurrences ) . " " x $table_padding_inner; 

                    print "$row\n";
                }
            }

            print "\n";
        }
    }

    return;
}

## MAIN ##

# Skip the banner when a --help or --explain view is being dispatched -- those
# views render the banner inside their own pager-piped content so the title
