# Pattern file functions (Issue #19)
sub read_pattern_file {
    my ($filename, $filter_type) = @_;
    my @patterns;

    # Use File::Spec for cross-platform path handling
    my $canonical_filename = File::Spec->canonpath($filename);

    # Validate file exists
    unless (-e $canonical_filename) {
        print STDERR "Warning: Pattern file not found: $filename\n";
        $pattern_file_status{$filter_type}{$filename} = { status => 'error', count => 0 };
        return ();
    }

    # Check file size
    my $size = -s $canonical_filename;
    if ($size > $pattern_file_max_size) {
        print STDERR "Warning: Pattern file exceeds maximum size (10KB): $filename\n";
        $pattern_file_status{$filter_type}{$filename} = { status => 'error', count => 0 };
        return ();
    }

    # Check for binary (null bytes in first 8KB)
    my $fh;
    unless (open $fh, '<:raw', $canonical_filename) {
        print STDERR "Warning: Cannot read pattern file: $filename ($!)\n";
        $pattern_file_status{$filter_type}{$filename} = { status => 'error', count => 0 };
        return ();
    }
    my $header;
    read($fh, $header, 8192);
    if (defined $header && $header =~ /\x00/) {
        close $fh;
        print STDERR "Warning: Pattern file appears to be binary: $filename\n";
        $pattern_file_status{$filter_type}{$filename} = { status => 'error', count => 0 };
        return ();
    }
    close $fh;

    # Read file as text
    unless (open $fh, '<:encoding(UTF-8)', $canonical_filename) {
        print STDERR "Warning: Cannot read pattern file: $filename ($!)\n";
        $pattern_file_status{$filter_type}{$filename} = { status => 'error', count => 0 };
        return ();
    }
    while (<$fh>) {
        s/\r?\n$//;               # Remove line endings (handles LF, CRLF)
        next if /^#/;             # Skip comment lines
        next if /^$/;             # Skip empty lines
        next if /^\s+$/;          # Skip whitespace-only lines
        # Whitespace within content is preserved - no trimming
        push @patterns, $_;
    }
    close $fh;

    if (@patterns == 0) {
        print STDERR "Warning: Pattern file is empty: $filename\n";
        $pattern_file_status{$filter_type}{$filename} = { status => 'empty', count => 0 };
        return ();
    }

    # Warn if pattern count exceeds limit (but use all patterns)
    if (@patterns > $pattern_file_max_patterns) {
        print STDERR "Warning: Pattern file contains " . scalar(@patterns) .
                     " patterns (exceeds recommended limit of $pattern_file_max_patterns): $filename\n";
    }

    $pattern_file_status{$filter_type}{$filename} = { status => 'ok', count => scalar(@patterns) };
    return @patterns;
}

sub build_merged_regex {
    my ($cli_regex, @file_patterns) = @_;

    # Escape file patterns using quotemeta
    my @escaped = map { quotemeta($_) } @file_patterns;

    # Build merged regex
    my $file_regex = join('|', @escaped);

    my $merged;
    if (defined $cli_regex && $cli_regex ne '') {
        $merged = "$cli_regex|$file_regex";
    } else {
        $merged = $file_regex;
    }

    # Warn if merged regex exceeds length threshold
    if (length($merged) > $pattern_regex_max_length) {
        print STDERR "Warning: Merged regex pattern is " . length($merged) .
                     " characters (exceeds recommended limit of $pattern_regex_max_length)\n";
    }

    return $merged;
}

sub get_pattern_file_indicator {
    my ($filter_type, $filename) = @_;
    return '' unless exists $pattern_file_status{$filter_type}{$filename};
    my $status = $pattern_file_status{$filter_type}{$filename}{status};
    return '' if $status eq 'ok';
    return '!' if $status eq 'empty';
    return '!!' if $status eq 'error';
    return '';
}

# User-defined metrics parsing (Issue #22)
sub parse_udm_configs {
    my $number = qr/-?\d+(?:\.\d+)?/;
    my %time_units = map { $_ => 1 } qw( ns us ms s m h );
    my %byte_units = map { $_ => 1 } qw( B b kB KB MB GB TB KiB MiB GiB TiB );
    my %si_units = ( 'k' => 1000, 'K' => 1000, 'M' => 1000**2, 'G' => 1000**3, 'T' => 1000**4 );

    # Case normalization: map lowercase variants to canonical forms
    my %byte_unit_canonical = map { lc($_) => $_ } keys %byte_units;
    my %time_unit_canonical = map { lc($_) => $_ } keys %time_units;
    $time_unit_canonical{'min'} = 'm';

    foreach my $raw_arg (@udm_raw_args) {
        my $arg = $raw_arg;
        my ($custom_pattern, $name, $unit, $function);
        my @patterns;

        # Extract trailing /pattern/ if present (right-to-left parsing)
        if ($arg =~ s{:(/.*/)$}{}) {
            my $pat_str = $1;
            $pat_str =~ s{^/|/$}{}g;  # Strip delimiters
            eval { $custom_pattern = qr/$pat_str/ };
            if ($@) {
                print STDERR "Warning: Invalid regex in -udm '$raw_arg': $@\n";
                next;
            }
            @patterns = ($custom_pattern);
        }

        # Split remaining on : to get name, unit, function
        my @fields = split(/:/, $arg, 3);
        $name = $fields[0];
        $unit = (defined $fields[1] && $fields[1] ne '') ? $fields[1] : undef;
        $function = (defined $fields[2] && $fields[2] ne '') ? $fields[2] : undef;

        unless (defined $name && $name ne '') {
            print STDERR "Warning: -udm requires a metric name: '$raw_arg'\n";
            next;
        }

        # Parse function field into transform and aggregation
        my ($transform, $aggregation);
        if (defined $function) {
            if ($function =~ /^(sum|min|max|avg)\((delta|idelta)\)$/) {
                $aggregation = $1;
                $transform = $2;
            } elsif ($function =~ /^(delta|idelta)$/) {
                $transform = $1;
                $aggregation = 'sum';
            } elsif ($function =~ /^(sum|min|max|avg)$/) {
                $aggregation = $1;
            } else {
                print STDERR "Warning: Invalid function '$function' in -udm '$raw_arg' (valid: sum, min, max, avg, delta, idelta, or combined e.g. max(delta))\n";
                next;
            }
        }
        $aggregation //= 'sum';

        # Normalize unit case: SI units checked case-sensitively first
        # (m = minutes, M = mega), then lowercase lookups for time/byte
        if (defined $unit) {
            if (exists $si_units{$unit}) {
                # Case-sensitive match — $unit stays as-is
            } else {
                my $lc = lc($unit);
                if (exists $time_unit_canonical{$lc}) {
                    $unit = $time_unit_canonical{$lc};
                } elsif (exists $byte_unit_canonical{$lc}) {
                    $unit = $byte_unit_canonical{$lc};
                }
            }
        }

        # Determine unit type, converter, and formatter
        my ($unit_type, $converter, $formatter);
        if (defined $unit && exists $time_units{$unit}) {
            $unit_type = 'time';
            $converter = sub { convert_duration_to_ms($_[0], $unit) };
            $formatter = \&format_time;
        } elsif (defined $unit && exists $si_units{$unit}) {
            $unit_type = 'number';
            my $multiplier = $si_units{$unit};
            $converter = sub { $_[0] * $multiplier };
            $formatter = \&format_number;
        } elsif (defined $unit && exists $byte_units{$unit}) {
            $unit_type = 'bytes';
            $converter = sub { convert_bytes($_[0], $unit) };
            $formatter = \&format_bytes;
        } elsif (defined $unit) {
            print STDERR "Warning: Unknown unit '$unit' in -udm '$raw_arg', treating as raw number\n";
            $unit_type = 'raw';
            $converter = undef;
            $formatter = \&format_number;
        } else {
            $unit_type = 'raw';
            $converter = undef;
            $formatter = \&format_number;
        }

        # Build default patterns if no custom pattern provided
        if (!@patterns) {
            my $escaped_name = quotemeta($name);
            push @patterns, qr/\b${escaped_name}\s*[=:]\s*(${number})/;
            push @patterns, qr/(${number})\s*[=:]?\s*${escaped_name}\b/;
        }

        push @udm_configs, {
            name        => $name,
            base_name   => $name,
            unit        => $unit,
            function    => $function,
            transform   => $transform,
            aggregation => $aggregation,
            patterns    => \@patterns,
            unit_type   => $unit_type,
            converter   => $converter,
            formatter   => $formatter,
        };
    }

    # Disambiguate duplicate metric names by appending :aggregation (#99)
    my %name_counts;
    $name_counts{$_->{name}}++ for @udm_configs;
    for my $config (@udm_configs) {
        if ($name_counts{$config->{name}} > 1) {
            $config->{name} = "$config->{base_name}:$config->{aggregation}";
        }
    }

    push @graph_user_defined_metrics, $_->{name} for @udm_configs;

    # Add UDM metric names to graph columns
    push @graph_columns, map { "udm_$_->{name}" } @udm_configs;
}

# CSV header detection and column mapping for UDM (Issue #22)
sub detect_and_parse_csv_header {
    my ($header_line) = @_;

    # Auto-detect separator: count candidate separators
    my $comma_count = () = $header_line =~ /,/g;
    my $semi_count  = () = $header_line =~ /;/g;
    my $tab_count   = () = $header_line =~ /\t/g;

    my %sep_counts = ( ',' => $comma_count, ';' => $semi_count, "\t" => $tab_count );
    my ($best_sep) = sort { $sep_counts{$b} <=> $sep_counts{$a} } keys %sep_counts;

    # Override with user-specified separator
    if (defined $csv_separator_override) {
        $best_sep = $csv_separator_override eq '\t' ? "\t" : $csv_separator_override;
    } elsif ($sep_counts{$best_sep} < 1) {
        return 0;  # Not a CSV file
    }

    $csv_separator = $best_sep;

    # Split header into column names
    my @headers = split(/\Q$csv_separator\E/, $header_line, -1);
    %csv_col_index = ();
    for my $i (0 .. $#headers) {
        my $col = $headers[$i];
        $col =~ s/^\s+|\s+$//g;
        $csv_col_index{lc($col)} = $i;
    }

    # Find timestamp column
    if (exists $csv_col_index{'timestamp'}) {
        $csv_timestamp_col = $csv_col_index{'timestamp'};
    } else {
        $csv_timestamp_col = 0;  # Fall back to first column
    }

    # Map UDM configs to column indices
    @csv_udm_col_indices = ();
    for my $i (0 .. $#udm_configs) {
        my $col_name = lc($udm_configs[$i]->{base_name});
        if (exists $csv_col_index{$col_name}) {
            $csv_udm_col_indices[$i] = $csv_col_index{$col_name};
        } else {
            $csv_udm_col_indices[$i] = -1;
            print STDERR "Warning: UDM metric '$udm_configs[$i]->{base_name}' not found in CSV headers\n";
        }
    }

    # Map message columns from -ucm
    @csv_message_col_indices = ();
    for my $name (@udm_csv_message_col_names) {
        # Support space-separated column names in a single -ucm argument
        for my $col_name (split(/\s+/, $name)) {
            if (exists $csv_col_index{lc($col_name)}) {
                push @csv_message_col_indices, $csv_col_index{lc($col_name)};
            } else {
                print STDERR "Warning: CSV message column '$col_name' not found in headers\n";
            }
        }
    }

    $csv_detected = 1;
    return 1;
}

# Duration unit autodetection functions (Issue #17)
sub convert_duration_to_ms {
    my ($value, $unit) = @_;
    return undef unless defined $value;
    return $value * 1000         if $unit eq 's';
    return $value                if $unit eq 'ms';
    return $value / 1000         if $unit eq 'us';
    return $value / 1000000      if $unit eq 'ns';
    return $value * 60000        if $unit eq 'm';
    return $value * 3600000      if $unit eq 'h';
    return $value;  # default: assume milliseconds
}

sub detect_light_terminal_background {
    # Detect if terminal has a light background using OSC 11 query
    # Returns 1 if light background detected, 0 otherwise
    # Uses xterm-compatible escape sequence: \e]11;?\e\\
    # Terminal responds with: \e]11;rgb:RRRR/GGGG/BBBB\e\\
    #
    # References:
    # - https://jwodder.github.io/kbits/posts/term-fgbg/
    # - https://dystroy.org/blog/terminal-light/
    #
    # Note: On Windows, OSC 11 query is not reliably supported (only works in
    # Windows Terminal 1.22+, not in legacy conhost or cmd.exe). The stty command
    # used for terminal raw mode is also Unix-only. Users on Windows should use
    # the -lbg flag explicitly if they have a light background terminal.

    # Skip auto-detection on Windows - use -lbg flag instead
    return 0 if $^O eq 'MSWin32';

    return 0 unless -t STDIN && -t STDOUT;  # Only works on interactive terminals

    my $response = '';
    my $is_light = 0;

    eval {
        # Save terminal settings
        my $old_settings = `stty -g 2>/dev/null`;
        chomp $old_settings if $old_settings;

        # Set terminal to raw mode with timeout
        system('stty', '-icanon', '-echo', 'min', '0', 'time', '1') == 0 or die "stty failed";

        # Send OSC 11 query (background color)
        # Using BEL (0x07) as terminator for wider compatibility
        print STDOUT "\e]11;?\a";
        STDOUT->flush();

        # Read response with timeout (using select)
        my $rin = '';
        vec($rin, fileno(STDIN), 1) = 1;

        my $timeout = 0.1;  # 100ms timeout
        my $start = time();

        while ((time() - $start) < $timeout) {
            if (select(my $rout = $rin, undef, undef, 0.01)) {
                my $char;
                if (sysread(STDIN, $char, 1)) {
                    $response .= $char;
                    # Response ends with BEL (0x07) or ST (\e\\)
                    last if $response =~ /\a$/ || $response =~ /\e\\$/;
                }
            }
        }

        # Restore terminal settings
        system('stty', $old_settings) if $old_settings;

        # Parse response: expect format like \e]11;rgb:RRRR/GGGG/BBBB\a
        if ($response =~ /rgb:([0-9a-fA-F]+)\/([0-9a-fA-F]+)\/([0-9a-fA-F]+)/) {
            my ($r, $g, $b) = ($1, $2, $3);

            # Normalize to 0-1 range (values can be 2 or 4 hex digits)
            my $max_val = (length($r) == 4) ? 65535 : 255;
            my $r_norm = hex($r) / $max_val;
            my $g_norm = hex($g) / $max_val;
            my $b_norm = hex($b) / $max_val;

            # Calculate luma (perceived brightness)
            # Using ITU-R BT.709 coefficients
            my $luma = 0.2126 * $r_norm + 0.7152 * $g_norm + 0.0722 * $b_norm;

            # Light background if luma > 0.5
            $is_light = ($luma > 0.5) ? 1 : 0;
        }
    };

    # If anything fails, default to dark background (0)
    return $is_light;
}

sub get_memory_usage {
    my $memory_usage;

    if ($^O eq 'darwin') {                                      # macOS
        # Use ps command - reliable and avoids Proc::ProcessTable SIGTRAP crashes
        my $rss = `ps -o rss= -p $$`;
        chomp $rss;
        $memory_usage = $rss * 1024 if $rss;                    # ps returns KB, convert to bytes
    } elsif ($^O eq 'linux') {                                  # Linux
        # Read /proc/self/statm directly - always available, no dependencies
        if (open my $fh, '<', '/proc/self/statm') {
            my $line = <$fh>;
            close $fh;
            my @fields = split /\s+/, $line;
            if (defined $fields[1]) {
                # Field 1 is RSS in pages, multiply by system page size
                require POSIX;
                my $page_size = POSIX::sysconf(&POSIX::_SC_PAGESIZE);
                $memory_usage = $fields[1] * $page_size;
            }
        }
    } elsif ($^O eq 'MSWin32') {                                # Windows
        eval {
            require Win32::Process::Info;
            Win32::Process::Info->import();
            my $pi = Win32::Process::Info->new();
            my $info = $pi->GetProcInfo();
            ($memory_usage) = map { $_->{WorkingSetSize} } grep { $_->{ProcessId} == $$ } @$info;
        };
        if ($@) {
            warn "Failed to get memory usage on Windows: $@";
        }
    }

    return $memory_usage // 0;
}

# ==================================================================================
# FUZZY MESSAGE CONSOLIDATION (Issue #96)
# Consolidates similar log messages to reduce noise in the top-N message summary.
# Operates on $message body only (metadata fields are exact-match grouping keys).
# ==================================================================================

sub group_similar_messages {
    # Final pass: consolidate ceiling-excluded keys with higher threshold
    if ($consolidation_final_pass) {
        for my $cat_gk (sort keys %consolidation_unmatched) {
            my ($category, $grouping_key) = split(/\|/, $cat_gk, 2);
            my @remaining = sort keys %{$consolidation_unmatched{$cat_gk}};
            next unless @remaining > 1;

            # Select keys that were ceiling-excluded
            my @candidates;
            for my $key (@remaining) {
                my $occ = $log_messages{$category}{$key}{occurrences} // 1;
                if ($occ >= $consolidation_occurrence_ceiling && $occ < $consolidation_final_ceiling) {
                    push @candidates, $key;
                }
            }
            next unless @candidates >= 2;

            # Build n-gram index for candidates
            delete $consolidation_ngram_index{$cat_gk};
            delete $consolidation_key_trigrams{$_} for @candidates;
            build_consolidation_ngram_index($cat_gk, \@candidates);

            my %consumed;
            my $patterns_discovered = 0;
            my $messages_absorbed = 0;
            my $keys_searched = 0;
            my $max_search = min(500, scalar @candidates);

            for my $key (@candidates) {
                last if $keys_searched >= $max_search;
                next if $consumed{$key};

                $keys_searched++;
                my @matches = find_consolidation_candidates($cat_gk, $key, $consolidation_final_threshold);

                for my $match (@matches) {
                    next if $consumed{$match->{key}};

                    my $msg_a = substr($consolidation_key_message{$key} // '', 0, $consolidation_message_length_cap);
                    my $msg_b = substr($consolidation_key_message{$match->{key}} // '', 0, $consolidation_message_length_cap);

                    my $raw_mask = compute_mask($msg_a, $msg_b);
                    my $mask = coalesce_mask($raw_mask);
                    my $canonical = derive_canonical($msg_a, $mask);
                    my $regex = derive_regex($msg_a, $mask);

                    next unless ($msg_a =~ $regex) && ($msg_b =~ $regex);

                    $consumed{$key} = 1;
                    $consumed{$match->{key}} = 1;

                    my $new_cluster = {
                        canonical   => $canonical,
                        pattern     => $regex,
                        mask        => $mask,
                        occurrences => 0,
                        match_count => 0,
                    };

                    for my $src_key ($key, $match->{key}) {
                        if (exists $log_messages{$category}{$src_key}) {
                            merge_consolidation_stats($new_cluster, $log_messages{$category}{$src_key});
                            $new_cluster->{match_count}++;
                            $messages_absorbed++;
                        }
                    }

                    # Interleaved re-scan against remaining candidates
                    for my $ukey (@candidates) {
                        next if $consumed{$ukey};
                        my $umsg = $consolidation_key_message{$ukey};
                        next unless defined $umsg;
                        if ($umsg =~ $regex) {
                            $consumed{$ukey} = 1;
                            if (exists $log_messages{$category}{$ukey}) {
                                merge_consolidation_stats($new_cluster, $log_messages{$category}{$ukey});
                                $new_cluster->{match_count}++;
                                $messages_absorbed++;
                            }
                        }
                    }

                    # Try merge-first into existing patterns
                    my $merged_regex = try_consolidation_merge_into_existing($cat_gk, $canonical, $regex, $mask, $new_cluster);
                    if ($merged_regex) {
                        $patterns_discovered++;
                        # Re-scan remaining candidates against generalized pattern
                        for my $ukey (@candidates) {
                            next if $consumed{$ukey};
                            my $umsg = $consolidation_key_message{$ukey};
                            next unless defined $umsg;
                            if ($umsg =~ $merged_regex) {
                                $consumed{$ukey} = 1;
                                for my $entry (@{$consolidation_patterns{$cat_gk}}) {
                                    if ($entry->{pattern} eq $merged_regex) {
                                        my $cluster = $consolidation_clusters{$cat_gk}{$entry->{canonical}};
                                        if ($cluster && exists $log_messages{$category}{$ukey}) {
                                            merge_consolidation_stats($cluster, $log_messages{$category}{$ukey});
                                            $cluster->{match_count}++;
                                            $entry->{match_count} = $cluster->{match_count};
                                            $messages_absorbed++;
                                        }
                                        last;
                                    }
                                }
                            }
                        }
                        last;
                    }

                    # Add as new pattern
                    $consolidation_clusters{$cat_gk}{$canonical} = $new_cluster;
                    push @{$consolidation_patterns{$cat_gk}}, {
                        pattern     => $regex,
                        cluster_key => $canonical,
                        canonical   => $canonical,
                        match_count => $new_cluster->{match_count},
                    };
                    $patterns_discovered++;
                    last;
                }
            }

            # Remove consumed keys from %log_messages and tracking structures
            for my $key (keys %consumed) {
                delete $consolidation_unmatched{$cat_gk}{$key};
                delete $log_messages{$category}{$key};
                delete $consolidation_key_message{$key};
                delete $consolidation_key_message_cat_gk{$key};
            }

            # Free trigram data from final pass
            delete $consolidation_ngram_index{$cat_gk};
            delete $consolidation_posting_size{$cat_gk};
            for my $key (keys %consumed) {
                delete $consolidation_key_trigrams{$key};
                delete $consolidation_key_trigrams_norm{$key};
            }
        }
    }

    # Inject consolidated clusters back into %log_messages
    for my $cat_gk (sort keys %consolidation_clusters) {
        my ($category, $grouping_key) = split(/\|/, $cat_gk, 2);

        for my $canonical (sort keys %{$consolidation_clusters{$cat_gk}}) {
            my $cluster = $consolidation_clusters{$cat_gk}{$canonical};
            next unless $cluster->{occurrences} > 0;

            # Reconstruct the canonical log_key from the prefix + canonical message
            my $prefix = $consolidation_gk_prefix{$cat_gk} // "";
            my $canonical_log_key = $prefix . $canonical;

            # Truncate to match the display width
            $canonical_log_key = substr($canonical_log_key, 0, ($write_messages_to_csv == 1 ? 350 : $max_log_message_length));

            # Create the %log_messages entry with all merged stats
            $log_messages{$category}{$canonical_log_key} = {
                occurrences       => $cluster->{occurrences},
                is_consolidated   => 1,
            };

            my $entry = $log_messages{$category}{$canonical_log_key};

            # Copy duration stats
            if (defined $cluster->{total_duration}) {
                $entry->{total_duration}     = $cluster->{total_duration};
                $entry->{total_duration_num} = $cluster->{total_duration_num};
                $entry->{sum_of_squares}     = $cluster->{sum_of_squares};
                $entry->{durations}          = $cluster->{durations} // [];
                $entry->{min}                = $cluster->{min} if defined $cluster->{min};
                $entry->{max}                = $cluster->{max} if defined $cluster->{max};
            }

            # Copy bytes stats
            $entry->{total_bytes} = $cluster->{total_bytes} if defined $cluster->{total_bytes};

            # Copy count stats
            if (defined $cluster->{count_sum}) {
                $entry->{count_sum}         = $cluster->{count_sum};
                $entry->{count_occurrences} = $cluster->{count_occurrences};
                $entry->{count_min}         = $cluster->{count_min};
                $entry->{count_max}         = $cluster->{count_max};
            }

            # Copy UDM stats
            foreach my $config (@udm_configs) {
                my $name = $config->{name};
                my $sum_key = "udm_${name}_sum";
                next unless defined $cluster->{$sum_key};
                $entry->{$sum_key} = $cluster->{$sum_key};
                $entry->{"udm_${name}_occurrences"} = $cluster->{"udm_${name}_occurrences"};
                $entry->{"udm_${name}_min"} = $cluster->{"udm_${name}_min"};
                $entry->{"udm_${name}_max"} = $cluster->{"udm_${name}_max"};
            }

            # Recompute impact
            if (defined $entry->{total_duration} && $entry->{occurrences} > 0 && $entry->{total_duration} > 0) {
                my $mean = $entry->{total_duration} / $entry->{occurrences};
                $entry->{impact} = sprintf("%.2f", log($mean ** $impact_time_exponent * $entry->{occurrences}));
            }
        }
    }
}

# Build a composite grouping key from metadata fields for exact-match partitioning
sub build_grouping_key {
    my ($log_level, $truncated_thread, $truncated_object, $session_for_key) = @_;
    return "" if $consolidate_full_key;
    my @parts = ($log_level // "");
    push @parts, ($truncated_thread // "");
    push @parts, ($truncated_object // "");
    push @parts, ($session_for_key // "");
    return join("|", @parts);
}

# Returns hashref of all 3-character substrings from capped message
sub get_consolidation_trigrams {
    my ($str) = @_;
    my $capped = substr($str, 0, $consolidation_message_length_cap);
    my %trigrams;
    for my $i (0 .. length($capped) - 3) {
        $trigrams{substr($capped, $i, 3)} = 1;
    }
    return \%trigrams;
}

# Sorensen-Dice similarity coefficient between two trigram sets (0-100)
sub dice_coefficient {
    my ($trig_a, $trig_b) = @_;
    my $size_a = scalar keys %$trig_a;
    my $size_b = scalar keys %$trig_b;
    return 0 if $size_a == 0 || $size_b == 0;

    my $intersection = 0;
    if ($size_a <= $size_b) {
        for my $t (keys %$trig_a) {
            $intersection++ if exists $trig_b->{$t};
        }
    } else {
        for my $t (keys %$trig_b) {
            $intersection++ if exists $trig_a->{$t};
        }
    }

    return int((2 * $intersection * 100) / ($size_a + $size_b));
}

# Build ngram index for a set of keys within a consolidation category
sub build_consolidation_ngram_index {
    my ($cat_gk, $log_keys_ref) = @_;
    my $indexed = 0;
    for my $log_key (@$log_keys_ref) {
        my $msg = $consolidation_key_message{$log_key};
        next unless defined $msg;
        my $trigrams = get_consolidation_trigrams($msg);
        $consolidation_key_trigrams{$log_key} = $trigrams;
        for my $trig (keys %$trigrams) {
            $consolidation_ngram_index{$cat_gk}{$trig}{$log_key} = 1;
        }
        # Build UUID-normalized trigrams for Dice scoring
        if ($msg =~ $uuid_re) {
            (my $normalized = $msg) =~ s/$uuid_re/<UUID>/g;
            $consolidation_key_trigrams_norm{$log_key} = get_consolidation_trigrams($normalized);
        }
        $indexed++;
    }
    # Cache posting list sizes for discriminative trigram selection
    delete $consolidation_posting_size{$cat_gk};
    for my $trig (keys %{$consolidation_ngram_index{$cat_gk}}) {
        $consolidation_posting_size{$cat_gk}{$trig} = scalar keys %{$consolidation_ngram_index{$cat_gk}{$trig}};
    }
    return $indexed;
}

# Find candidate keys similar to source_key using discriminative trigram pre-filter + Dice verification
sub find_consolidation_candidates {
    my ($cat_gk, $source_key, $threshold_pct, $max_candidates) = @_;
    $max_candidates //= 50;
    my $source_trigrams = $consolidation_key_trigrams{$source_key};
    return () unless defined $source_trigrams;

    my $source_size = scalar keys %$source_trigrams;
    return () if $source_size == 0;

    # Length pre-filter: Dice >= T% requires |B| >= |A|*T/(200-T)
    my $min_cand_size = int($source_size * $threshold_pct / (200 - $threshold_pct));
    my $max_cand_size = int($source_size * (200 - $threshold_pct) / $threshold_pct) + 1;

    # Phase 1: top-K most discriminative trigrams (smallest posting lists)
    my $ps = $consolidation_posting_size{$cat_gk};
    my @disc_trigrams = sort { ($ps->{$a} // 0) <=> ($ps->{$b} // 0) }
                        grep { exists $consolidation_ngram_index{$cat_gk}{$_} }
                        keys %$source_trigrams;
    my $topk_actual = min($consolidation_discriminative_topk, scalar @disc_trigrams);
    splice(@disc_trigrams, $topk_actual) if @disc_trigrams > $topk_actual;

    my $loose_min = max(1, int($consolidation_prefilter_ratio * $topk_actual));

    my %candidate_hits;
    for my $trig (@disc_trigrams) {
        for my $cand_key (keys %{$consolidation_ngram_index{$cat_gk}{$trig}}) {
            next if $cand_key eq $source_key;
            $candidate_hits{$cand_key}++;
        }
    }

    # Phase 2: Full Dice verification using UUID-normalized trigrams when available
    my $source_trig_dice = $consolidation_key_trigrams_norm{$source_key} // $source_trigrams;
    my $source_size_dice = scalar keys %$source_trig_dice;
    my $min_dice_size = int($source_size_dice * $threshold_pct / (200 - $threshold_pct));
    my $max_dice_size = int($source_size_dice * (200 - $threshold_pct) / $threshold_pct) + 1;

    my @results;
    for my $cand_key (keys %candidate_hits) {
        next if $candidate_hits{$cand_key} < $loose_min;

        my $cand_trigrams = $consolidation_key_trigrams{$cand_key};
        next unless defined $cand_trigrams;

        my $cand_size = scalar keys %$cand_trigrams;
        next if $cand_size < $min_cand_size || $cand_size > $max_cand_size;

        my $cand_trig_dice = $consolidation_key_trigrams_norm{$cand_key} // $cand_trigrams;
        my $cand_size_dice = scalar keys %$cand_trig_dice;
        next if $cand_size_dice < $min_dice_size || $cand_size_dice > $max_dice_size;

        my $score = dice_coefficient($source_trig_dice, $cand_trig_dice);
        if ($score >= $threshold_pct) {
            push @results, { key => $cand_key, score => $score };
        }
    }

    @results = sort { $b->{score} <=> $a->{score} || $a->{key} cmp $b->{key} } @results;
    splice(@results, $max_candidates) if @results > $max_candidates;
    return @results;
}

# Pure Perl banded edit distance with backtrace — returns mask arrayref (1=keep, 0=variable)
sub compute_mask {
    my ($str_a, $str_b) = @_;
    my @a = split //, $str_a;
    my @b = split //, $str_b;
    my $la = scalar @a;
    my $lb = scalar @b;

    # Strip common prefix/suffix
    my $prefix = 0;
    my $min_len = $la < $lb ? $la : $lb;
    while ($prefix < $min_len && $a[$prefix] eq $b[$prefix]) { $prefix++; }
    my $suffix = 0;
    while ($suffix < ($min_len - $prefix) &&
           $a[$la - 1 - $suffix] eq $b[$lb - 1 - $suffix]) { $suffix++; }

    my @mask = (0) x $la;
    for my $i (0 .. $prefix - 1) { $mask[$i] = 1; }
    for my $i (0 .. $suffix - 1) { $mask[$la - 1 - $i] = 1; }

    my $mid_a = $la - $prefix - $suffix;
    my $mid_b = $lb - $prefix - $suffix;

    if ($mid_a > 0 && $mid_b > 0) {
        my $m = $mid_a;
        my $n = $mid_b;
        my $k = int(($m > $n ? $m : $n) * 0.6) + 2;
        my $big = $m + $n + 1;

        my @dir;
        my @prev = map { $_ } (0 .. $n);
        $dir[0] = [(0) x ($n + 1)];
        for my $j (1 .. min($n, $k)) { $dir[0][$j] = 2; }

        for my $i (1 .. $m) {
            my $j_min = $i - $k; $j_min = 1 if $j_min < 1;
            my $j_max = $i + $k; $j_max = $n if $j_max > $n;
            my @curr = ($big) x ($n + 1);
            $curr[0] = $i;
            $dir[$i] = [(0) x ($n + 1)];

            for my $j ($j_min .. $j_max) {
                if ($a[$prefix + $i - 1] eq $b[$prefix + $j - 1]) {
                    $curr[$j] = $prev[$j - 1];
                    $dir[$i][$j] = 0;
                } else {
                    my $sc = $prev[$j - 1] + 1;
                    my $dc = $prev[$j] + 1;
                    my $ic = $curr[$j - 1] + 1;
                    if ($sc <= $dc && $sc <= $ic) {
                        $curr[$j] = $sc;
                        $dir[$i][$j] = 0;
                    } elsif ($dc <= $ic) {
                        $curr[$j] = $dc;
                        $dir[$i][$j] = 1;
                    } else {
                        $curr[$j] = $ic;
                        $dir[$i][$j] = 2;
                    }
                }
            }
            @prev = @curr;
        }

        # Backtrace
        my ($i, $j) = ($m, $n);
        while ($i > 0 && $j > 0) {
            my $d = $dir[$i][$j];
            if ($d == 0) {
                $mask[$prefix + $i - 1] = 1 if $a[$prefix + $i - 1] eq $b[$prefix + $j - 1];
                $i--; $j--;
            } elsif ($d == 1) {
                $i--;
            } else {
                $j--;
            }
        }
    }

    return \@mask;
}

# Remove spurious keep regions: short runs between variable, and variable-dominated spans
sub coalesce_mask {
    my ($mask) = @_;
    my @m = @$mask;
    my $len = scalar @m;

    # Pass 1: Remove very short keep runs (<3 chars) between variable regions
    my $i = 0;
    while ($i < $len) {
        if ($m[$i] == 1) {
            my $start = $i;
            while ($i < $len && $m[$i] == 1) { $i++; }
            my $run_len = $i - $start;

            if ($run_len < 3) {
                my $has_var_before = ($start == 0) ? 0 : ($m[$start-1] == 0);
                my $has_var_after  = ($i >= $len)  ? 0 : ($m[$i] == 0);
                if ($has_var_before && $has_var_after) {
                    for my $k ($start .. $start + $run_len - 1) {
                        $m[$k] = 0;
                    }
                }
            }
        } else {
            $i++;
        }
    }

    # Pass 2: variable-dominated spans — collapse keeps where keep/total < 40%
    $i = 0;
    while ($i < $len) {
        if ($m[$i] == 0) {
            my $span_start = $i;
            my $j = $i;
            while ($j < $len) {
                if ($m[$j] == 1) {
                    my $keep_start = $j;
                    while ($j < $len && $m[$j] == 1) { $j++; }
                    my $keep_len = $j - $keep_start;
                    if ($keep_len >= 10) {
                        $j = $keep_start;
                        last;
                    }
                } else {
                    $j++;
                }
            }
            my $span_end = $j;
            my $span_len = $span_end - $span_start;

            if ($span_len >= 5) {
                my $keep_count = 0;
                for my $k ($span_start .. $span_end - 1) {
                    $keep_count++ if $m[$k] == 1;
                }
                if ($keep_count / $span_len < 0.40) {
                    for my $k ($span_start .. $span_end - 1) {
                        $m[$k] = 0;
                    }
                }
            }

            $i = $span_end;
        } else {
            $i++;
        }
    }

    return \@m;
}

# Derive canonical form: keep positions retain chars, variable regions become *
sub derive_canonical {
    my ($reference_string, $mask) = @_;
    my @chars = split //, $reference_string;
    my $result = '';
    my $in_variable = 0;

    for my $i (0 .. $#chars) {
        if ($mask->[$i]) {
            if ($chars[$i] eq '*') {
                if (!$in_variable) {
                    $result .= '*';
                    $in_variable = 1;
                }
            } else {
                $in_variable = 0;
                $result .= $chars[$i];
            }
        } else {
            if (!$in_variable) {
                $result .= '*';
                $in_variable = 1;
            }
        }
    }

    return $result;
}

# Derive compiled regex: keep positions become \Q..\E literals, variable regions become .+?
sub derive_regex {
    my ($reference_string, $mask) = @_;
    my @chars = split //, $reference_string;
    my $pattern = '^';
    my $literal_buf = '';
    my $in_variable = 0;

    for my $i (0 .. $#chars) {
        if ($mask->[$i]) {
            if ($chars[$i] eq '*') {
                if (length $literal_buf) {
                    $pattern .= quotemeta($literal_buf);
                    $literal_buf = '';
                }
                if (!$in_variable) {
                    $in_variable = 1;
                }
            } else {
                if ($in_variable) {
                    $pattern .= '.+?';
                    $in_variable = 0;
                }
                $literal_buf .= $chars[$i];
            }
        } else {
            if (length $literal_buf) {
                $pattern .= quotemeta($literal_buf);
                $literal_buf = '';
            }
            if (!$in_variable) {
                $in_variable = 1;
            }
        }
    }

    if ($in_variable) {
        $pattern .= '.+?';
    }
    if (length $literal_buf) {
        $pattern .= quotemeta($literal_buf);
    }

    $pattern .= '$';
    return qr/$pattern/;
}

# Linear scan of compiled patterns for a consolidation category
# Returns pattern entry on match, undef otherwise. Hot-sorts on match.
sub match_consolidation_patterns {
    my ($category, $grouping_key, $msg) = @_;
    my $cat_gk = "$category|$grouping_key";
    return undef unless exists $consolidation_patterns{$cat_gk};
    my $patterns = $consolidation_patterns{$cat_gk};
    for my $i (0 .. $#$patterns) {
        if ($msg =~ $patterns->[$i]{pattern}) {
            my $entry = $patterns->[$i];
            $entry->{match_count}++;
            # Hot-sort: bubble matched entry up by one position
            if ($i > 0 && $entry->{match_count} > $patterns->[$i-1]{match_count}) {
                ($patterns->[$i], $patterns->[$i-1]) = ($patterns->[$i-1], $patterns->[$i]);
            }
            return $entry;
        }
    }
    return undef;
}

# Merge stats from source entry into target (for consolidation cluster merging)
# Handles all ltl %log_messages fields: occurrences, duration, bytes, count, UDM
sub merge_consolidation_stats {
    my ($target, $source) = @_;
    $target->{occurrences} += ($source->{occurrences} // 0);

    # Duration stats
    if (defined $source->{total_duration}) {
        $target->{total_duration} = ($target->{total_duration} // 0) + $source->{total_duration};
        $target->{total_duration_num} = ($target->{total_duration_num} // 0) + ($source->{total_duration_num} // 0);
        $target->{sum_of_squares} = ($target->{sum_of_squares} // 0) + ($source->{sum_of_squares} // 0);
        $target->{min} = $source->{min} if defined $source->{min} && (!defined $target->{min} || $source->{min} < $target->{min});
        $target->{max} = $source->{max} if defined $source->{max} && (!defined $target->{max} || $source->{max} > $target->{max});
        push @{$target->{durations}}, @{$source->{durations}} if $source->{durations} && @{$source->{durations}};
    }

    # Bytes stats
    $target->{total_bytes} = ($target->{total_bytes} // 0) + $source->{total_bytes} if defined $source->{total_bytes};

    # Count stats
    if (defined $source->{count_sum}) {
        $target->{count_sum} = ($target->{count_sum} // 0) + $source->{count_sum};
        $target->{count_occurrences} = ($target->{count_occurrences} // 0) + ($source->{count_occurrences} // 0);
        $target->{count_min} = $source->{count_min} if defined $source->{count_min} && (!defined $target->{count_min} || $source->{count_min} < $target->{count_min});
        $target->{count_max} = $source->{count_max} if defined $source->{count_max} && (!defined $target->{count_max} || $source->{count_max} > $target->{count_max});
    }

    # UDM stats
    foreach my $config (@udm_configs) {
        my $name = $config->{name};
        my $sum_key = "udm_${name}_sum";
        next unless defined $source->{$sum_key};
        $target->{$sum_key} = ($target->{$sum_key} // 0) + $source->{$sum_key};
        $target->{"udm_${name}_occurrences"} = ($target->{"udm_${name}_occurrences"} // 0) + ($source->{"udm_${name}_occurrences"} // 0);
        my $smin = $source->{"udm_${name}_min"};
        $target->{"udm_${name}_min"} = $smin if defined $smin && (!defined $target->{"udm_${name}_min"} || $smin < $target->{"udm_${name}_min"});
        my $smax = $source->{"udm_${name}_max"};
        $target->{"udm_${name}_max"} = $smax if defined $smax && (!defined $target->{"udm_${name}_max"} || $smax > $target->{"udm_${name}_max"});
    }
}

# Try to merge new pattern into an existing similar pattern (merge-first strategy)
sub try_consolidation_merge_into_existing {
    my ($cat_gk, $new_canonical, $new_regex, $new_mask, $new_cluster) = @_;
    return undef unless exists $consolidation_patterns{$cat_gk};

    my $new_trigrams = get_consolidation_trigrams($new_canonical);

    for my $entry (@{$consolidation_patterns{$cat_gk}}) {
        my $existing = $consolidation_clusters{$cat_gk}{$entry->{canonical}};
        next unless $existing;

        my $existing_trigrams = get_consolidation_trigrams($entry->{canonical});
        my $score = dice_coefficient($new_trigrams, $existing_trigrams);

        if ($score >= $consolidation_threshold) {
            my $raw_mask = compute_mask($entry->{canonical}, $new_canonical);
            my $mask = coalesce_mask($raw_mask);
            my $merged_canonical = derive_canonical($entry->{canonical}, $mask);
            my $merged_regex = derive_regex($entry->{canonical}, $mask);

            next unless ($entry->{canonical} =~ $merged_regex) && ($new_canonical =~ $merged_regex);

            merge_consolidation_stats($existing, $new_cluster);
            $existing->{match_count} += $new_cluster->{match_count};

            my $old_canonical = $entry->{canonical};
            $existing->{canonical} = $merged_canonical;
            $existing->{pattern} = $merged_regex;
            $existing->{mask} = $mask;
            $entry->{canonical} = $merged_canonical;
            $entry->{cluster_key} = $merged_canonical;
            $entry->{pattern} = $merged_regex;
            $entry->{match_count} = $existing->{match_count};

            if ($old_canonical ne $merged_canonical) {
                $consolidation_clusters{$cat_gk}{$merged_canonical} = $existing;
                delete $consolidation_clusters{$cat_gk}{$old_canonical};
            }

            return $merged_regex;
        }
    }
    return undef;
}

# Extract partitioning key from a message for re-scan bucketing
# Simplified for IQ-01: operates on $message only, uses first word or first 20 chars
sub extract_consolidation_bucket_key {
    my ($msg) = @_;
    if ($msg =~ /^(\S+)/) {
        return substr($1, 0, 30);
    }
    return substr($msg, 0, 20);
}

# Partition an array of keys into buckets by their bucket key
sub partition_consolidation_keys {
    my ($keys_ref) = @_;
    my %buckets;
    for my $key (@$keys_ref) {
        my $bk = extract_consolidation_bucket_key($consolidation_key_message{$key} // $key);
        push @{$buckets{$bk}}, $key;
    }
    return \%buckets;
}

# Core pairwise discovery engine for one consolidation category
sub run_consolidation_pass {
    my ($cat_gk, $unmatched_ref, $pass_num) = @_;
    my @unmatched_keys = @$unmatched_ref;
    my $initial_count = scalar @unmatched_keys;

    return (0, 0, 0, 0, 0, 0, 0) if $initial_count < 2;

    # Extract the ltl category (plain/highlight) from the composite key
    my ($category) = split(/\|/, $cat_gk, 2);

    # Separate keys by occurrence ceiling
    my @discovery_candidates;
    my @ceiling_keys;
    for my $key (@unmatched_keys) {
        my $occ = $log_messages{$category}{$key}{occurrences} // 1;
        if ($occ >= $consolidation_occurrence_ceiling) {
            push @ceiling_keys, $key;
        } else {
            push @discovery_candidates, $key;
        }
    }
    my $ceiling_skipped = scalar @ceiling_keys;

    my %consumed;
    my $gate2_absorbed = 0;
    my $fc_calls = 0;
    my $messages_absorbed = 0;

    return (0, 0, $ceiling_skipped, 0, 0, 0, scalar @discovery_candidates) if scalar @discovery_candidates < 2;

    # Gate 2 (S3): match discovery candidates against existing compiled patterns
    my @gate2_survivors;
    for my $key (@discovery_candidates) {
        my $msg = $consolidation_key_message{$key};
        # Use the composite key to look up patterns
        my ($c, $gk) = split(/\|/, $cat_gk, 2);
        my $entry = match_consolidation_patterns($c, $gk, $msg);
        if ($entry) {
            $consumed{$key} = 1;
            my $cluster = $consolidation_clusters{$cat_gk}{$entry->{canonical}};
            if ($cluster && exists $log_messages{$category}{$key}) {
                merge_consolidation_stats($cluster, $log_messages{$category}{$key});
                $messages_absorbed++;
            }
            $gate2_absorbed++;
        } else {
            push @gate2_survivors, $key;
        }
    }

    if (scalar @gate2_survivors < 2) {
        my @remaining = grep { !$consumed{$_} } @unmatched_keys;
        @$unmatched_ref = @remaining;
        return (0, $messages_absorbed, $ceiling_skipped, 0, $gate2_absorbed, $fc_calls, scalar @gate2_survivors);
    }

    # Build n-gram index for gate2 survivors
    my $index_limit = min($consolidation_trigger, scalar @gate2_survivors);
    my @index_batch = @gate2_survivors[0 .. $index_limit - 1];

    delete $consolidation_ngram_index{$cat_gk};
    build_consolidation_ngram_index($cat_gk, \@index_batch);

    my $patterns_discovered = 0;
    my $merges_into_existing = 0;
    my $keys_searched = 0;
    my $max_search = min(500, scalar @index_batch);
    my $cap_hit = 0;

    my $current_pattern_count = exists $consolidation_patterns{$cat_gk} ? scalar @{$consolidation_patterns{$cat_gk}} : 0;

    # Build partitioned buckets for fast re-scan
    my %buckets;
    for my $key (@unmatched_keys) {
        my $bk = extract_consolidation_bucket_key($consolidation_key_message{$key} // $key);
        push @{$buckets{$bk}}, $key;
    }

    for my $key (@index_batch) {
        last if $keys_searched >= $max_search;
        next if $consumed{$key};

        $keys_searched++;
        $fc_calls++;
        my @matches = find_consolidation_candidates($cat_gk, $key, $consolidation_threshold);

        for my $match (@matches) {
            next if $consumed{$match->{key}};

            my $msg_a = substr($consolidation_key_message{$key} // '', 0, $consolidation_message_length_cap);
            my $msg_b = substr($consolidation_key_message{$match->{key}} // '', 0, $consolidation_message_length_cap);

            my $raw_mask = compute_mask($msg_a, $msg_b);
            my $mask = coalesce_mask($raw_mask);
            my $canonical = derive_canonical($msg_a, $mask);
            my $regex = derive_regex($msg_a, $mask);

            next unless ($msg_a =~ $regex) && ($msg_b =~ $regex);

            $consumed{$key} = 1;
            $consumed{$match->{key}} = 1;

            my $new_cluster = {
                canonical   => $canonical,
                pattern     => $regex,
                mask        => $mask,
                occurrences => 0,
                match_count => 0,
            };

            for my $src_key ($key, $match->{key}) {
                if (exists $log_messages{$category}{$src_key}) {
                    merge_consolidation_stats($new_cluster, $log_messages{$category}{$src_key});
                    $new_cluster->{match_count}++;
                    $messages_absorbed++;
                }
            }

            my $scan_regex = $regex;
            my $scan_cluster = $new_cluster;
            my $scan_entry;
            my $merged_regex = try_consolidation_merge_into_existing($cat_gk, $canonical, $regex, $mask, $new_cluster);
            if ($merged_regex) {
                $merges_into_existing++;
                $patterns_discovered++;
                $scan_regex = $merged_regex;

                for my $entry (@{$consolidation_patterns{$cat_gk}}) {
                    if ($entry->{pattern} eq $merged_regex) {
                        $scan_entry = $entry;
                        $scan_cluster = $consolidation_clusters{$cat_gk}{$entry->{canonical}};
                        last;
                    }
                }
            } else {
                # Optional hard cap (--consolidation-max-patterns N, default 0 = unlimited)
                if ($consolidation_max_patterns > 0 && $current_pattern_count >= $consolidation_max_patterns) {
                    $consolidation_clusters{$cat_gk}{$canonical} = $new_cluster;
                    $patterns_discovered++;
                    last;
                }

                $consolidation_clusters{$cat_gk}{$canonical} = $new_cluster;
                $scan_entry = {
                    pattern     => $regex,
                    cluster_key => $canonical,
                    canonical   => $canonical,
                    match_count => $new_cluster->{match_count},
                };
                push @{$consolidation_patterns{$cat_gk}}, $scan_entry;
                $current_pattern_count++;
                $patterns_discovered++;
            }

            # Interleaved re-scan with partitioning
            my $pattern_bk = extract_consolidation_bucket_key($scan_entry ? $scan_entry->{canonical} : $canonical);
            my $bucket_keys = $buckets{$pattern_bk};
            if ($bucket_keys) {
                my @surviving;
                for my $ukey (@$bucket_keys) {
                    if ($consumed{$ukey}) { next; }
                    my $umsg = $consolidation_key_message{$ukey};
                    unless (defined $umsg) { push @surviving, $ukey; next; }
                    if ($umsg =~ $scan_regex) {
                        $consumed{$ukey} = 1;
                        if (exists $log_messages{$category}{$ukey}) {
                            merge_consolidation_stats($scan_cluster, $log_messages{$category}{$ukey});
                            $scan_cluster->{match_count}++;
                            $scan_entry->{match_count} = $scan_cluster->{match_count} if $scan_entry;
                            $messages_absorbed++;
                        }
                    } else {
                        push @surviving, $ukey;
                    }
                }
                $buckets{$pattern_bk} = \@surviving;
            }

            last;
        }
    }

    my @remaining = grep { !$consumed{$_} } @unmatched_keys;
    @$unmatched_ref = @remaining;

    return ($patterns_discovered, $messages_absorbed, $ceiling_skipped, $cap_hit, $gate2_absorbed, $fc_calls, scalar @gate2_survivors);
}

# Cross-cluster merge: merge overlapping patterns whose canonical forms match each other
sub merge_consolidation_overlapping_patterns {
    my ($cat_gk) = @_;
    return 0 unless exists $consolidation_patterns{$cat_gk};
    my @patterns = @{$consolidation_patterns{$cat_gk}};
    return 0 if @patterns < 2;

    my $merges = 0;
    my %removed;

    @patterns = sort { ($consolidation_clusters{$cat_gk}{$b->{canonical}}{match_count} // 0) <=> ($consolidation_clusters{$cat_gk}{$a->{canonical}}{match_count} // 0) } @patterns;

    for my $i (0 .. $#patterns) {
        next if $removed{$i};
        my $parent = $patterns[$i];
        my $parent_cluster = $consolidation_clusters{$cat_gk}{$parent->{canonical}};
        next unless $parent_cluster;

        for my $j ($i + 1 .. $#patterns) {
            next if $removed{$j};
            my $child = $patterns[$j];
            my $child_cluster = $consolidation_clusters{$cat_gk}{$child->{canonical}};
            next unless $child_cluster;

            if ($child->{canonical} =~ $parent->{pattern}) {
                merge_consolidation_stats($parent_cluster, $child_cluster);
                $parent_cluster->{match_count} += $child_cluster->{match_count};
                delete $consolidation_clusters{$cat_gk}{$child->{canonical}};
                $removed{$j} = 1;
                $merges++;
            }
        }
    }

    if ($merges > 0) {
        $consolidation_patterns{$cat_gk} = [ grep { exists $consolidation_clusters{$cat_gk}{$_->{canonical}} } @patterns ];
    }

    return $merges;
}

# Fire a consolidation checkpoint for one category/grouping_key pair
sub run_consolidation_checkpoint {
    my ($category, $grouping_key) = @_;
    my $cat_gk = "$category|$grouping_key";
    $consolidation_cat_stats{$cat_gk}{checkpoints}++;
    my $cp_num = $consolidation_cat_stats{$cat_gk}{checkpoints};

    my @unmatched = sort keys %{$consolidation_unmatched{$cat_gk}};
    my $pre_count = scalar @unmatched;
    return if $pre_count < 2;

    my ($discovered, $absorbed, $ceiling_skipped, $cap_hit, $g2_absorbed, $fc_calls, $g2_survivors) =
        run_consolidation_pass($cat_gk, \@unmatched, $cp_num);

    my $post_count = scalar @unmatched;

    # Update per-category accumulators
    $consolidation_cat_stats{$cat_gk}{s3_checkpoint} += $g2_absorbed;
    $consolidation_cat_stats{$cat_gk}{s4_pairwise}   += ($absorbed - $g2_absorbed);
    $consolidation_cat_stats{$cat_gk}{fc_calls}      += $fc_calls;
    $consolidation_cat_stats{$cat_gk}{patterns_discovered} += $discovered;
    $consolidation_cat_stats{$cat_gk}{patterns_final} = exists $consolidation_patterns{$cat_gk} ? scalar @{$consolidation_patterns{$cat_gk}} : 0;

    # Rebuild %consolidation_unmatched from the modified @unmatched list
    %{$consolidation_unmatched{$cat_gk}} = map { $_ => 1 } @unmatched;

    # Delete absorbed keys from %log_messages and %consolidation_key_message
    for my $key (keys %{$log_messages{$category}}) {
        unless (exists $consolidation_unmatched{$cat_gk}{$key}) {
            # Only delete if this key belongs to this cat_gk grouping
            # (other grouping keys within the same category should not be affected)
            next unless exists $consolidation_key_message{$key};
            my $key_cat_gk = $consolidation_key_message_cat_gk{$key} // "";
            next unless $key_cat_gk eq $cat_gk;
            delete $log_messages{$category}{$key};
            delete $consolidation_key_message{$key};
            delete $consolidation_key_message_cat_gk{$key};
        }
    }

    # Free trigram data
    delete $consolidation_ngram_index{$cat_gk};
    delete $consolidation_posting_size{$cat_gk};
    for my $key (keys %consolidation_key_trigrams) {
        unless (exists $consolidation_unmatched{$cat_gk}{$key}) {
            delete $consolidation_key_trigrams{$key};
            delete $consolidation_key_trigrams_norm{$key};
        }
    }

    # Cross-cluster merge
    if ($discovered > 0) {
        merge_consolidation_overlapping_patterns($cat_gk);
        $consolidation_cat_stats{$cat_gk}{patterns_final} = exists $consolidation_patterns{$cat_gk} ? scalar @{$consolidation_patterns{$cat_gk}} : 0;
    }

    # Track checkpoint stall — consecutive unproductive checkpoints
    if ($discovered == 0 && $absorbed == 0) {
        $consolidation_cat_stats{$cat_gk}{stall_count} = ($consolidation_cat_stats{$cat_gk}{stall_count} // 0) + 1;
    } else {
        $consolidation_cat_stats{$cat_gk}{stall_count} = 0;
    }

}

# Issue #45: Measure all data structures and update high-water marks
# Called after each major subroutine to capture peak memory usage
sub measure_memory_structures {
    # Always capture RSS high-water mark
    $current_memory_usage = get_memory_usage();
    if ($current_memory_usage > $max_memory_usage) {
        $max_memory_usage = $current_memory_usage;
    }

    # Only measure individual structures when -mem flag is used
    return unless $show_memory;

    require Devel::Size;

    # Measure all key data structures
    my %current_sizes = (
        log_occurrences        => Devel::Size::total_size(\%log_occurrences),
        log_analysis           => Devel::Size::total_size(\%log_analysis),
        log_messages           => Devel::Size::total_size(\%log_messages),
        log_stats              => Devel::Size::total_size(\%log_stats),
        log_threadpools        => Devel::Size::total_size(\%log_threadpools),
        log_sessions           => Devel::Size::total_size(\%log_sessions),
        threadpool_activity    => Devel::Size::total_size(\%threadpool_activity),
        udm_last_value         => Devel::Size::total_size(\%udm_last_value),
        heatmap_data           => Devel::Size::total_size(\%heatmap_data),
        heatmap_data_hl        => Devel::Size::total_size(\%heatmap_data_hl),
        heatmap_raw            => Devel::Size::total_size(\%heatmap_raw),
        heatmap_raw_hl         => Devel::Size::total_size(\%heatmap_raw_hl),
        histogram_values       => Devel::Size::total_size(\%histogram_values),
        consolidation_clusters => Devel::Size::total_size(\%consolidation_clusters),
        consolidation_patterns => Devel::Size::total_size(\%consolidation_patterns),
        consolidation_key_message => Devel::Size::total_size(\%consolidation_key_message),
        consolidation_unmatched => Devel::Size::total_size(\%consolidation_unmatched),
    );

    # Update high-water marks (only if current value is larger)
    for my $struct (keys %current_sizes) {
        my $current = $current_sizes{$struct};
        my $hwm = $memory_high_water_marks{$struct} // 0;
        if ($current > $hwm) {
            $memory_high_water_marks{$struct} = $current;
        }
    }
}

sub convert_bytes {
    my ($input_value, $input_unit) = @_;
    my ($value, $unit);

    if( defined( $input_unit ) ) {
        $value = $input_value;
        $unit = $input_unit;
    } else {
        ( $value, $unit ) = $input_value =~ /^(\d+)[ ]?(\w+)$/;
    }

    my %units = (
        'B'  => 1,
        'b'  => 1,
        'kB' => 1000,
        'k'  => 1000,
        'MB' => 1000**2,
        'M'  => 1000**2,
        'GB' => 1000**3,
        'G'  => 1000**3,
        'TB' => 1000**4,
        'T'  => 1000**4,
        'KB'  => 1024,
        'K'   => 1024,
        'KiB' => 1024,
        'MiB' => 1024**2,
        'GiB' => 1024**3,
        'TiB' => 1024**4,
    );

    my $bytes = $value * $units{$unit};

    return $bytes;
}

sub format_bytes {
    my ($value, $unit, $decimals) = @_;
    $decimals = 1 if !defined $decimals;
    my %units = (
        'b'  => 1,
        'B'  => 1,
        'KiB' => 1024,
        'MiB' => 1024**2,
        'GiB' => 1024**3,
        'TiB' => 1024**4,
    );

    return undef unless defined $value;

    my $bytes = $value * $units{$unit};
    my $bytes_int = int($bytes);  # Use integer for unit comparison to avoid float string length issues

    my @unit_order = ('B', 'KiB', 'MiB', 'GiB', 'TiB');
    my $formatted_value = $bytes;
    my $formatted_unit = 'B';

    foreach my $u (@unit_order) {                                           # Determine the most relevant unit
        if( length( $bytes_int ) >= length( $units{$u} ) ) {
# TO DO: 1000kB should convert to MB
        #if ($bytes >= $units{$u}) {
            $formatted_value = $bytes / $units{$u};
            $formatted_unit = $u;
        } else {
            last;
        }
    }

    $formatted_value = sprintf("%.${decimals}f", $formatted_value);
    $formatted_value =~ s/\.0+(?=\s|$)//;             # remove trailing .0 if followed by space or end of string

    return "$formatted_value $formatted_unit";
}

# Build CSV output filename with truncation to avoid filesystem errors
sub build_csv_filename {
    my ($file_type) = @_;  # 'STATS' or 'MESSAGES'
    my ($sec, $min, $hour, $mday, $mon, $year) = localtime();
    my $timestamp = sprintf("%04d-%02d-%02d_%02d%02d%02d", $year + 1900, $mon + 1, $mday, $hour, $min, $sec);

    # Sanitize args: replace special characters with underscores
    my $safe_args = $csv_file_args;
    $safe_args =~ tr/!@#\$%\^&*()_+{}|:"<>?[\];',.\/\\`~ /_/;

    # Build base filename
    my $base = "${timestamp}-LTL-${file_type}-${safe_args}";
    my $extension = ".csv";

    # Truncate if exceeds max length (accounting for extension)
    my $max_base_length = $csv_filename_max_length - length($extension);
    if (length($base) > $max_base_length) {
        $base = substr($base, 0, $max_base_length - 3) . '...';
    }

    return "${base}${extension}";
}

# Wrap text to fit within max_width, breaking on spaces
# Returns array of lines
sub wrap_text {
    my ($text, $max_width) = @_;
    return ($text) if length($text) <= $max_width;

    my @words = split /\s+/, $text;
    my @lines;
    my $current_line = '';

    foreach my $word (@words) {
        if ($current_line eq '') {
            $current_line = $word;
        } elsif (length($current_line) + 1 + length($word) <= $max_width) {
            $current_line .= ' ' . $word;
        } else {
            push @lines, $current_line;
            $current_line = $word;
        }
    }
    push @lines, $current_line if $current_line ne '';

    return @lines;
}

# Shorten filename to fit within max_length, keeping start and end with '...' in middle
# If $strip_path is true, removes directory path first (keeps only basename)
sub shorten_filename {
    my ($filename, $max_length, $strip_path) = @_;

    # Optionally strip directory path, keeping only the filename
    if ($strip_path) {
        $filename =~ s{.*/}{};  # Remove everything up to and including last /
        $filename =~ s{.*\\}{}; # Also handle Windows backslashes
    }

    return $filename if length($filename) <= $max_length;
    return $filename if $max_length < 10;  # Too short to meaningfully shorten

    my $ellipsis = '...';
    my $available = $max_length - length($ellipsis);
    my $left_len = int($available / 2);
    my $right_len = $available - $left_len;

    return substr($filename, 0, $left_len) . $ellipsis . substr($filename, -$right_len);
}

sub format_number {
    my ($value, $space, $decimals) = @_;
    my %units = (
        '1'  => 1,
        'k' => 1000,
        'Mil' => 1000**2,
        'Bil' => 1000**3,
        'Tril' => 1000**4,
    );

    my @unit_order = ('1', 'k', 'Mil', 'Bil', 'Tril');
    my $formatted_value = $value;
    my $formatted_unit = '';
    $decimals = 1 if !defined $decimals;

    foreach my $u (@unit_order) {                  # Determine the most relevant unit
        if ($value >= $units{$u}) {
            $formatted_value = $value / $units{$u};
            $formatted_unit = $u;
        } else {
            last;
        }
    }

    $formatted_value = sprintf("%.${decimals}f%s%s", $formatted_value, defined($space) ? " " : "", $formatted_unit eq "1" ? "" : $formatted_unit );
    $formatted_value =~ s/\.0+(?=\s|$)//;             # remove trailing .0 if followed by space or end of string

    return $formatted_value;
}

sub format_time {
    my ($value, $unit, $format, $space) = @_;
    my %units = (
        'us' => 1,                      # Microseconds
        'ms' => 1000,                   # Milliseconds
        's'  => 1000000,                # Seconds
        'm'  => 60 * 1000000,           # Minutes
        'h'  => 60 * 60 * 1000000,      # Hours
        'D'  => 24 * 60 * 60 * 1000000, # Days
    );

    my %unit_names = (
        'us' => { short => 'us', medium => 'usec', long => 'microseconds' },
        'ms' => { short => 'ms', medium => 'msec', long => 'milliseconds' },
        's'  => { short => 's',  medium => 'sec',      long => 'seconds' },
        'm'  => { short => 'm',  medium => 'min',      long => 'minutes' },
        'h'  => { short => 'h',  medium => 'hr',       long => 'hours' },
        'D'  => { short => 'd',  medium => 'day',      long => 'days' },
    );

    $format = "short" if !defined $format;

    my $microseconds = $value * $units{$unit};


    my @unit_order = ('us', 'ms', 's', 'm', 'h', 'D');
    my $formatted_value = $microseconds;
    my $formatted_unit = 'us';

    foreach my $u (@unit_order) {          # Determine the most relevant unit
        if ($microseconds >= $units{$u}) {
            $formatted_value = $microseconds / $units{$u};
            $formatted_unit = $u;
        } else {
            last;
        }
    }

    $formatted_value = sprintf("%.1f", $formatted_value);
    $formatted_value =~ s/\.0+(?=\s|$)//;                                                    # remove trailing .0 if followed by space or end of string
    

    my $unit_name = $unit_names{$formatted_unit}{$format};                                  # Get the appropriate unit name based on format
    $unit_name =~ s/s$// if $formatted_value == 1 && $format eq 'long';                     # Singular units for long format
    $unit_name = " " . $unit_name if defined( $space );

    return defined $value ? "$formatted_value$unit_name" : undef;
}


# utility function for formating numbers to normal format
sub normalize { $_[0] =~ s/\.0+$//r }

# utility functions for trimming spaces off of a string
sub ltrim { my $s = shift; $s =~ s/^\s+//; return $s }
sub rtrim { my $s = shift; $s =~ s/\s+$//; return $s }
sub trim  { my $s = shift; $s =~ s/^\s+|\s+$//g; return $s }

# Handler for -hg/--histogram option (Issue #25)
# Supports: -hg (all metrics), -hg duration, -hg bytes, -hg count, -hg duration,bytes
# Multiple uses are additive
sub handle_histogram_option {
    my ($opt_name, $opt_value) = @_;
    $histogram_enabled = 1;

    if (defined $opt_value && $opt_value ne '') {
        # Check if the value looks like a filename (not a valid metric)
        # This handles the case where -hg is followed by a filename
        my @parts = split /,/, $opt_value;
        my $has_valid_metric = 0;

        for my $part (@parts) {
            my $metric = lc(trim($part));
            if ($metric =~ /^(duration|time|bytes|count)$/) {
                $has_valid_metric = 1;
                last;
            }
        }

        if (!$has_valid_metric && !@udm_raw_args) {
            # Value doesn't contain any valid metrics and no UDM args - it's likely a filename
            # Push it back to @ARGV so it can be processed as a file
            unshift @ARGV, $opt_value;
            return;
        }

        # Parse comma-separated metrics, additive behavior
        for my $metric (split /,/, $opt_value) {
            $metric = lc(trim($metric));
            if ($metric =~ /^(duration|bytes|count)$/) {
                $histogram_metrics{$metric} = 1;
            } elsif ($metric =~ /^time$/) {
                # 'time' is an alias for 'duration' for consistency
                $histogram_metrics{'duration'} = 1;
            } elsif (@udm_raw_args) {
                # Could be a UDM metric name — store it, validate after parse_udm_configs()
                $histogram_metrics{$metric} = 1;
            } else {
                warn "Unknown histogram metric: $metric (valid: duration, time, bytes, count)\n";
            }
        }
    }
    # If no specific metrics given, will default to all available after parsing
}

