# Resolve the family for a CSV column name. Returns 'level' for log-level
# count and rate columns (their names are dynamic — ERROR, WARN, 2xx, 5xx,
# err-rate_min, etc.). Returns the matching family for UDM dynamic columns
# (which always have a *_min/_mean/_max/_sum/_occurrences suffix). Returns
# undef for unknown columns; the formatter falls back to pass-through.
sub resolve_csv_column_family {
    my ($column) = @_;
    return undef unless defined $column;
    return $csv_column_family{$column} if exists $csv_column_family{$column};
    return 'level' if $column =~ /^(err|msg)-rate(_(sec|min|hr|day))?$/;
    # Log-level columns: matched against the configured log levels.
    return 'level' if grep { $_ eq $column } @log_levels;
    return 'level' if $column =~ /^[1-5]xx$/;  # HTTP status family
    return 'level' if $column =~ /^Pause (Young|Full)$/;
    # UDM dynamic columns: <name>_<aggregate>; family follows the underlying
    # metric, which for UDM today is 'count' (raw numeric) — leave to caller
    # to override if a typed UDM lands.
    return 'count' if $column =~ /_(min|mean|max|sum|occurrences)$/;
    return undef;
}

# Issue #268: format a single numeric value for CSV emission, honoring
# the --csv-precision mode resolved at startup.
#
# Returns:
#   - undef             if $value is undef (preserves missing-data semantics)
#   - $value unchanged  if precision mode is 'full' (raw stored precise float)
#   - $value unchanged  if $value is non-numeric (already-formatted strings
#                       like 'duration_nice', rate strings, etc. pass through)
#   - sprintf("%.<N>f") otherwise, where N is the resolved decimals for the
#                       column's family (or 0 if family is unknown)
sub format_csv_value {
    my ($value, $column) = @_;
    return undef unless defined $value;
    return $value if $csv_precision eq 'full';
    # Non-numeric values (pre-formatted strings) pass through unchanged.
    return $value unless $value =~ /^-?\d+(\.\d+)?([eE][+-]?\d+)?$/;
    my $family = resolve_csv_column_family($column);
    my $decimals = defined $family && exists $csv_family_decimals{$family}
        ? $csv_family_decimals{$family}
        : 0;
    # Per-column override: rate columns within the level family always use
    # 1 decimal in default mode (matching the rules TSV's max_decimals=1).
    # In N mode, N wins.
    if (defined $column && $column =~ /^(err|msg)-rate/ && $csv_precision eq 'default') {
        $decimals = 1;
    }
    return $value if $decimals eq 'n/a';  # defensive — should not occur outside full mode
    # Round to the resolved decimal count, then strip trailing zeros (and a
    # trailing bare decimal point) so the emitted form carries only
    # significant digits. The family decimals are a max, not a fixed width.
    my $formatted = sprintf("%.${decimals}f", $value);
    $formatted =~ s/\.0+$//;
    $formatted =~ s/(\.\d*?)0+$/$1/;
    return $formatted;
}

# Issue #268: render-time CV formatter. Storage is precise; the table
# and bar-graph cells have a fixed 4-char value budget, so render with
# magnitude-adaptive decimals so the value always fits: integer above
# 100, one decimal between 10 and 100, two decimals below 10.
sub format_cv_display {
    my ($cv) = @_;
    return '' unless defined $cv;
    return sprintf('%d',   $cv) if $cv >= 100;
    return sprintf('%.1f', $cv) if $cv >= 10;
    return sprintf('%.2f', $cv);
}


# utility function for formating numbers to normal format
sub normalize { $_[0] =~ s/\.0+$//r }

# utility functions for trimming spaces off of a string
sub ltrim { my $s = shift; $s =~ s/^\s+//; return $s }
sub rtrim { my $s = shift; $s =~ s/\s+$//; return $s }
sub trim  { my $s = shift; $s =~ s/^\s+|\s+$//g; return $s }

# Handler for -hg/--histogram option (Issue #25)
# Supports: -hg (all metrics), -hg duration, -hg bytes, -hg count, -hg duration,bytes
# Multiple uses are additive
# Single resolution surface for display-metric operands (-hm, -hg). Both
# options accept the same vocabulary and MUST resolve it identically:
# built-in names match case-insensitively ('time' is an alias for
# 'duration'); user-defined metric names match case-sensitively by name,
# then by base_name for disambiguated metrics (#104).

# Canonical built-in name for a token, or undef. Safe to call at option
# parse time, before parse_udm_configs() has run.
sub builtin_metric_name {
    my ($token) = @_;
    return undef unless defined $token;
    my $lc = lc trim($token);
    return 'duration' if $lc eq 'duration' || $lc eq 'time';
    return $lc        if $lc eq 'bytes' || $lc eq 'count';
    return undef;
}

# Full resolution including UDM names; must run after parse_udm_configs().
# Returns { kind => 'builtin', name => canonical } |
#         { kind => 'udm', config => $cfg } | undef (unknown token).
sub resolve_metric_operand {
    my ($token) = @_;
    return undef unless defined $token;
    $token = trim($token);
    my $builtin = builtin_metric_name($token);
    return { kind => 'builtin', name => $builtin } if defined $builtin;
    my ($match) = grep { $_->{name} eq $token } @udm_configs;
    ($match) = grep { $_->{base_name} eq $token } @udm_configs if !$match;
    return { kind => 'udm', config => $match } if $match;
    return undef;
}

# The metric vocabulary named in every unknown-metric diagnostic.
sub available_metric_names {
    return (qw(duration bytes count), map { $_->{name} } @udm_configs);
}

sub handle_histogram_option {
    my ($opt_name, $opt_value) = @_;
    $histogram_enabled = 1;

    if (defined $opt_value && $opt_value ne '') {
        # Check if the value looks like a filename (not a valid metric)
        # This handles the case where -hg is followed by a filename
        my @parts = split /,/, $opt_value;
        my $has_valid_metric = grep { defined builtin_metric_name($_) } @parts;

        if (!$has_valid_metric && !@udm_raw_args) {
            # Value doesn't contain any valid metrics and no UDM args - it's likely a filename
            # Push it back to @ARGV so it can be processed as a file
            unshift @ARGV, $opt_value;
            return;
        }

        # Parse comma-separated metrics, additive behavior. Built-in tokens
        # canonicalize through builtin_metric_name(); anything else is kept
        # verbatim as a potential UDM name (case-sensitive) and resolved by
        # resolve_metric_operand() after parse_udm_configs().
        for my $metric (split /,/, $opt_value) {
            $metric = trim($metric);
            my $builtin = builtin_metric_name($metric);
            if (defined $builtin) {
                $histogram_metrics{$builtin} = 1;
            } elsif (@udm_raw_args) {
                $histogram_metrics{$metric} = 1;
            } else {
                warn "Unknown histogram metric: $metric (valid: duration, time, bytes, count)\n";
            }
        }
    }
    # If no specific metrics given, will default to all available after parsing
}

# Classify a single raw @ARGV token as an informational-option invocation, or
# return undef for anything else. Recognizes both single-dash and double-dash
# long forms (so -help, -version, -explain behave the same as --help,
# --version, --explain), the documented short forms (-v, -ex), and the legacy
# help aliases (-?, /help, /?). Returns { kind => 'help'|'explain'|'version',
# topic => T }, where topic is the value of an =TOPIC suffix or undef for a bare
# token (the caller may then consume a following token as the topic). This is
# the single source of truth shared by dispatch_informational_options() and the
# banner-suppression check in MAIN, so the two can never disagree about what
# counts as an informational invocation.
sub classify_informational_arg {
    my ($tok) = @_;
    return undef unless defined $tok;

    if ($tok =~ m{^(?:--?help|-\?|/help|/\?)(?:=(.*))?$}s) {
        return { kind => 'help', topic => $1 };
    }
    if ($tok =~ m{^(?:--?explain|--?ex)(?:=(.*))?$}s) {
        return { kind => 'explain', topic => $1 };
    }
    # Version takes no topic; case-sensitive so -V (--verbose) never matches.
    if ($tok =~ m{^--?version$} || $tok eq '-v') {
        return { kind => 'version' };
    }
    return undef;
}

# Informational options (--help, --explain, --version) print their output and
# exit immediately. They are dispatched from a raw-@ARGV scan BEFORE GetOptions
# so they take precedence over option parsing and over every downstream
# validation — a malformed companion option cannot suppress them. When more
# than one is present the fixed priority is help > explain > version,
# independent of command-line position; the first match in that order wins and
# the process exits.
sub dispatch_informational_options {
    my ($argv) = @_;
    my @args = @$argv;   # scan a copy; never mutate the caller's @ARGV

    my ($want_help, $help_topic)       = (0, '');
    my ($want_explain, $explain_topic) = (0, '');
    my $want_version                   = 0;

    for (my $i = 0; $i < @args; $i++) {
        my $info = classify_informational_arg($args[$i]);
        next unless $info;

        if ($info->{kind} eq 'help') {
            $want_help = 1;
            if (defined $info->{topic}) {
                $help_topic = $info->{topic};      # from =TOPIC suffix
            }
            else {
                # Bare help: a following non-flag word is treated as a topic
                # candidate and validated below (unknown -> error), the same way
                # --explain handles its topic argument.
                my $next = $args[$i + 1];
                if (defined $next && $next !~ /^-/) {
                    $help_topic = $next;
                }
            }
        }
        elsif ($info->{kind} eq 'explain') {
            $want_explain = 1;
            if (defined $info->{topic}) {
                $explain_topic = $info->{topic};   # from =TOPIC suffix
            }
            else {
                # Explain's topic namespace is large (all -so/-explain aliases),
                # so a bare following non-flag word is treated as a topic
                # candidate and validated below (unknown -> error).
                my $next = $args[$i + 1];
                if (defined $next && $next !~ /^-/) {
                    $explain_topic = $next;
                }
            }
        }
        elsif ($info->{kind} eq 'version') {
            $want_version = 1;
        }
    }

    # Fixed priority: help > explain > version.
    if ($want_help) {
        if ($help_topic eq '') {
            print_help();            # already paginated internally
        }
        elsif ($help_topic eq 'statistics') {
            my $out = print_help_statistics();
            $out =~ s/^\n+//;
            pipe_to_pager($out);
        }
        else {
            print_usage("unknown --help topic '$help_topic' (try: statistics)");
            exit 1;
        }
        exit 0;
    }
    if ($want_explain) {
        my $out;
        if ($explain_topic eq '') {
            $out = print_explain_registry();
        }
        else {
            my $topic = resolve_explain_topic($explain_topic);
            if (!defined $topic) {
                print_usage("unknown --explain topic '$explain_topic' (try: 'ltl --explain' for the list)");
                exit 1;
            }
            $out = print_explain_topic($topic);
        }
        $out =~ s/^\n+//;
        pipe_to_pager($out);
        exit 0;
    }
    if ($want_version) {
        print_version();
        exit 0;
    }

    return;
}

# Turn Getopt::Long's captured parse-failure diagnostics into a single,
# specific, user-facing message that names the offending option/value. Getopt
# reports the option name without dashes; _dash_prefix restores the form the
# user typed. The generic "required options not provided" wording survives only
# as the no-match fallback, so it is no longer shown for the common
# unknown-option case (where the required options were in fact provided).
sub _dash_prefix {
    my ($name) = @_;
    return (length($name) == 1 ? "-$name" : "--$name");
}

sub classify_option_error {
    my ($warnings) = @_;
    for my $w (@{ $warnings || [] }) {
        if ($w =~ /^Unknown option:\s+(\S+)/) {
            return "unknown option '" . _dash_prefix($1) . "'";
        }
        if ($w =~ /^Option\s+(\S+)\s+requires an argument/) {
            return "option '" . _dash_prefix($1) . "' requires a value";
        }
        if ($w =~ /^Option\s+(\S+)\s+is ambiguous/) {
            # Should not fire once no_auto_abbrev is set; kept as a safety net.
            return "unknown option '" . _dash_prefix($1) . "'";
        }
    }
    return "required options not provided";
}

sub adapt_to_command_line_options {
    @ORIGINAL_ARGV = @ARGV;

    # Issue #231: record which flag tokens appear in @ARGV vs the env-var
    # splice so the runtime-config -V section can attribute each
    # user-supplied flag to its source (command-line vs environment-variable).
    my @cli_argv = @ARGV;

    # Parse LTL_CONFIG environment variable (Issue #21)
    my @env_args = ();
    if (defined $ENV{LTL_CONFIG} && $ENV{LTL_CONFIG} ne '') {
        $ltl_config_raw = $ENV{LTL_CONFIG};
        @env_args = shellwords($ltl_config_raw);
        unshift @ARGV, @env_args;
    }

    %option_provenance = _classify_argv_provenance(\@cli_argv, \@env_args);

    @ARGV = map { ($_ eq '-?' || $_ eq '/help' || $_ eq '/?') ? '--help' : $_ } @ARGV;

    # Resolve the terminal-width override before dispatching informational
    # options so --help/--explain/--version output reflows to the requested
    # width. This is a deliberately narrow, non-fatal pre-parse: pass_through
    # leaves every other token (including malformed companion options) untouched
    # and runs no other option's parsing or validation, so informational options
    # still short-circuit before full option parsing.
    {
        my @argv_copy = @ARGV;
        my $tw_pre;
        local $SIG{__WARN__} = sub {};
        Getopt::Long::Configure('pass_through');
        Getopt::Long::GetOptionsFromArray(\@argv_copy, 'terminal-width|tw=i' => \$tw_pre);
        Getopt::Long::Configure('no_pass_through');
        $terminal_width = $tw_pre if defined $tw_pre;
    }

    # Informational options (--help, --explain, --version) print their output
    # and exit immediately, taking precedence over option parsing and over any
    # other validation. Dispatching here — before GetOptions — means a
    # malformed companion option (e.g. `--version -b 5`) cannot suppress the
    # informational output. When more than one is present, the fixed priority
    # is help > explain > version, independent of command-line position.
    dispatch_informational_options(\@ARGV);

    # Capture Getopt::Long's own diagnostics (which it would otherwise warn
    # straight to stderr) so a parse failure can be reported as a specific,
    # named error rather than the misleading generic "required options not
    # provided". See classify_option_error().
    my @getopt_warnings;
    my $getopt_ok = do {
        local $SIG{__WARN__} = sub { push @getopt_warnings, $_[0]; };
        GetOptions(
        'bucket-size|bs=i' => \$time_bucket_size,
        'pause|p' => \$pause_output,
        'start|st=s' => \$filter_range_start,
        'end|et=s' => \$filter_range_end,
        'exclude|e=s' => \@exclude_args,
        'include|i=s' => \@include_args,
        'highlight|h=s' => \@highlight_args,
        'exclude-file|ef=s' => \@exclude_files,
        'include-file|if=s' => \@include_files,
        'highlight-file|hf=s' => \@highlight_files,
        'verbose|V:s@' => \@verbose_args,   # Issue #226: optional, repeatable section name; bare -V = all sections
        'top-messages|n=i' => \$top_n_messages,
        'omit-values|ov' => \$omit_values,
        'omit-stats|os' => \$omit_stats,
        'omit-empty|oe' => \$omit_empty,
        'omit-summary|osum' => \$omit_summary,
        'omit-rate|or' => \$omit_rate,
        'omit-durations|od' => \$omit_durations,
        'omit-bytes|ob' => \$omit_bytes,
        'omit-count|oc' => \$omit_count,
        'include-count|ic' => \$include_count,
        'include-query-string|iqs' => \$include_query_string,
        'include-session|is' => \$include_session,
        'hide-session|hs' => \$hide_session,
        'hide-occurrences|ho' => \$hide_occurrences,
        'hide-legend|hl' => \$hide_legend,
        'hide-duration|hd' => \$hide_duration,
        'hide-bytes|hb' => \$hide_bytes,
        'hide-count|hc' => \$hide_count,
        'hide-stats|hst' => \$hide_stats,
        'seconds|s' => \$print_seconds,
        'milliseconds|ms' => \$print_milliseconds,
        'version|v' => \$print_version,
        'duration-min|dmin=i' => \$filter_duration_min,
        'duration-max|dmax=i' => \$filter_duration_max,
        'duration-unit|du=s' => \$duration_unit_override,
        'rate-unit|ru=s' => \$rate_unit,
        'bytes-min|bmin=i' => \$filter_bytes_min,
        'bytes-max|bmax=i' => \$filter_bytes_max,
        'count-min|cmin=i' => \$filter_count_min,
        'count-max|cmax=i' => \$filter_count_max,
        'highlight-duration-min|hdmin=i' => \$highlight_duration_min,
        'highlight-duration-max|hdmax=i' => \$highlight_duration_max,
        'highlight-bytes-min|hbmin=i' => \$highlight_bytes_min,
        'highlight-bytes-max|hbmax=i' => \$highlight_bytes_max,
        'highlight-count-min|hcmin=i' => \$highlight_count_min,
        'highlight-count-max|hcmax=i' => \$highlight_count_max,
	    'memory-usage|mem:s' => \$memory_usage_operand,
        'disable-progress' => \$disable_progress,                                   # hidden
        'output-csv|o' => \$write_messages_to_csv,
        'csv-precision|cp=s' => sub { $csv_precision = $_[1]; $csv_precision_source = "-cp $_[1]"; },
        'sort-on|so=s' => \$sort_type,
        'sort-ascending|sa' => \$sort_ascending,
        'threadpool-activity-summary|tpas' => \$include_threadpool_summary,
        'threadpool-activity|tpa=s' => \@threadpool_activity_args,
        'user-defined-metrics|udm=s' => \@udm_raw_args,
        'udm-csv-message|ucm=s'    => \@udm_csv_message_col_names,
        'udm-csv-separator|ucs=s'  => \$csv_separator_override,
        'mask-uuid|uuid' => \$mask_uuid,
        'group-similar|g:s' => \$group_similar_sensitivity,
        'no-final-pass' => sub { $consolidation_final_pass = 0; },                  # hidden
        'consolidation-trigger=i' => \$consolidation_trigger,                       # hidden
        'consolidation-ceiling=i' => \$consolidation_occurrence_ceiling,            # hidden
        'consolidation-max-patterns=i' => \$consolidation_max_patterns,             # hidden
        'final-threshold=i' => \$consolidation_final_threshold,                     # hidden
        'group-ceiling|gc=i' => \$consolidation_final_ceiling,
        'heatmap|hm:s' => \$heatmap_metric,
        'heatmap-width|hmw=i' => \$heatmap_width,
        'light-background|lbg' => sub { $heatmap_light_bg = 1; $heatmap_light_bg_auto = 0; $heatmap_light_bg_source = '-lbg'; },
        'dark-background|dbg'  => sub { $heatmap_dark_bg_explicit = 1; $heatmap_light_bg_auto = 0; },
        'histogram|hg:s' => \&handle_histogram_option,
        'histogram-width|hgw=i' => sub { $histogram_width_percent = $_[1]; $histogram_width_explicit = 1; },
        'histogram-height|hgh=i' => sub { $histogram_height = $_[1]; $histogram_height_explicit = 1; },
        'hgb|histogram-buckets=i' => \$histogram_bucket_override,
        'dmp|data-model-precision=i' => \$data_model_precision_level,
        # Issue #266: explicit data-model selectors. Each accepts 'raw' or 'bin';
        # any other value dies at parse time via _validate_dm. The flags have no
        # defaults — when unset, the surface's existing logic applies.
        'dm|data-model=s'                  => sub { _validate_dm('data-model',                  $_[1]); $data_model_omnibus   = $_[1]; },
        'hgdm|histogram-data-model=s'      => sub { _validate_dm('histogram-data-model',       $_[1]); $data_model_histogram = $_[1]; },
        'hmdm|heatmap-data-model=s'        => sub { _validate_dm('heatmap-data-model',         $_[1]); $data_model_heatmap   = $_[1]; },
        'mdm|message-stats-data-model=s'   => sub { _validate_dm('message-stats-data-model',   $_[1]); $data_model_message   = $_[1]; },
        'bdm|bucket-stats-data-model=s'    => sub { _validate_dm('bucket-stats-data-model',    $_[1]); $data_model_bucket    = $_[1]; },
        'profile|pr=s'                     => sub { _validate_profile($_[1]); $profile_mode = $_[1]; },
        'terminal-width|tw=i' => \$terminal_width,                                  # hidden
        'no-auto-hide|nah' => \$no_auto_hide,
        'debug-layout' => \$debug_layout,                                           # hidden
        'validate-layout' => \$validate_layout,                                     # hidden
        'help:s'       => \$show_help,                                              # hidden — special-cased; legacy aliases -?/--help via PreProcessor. Optional arg: '' = full help; 'statistics' = stats index; other = error (Issue #261).
        'explain|ex:s' => \$explain_arg,                                            # Issue #261: optional arg: '' = topic registry; <topic> = long-form explanation. Aliases shared with -so (avg, stddev, p1..p99999).
        );
    };
    unless ($getopt_ok) {
        print_usage( classify_option_error(\@getopt_warnings), join('', @getopt_warnings) );
        exit 1;
    }

    # Issue #226: -V section selectivity. Resolve @verbose_args (raw from
    # GetOptions :s@) into %verbose_sections_requested. See HARNESS-DESIGN.md
    # for the contract. Behavior:
    #   no -V                       => $verbose=0, no sections, nothing emitted
    #   -V (no arg)                 => $verbose=1, 'all' sentinel set
    #   -V all                      => same as bare -V
    #   -V list                     => print known sections + descriptions, exit 0
    #   -V <name>                   => $verbose=1, that section selected
    #   -V <a>,<b>  /  -V a -V b    => $verbose=1, both selected
    #   -V bogus                    => warn to stderr, continue without that section
    if (@verbose_args) {
        $verbose = 1;
        my @requested;
        for my $arg (@verbose_args) {
            # Bare -V (no =value) pushes empty string; treat as 'all'.
            if (!defined $arg || $arg eq '') {
                push @requested, 'all';
                next;
            }
            # Allow comma-list shorthand: -V a,b,c
            push @requested, split(/,/, $arg);
        }
        for my $name (@requested) {
            $name =~ s/^\s+|\s+$//g;
            next if $name eq '';
            if ($name eq 'list') {
                print "Known -V sections (Issue #226):\n";
                for my $section (@verbose_section_order) {
                    printf "  %-25s  %s\n",
                        $section, $verbose_section_registry{$section}{description};
                }
                print "\nUsage: -V             emit all sections (default)\n";
                print "       -V all         emit all sections (explicit)\n";
                print "       -V <name>      emit only the named section\n";
                print "       -V a,b,c       emit a comma-separated list of sections\n";
                print "       -V a -V b      same as -V a,b (repeatable)\n";
                exit 0;
            }
            if ($name eq 'all') {
                $verbose_sections_requested{'all'} = 1;
                next;
            }
            if (exists $verbose_section_registry{$name}) {
                $verbose_sections_requested{$name} = 1;
            } elsif ($name =~ m{[/.]} || -e $name) {
                # Looks like a filename (path separator, dot, or existing file
                # on disk) — Getopt::Long greedily ate the next positional
                # argument when the user typed bare `-V <file>`. Push it back
                # to @ARGV and treat -V as bare (all sections). Same pattern
                # as -g, -hm, -hg elsewhere in this parser.
                unshift @ARGV, $name;
                $verbose_sections_requested{'all'} = 1;
            } else {
                warn "Unknown -V section: $name. Known sections: "
                    . join(', ', @verbose_section_order)
                    . " (and 'all', 'list'). Continuing.\n";
            }
        }
        # If -V was given but every requested name was unknown,
        # %verbose_sections_requested is empty. Keep $verbose=1 so the run
        # still records that verbose was requested, but no sections will
        # match through section_requested(). This mirrors the issue body:
        # exit code unchanged, warning emitted, run continues.
    }

    $filter_range{'start'} = $filter_range_start if defined( $filter_range_start );
    $filter_range{'end'} = $filter_range_end if defined(  $filter_range_end );

    # -mem option processing (Issue #356): optional literal operand 'debug'
    # enables per-phase memory diagnostics. Getopt's :s greedily captures a
    # following bare token, so any value other than the literal 'debug' is
    # pushed back as a positional (file) argument. Unlike -g/-hm (#231) the
    # pushback is silent: -mem accepts exactly one literal, so a following
    # filename is the normal invocation shape, not a mis-typed operand.
    if (defined $memory_usage_operand) {
        $show_memory = 1;
        if ($memory_usage_operand eq 'debug') {
            $show_memory_debug = 1;
        } elsif ($memory_usage_operand ne '') {
            unshift @ARGV, $memory_usage_operand;
        }
    }

    # Consolidation option processing (Issue #96)
    if ($group_similar_sensitivity ne "none") {
        if ($group_similar_sensitivity eq '') {
            # -g with no value: use default threshold (85)
            $consolidation_threshold = 85;
        } elsif ($group_similar_sensitivity =~ /^\d+$/) {
            $consolidation_threshold = int($group_similar_sensitivity);
        } else {
            # Non-numeric value captured (likely a filename) — push it back.
            # Issue #231: surface this previously-silent pushback so users
            # see why -g looks like it took the default threshold.
            warn "-g value '$group_similar_sensitivity' is not numeric; treating as positional argument and using default threshold 85.\n";
            unshift @ARGV, $group_similar_sensitivity;
            $consolidation_threshold = 85;
        }
        # Ensure threshold is in valid range
        $consolidation_threshold = 50 if $consolidation_threshold < 50;
        $consolidation_threshold = 99 if $consolidation_threshold > 99;
        $group_similar_sensitivity = $consolidation_threshold;  # normalize for downstream checks
    }

    # Heatmap option processing
    if (defined $heatmap_metric) {
        $heatmap_enabled = 1;
        # Handle case where -hm is followed by a filename (GetOptions captures it as optional value)
        my $builtin = builtin_metric_name($heatmap_metric);
        if ($heatmap_metric eq '') {
            $heatmap_metric = 'duration';  # Default metric (empty string case)
        } elsif (defined $builtin) {
            $heatmap_metric = $builtin;    # canonical form ('time' resolves to 'duration')
        } elsif (@udm_raw_args) {
            # Potential UDM name — resolve via resolve_metric_operand() after parse_udm_configs()
        } else {
            # No UDM args — it's likely a filename, push it back.
            # Issue #231: surface this previously-silent pushback.
            warn "-hm value '$heatmap_metric' is not a built-in metric (duration|bytes|count) and no -udm configs are defined; treating as positional argument and using default metric 'duration'.\n";
            unshift @ARGV, $heatmap_metric;
            $heatmap_metric = 'duration';  # Default metric
        }

        # -dbg wins over -lbg regardless of CLI order: force dark and skip auto-detect
        if ($heatmap_dark_bg_explicit) {
            $heatmap_light_bg = 0;
            $heatmap_light_bg_auto = 0;
            $heatmap_light_bg_source = '-dbg';
        }

        # Auto-detect light terminal background if neither -lbg nor -dbg was set
        if ($heatmap_light_bg_auto) {
            $heatmap_light_bg = detect_light_terminal_background();
            $heatmap_light_bg_source = 'auto-detect';
        }
    }

    # Histogram option processing (Issue #25)
    # If histogram enabled but no specific metrics requested, default to all available after parsing
    # The handler already sets $histogram_enabled = 1 and populates %histogram_metrics
    if ($histogram_enabled) {
        if ($histogram_bucket_override < 0) {
            warn "Invalid bucket override value: $histogram_bucket_override. Disabling override.\n";
            $histogram_bucket_override = 0;
        }
        if ($histogram_height < 3) {
            warn "Histogram height too small: $histogram_height. Using minimum (3).\n";
            $histogram_height = 3;
        }
        if ($histogram_width_percent < 20 || $histogram_width_percent > 100) {
            warn "Invalid histogram width percent: $histogram_width_percent. Using default (95).\n";
            $histogram_width_percent = 95;
        }
    }

    # Data-model precision resolution (Issue #293). The single tiered lever
    # (--data-model-precision, 1..9, default 5) resolves a per-surface
    # bins-per-decade through %TIER_BPD. The tier is the only resolution knob;
    # each surface derives its own bpd. Contract locked at:
    #   features/187-histogram-bin-counter-percentiles.md § Decision 2
    #   features/293-precision-lever-unification.md (per-surface tier table)
    if (!$option_provenance{'data-model-precision'}) {
        $data_model_precision_source = 'default';
    } elsif ($data_model_precision_level < 1 || $data_model_precision_level > 9) {
        warn "Invalid --data-model-precision: $data_model_precision_level (must be 1..9). Using default (5).\n";
        $data_model_precision_level  = 5;
        $data_model_precision_source = 'default';
    } else {
        $data_model_precision_source = "--data-model-precision $data_model_precision_level";
    }
    # Derive each surface's bpd from the resolved tier.
    $percentile_buckets_per_decade   = bpd_for_surface('message-stats');
    $bucket_stats_buckets_per_decade = bpd_for_surface('bucket-stats');
    $heatmap_stream_bpd              = bpd_for_surface('heatmap');
    $histogram_stream_bpd            = bpd_for_surface('histogram');

    # Duration unit option validation (Issue #17)
    if (defined $duration_unit_override) {
        do { print_usage("Invalid duration unit '$duration_unit_override'. Valid values: ns, us, ms, s"); exit 1; }
            unless $duration_unit_override =~ /^(ns|us|ms|s)$/;
    }

    # Rate unit option validation (Issue #122)
    do { print_usage("Invalid rate unit '$rate_unit'. Valid values: s, m, h, d"); exit 1; }
        unless $rate_unit =~ /^(s|m|h|d)$/;

    # CSV precision option validation (Issue #268)
    do { print_usage("Invalid --csv-precision value '$csv_precision'. Valid values: default, full, or a non-negative integer."); exit 1; }
        unless $csv_precision eq 'default' || $csv_precision eq 'full' || $csv_precision =~ /^\d+$/;

    # Resolve duration unit for CSV emission (Issue #268). When -du is set,
    # use that; otherwise ms is the implicit default ltl applies through
    # the parsing/emit paths. Format-detection-derived units are not
    # surfaced here today.
    if (defined $duration_unit_override) {
        $duration_unit_resolved = $duration_unit_override;
        $duration_unit_source   = "-du $duration_unit_override";
    } else {
        $duration_unit_resolved = 'ms';
        $duration_unit_source   = 'default';
    }

    # Resolve per-family decimal counts (Issue #268).
    # - default mode: time-valued families derive from duration unit;
    #   shape is fixed at 3 (unitless); meta and bytes are integer.
    # - full mode: all families read 'n/a' (the emit path bypasses formatting).
    # - N mode: every family uses N decimals.
    my %decimals_by_unit = ( ns => 9, us => 6, ms => 0, s => 0 );
    if ($csv_precision eq 'default') {
        my $time_decimals = $decimals_by_unit{$duration_unit_resolved} // 0;
        %csv_family_decimals = (
            meta       => 0,
            count      => 0,
            duration   => $time_decimals,
            percentile => $time_decimals,
            shape      => 3,
            bytes      => 0,
            level      => 0,
        );
    } elsif ($csv_precision eq 'full') {
        %csv_family_decimals = (
            meta       => 'n/a',
            count      => 'n/a',
            duration   => 'n/a',
            percentile => 'n/a',
            shape      => 'n/a',
            bytes      => 'n/a',
            level      => 'n/a',
        );
    } else {
        # Integer N mode: every family uses N decimals.
        %csv_family_decimals = (
            meta       => $csv_precision + 0,
            count      => $csv_precision + 0,
            duration   => $csv_precision + 0,
            percentile => $csv_precision + 0,
            shape      => $csv_precision + 0,
            bytes      => $csv_precision + 0,
            level      => $csv_precision + 0,
        );
    }

    # Build compiled filter matchers (Issue #21, #117)
    # Handles CLI args with AND (&) / OR (|) operators and pattern files
    $include_filter   = build_filter_matcher(\@include_args,   \@include_files,   'include');
    $exclude_filter   = build_filter_matcher(\@exclude_args,   \@exclude_files,   'exclude');
    $highlight_filter = build_filter_matcher(\@highlight_args,  \@highlight_files, 'highlight');
    $threadpool_activity_regex = join('|', @threadpool_activity_args) if @threadpool_activity_args;

    # Set legacy regex strings for defined-checks and display
    $include_regex   = $include_filter->{regex}   if $include_filter;
    $exclude_regex   = $exclude_filter->{regex}   if $exclude_filter;
    $highlight_regex = $highlight_filter->{regex}  if $highlight_filter;

    # Highlight activation: numeric criteria and the regex matcher each activate
    # highlighting on their own; when both are given a line must satisfy both (AND).
    $numeric_highlight_active = ( grep { defined }
        $highlight_duration_min, $highlight_duration_max,
        $highlight_bytes_min, $highlight_bytes_max,
        $highlight_count_min, $highlight_count_max ) ? 1 : 0;
    $highlight_active = ( defined($highlight_filter) || $numeric_highlight_active ) ? 1 : 0;

    # An inverted numeric range (minimum above maximum) is unsatisfiable: no
    # line can ever pass the filter pair, and no line can ever be highlighted
    # by the highlight pair. Warn up front so the resulting empty selection
    # (or highlight-less run) is explained rather than silent.
    for my $range (
        [ $filter_duration_min,    $filter_duration_max,    '-dmin',  '-dmax',  'no log entries can match'         ],
        [ $filter_bytes_min,       $filter_bytes_max,       '-bmin',  '-bmax',  'no log entries can match'         ],
        [ $filter_count_min,       $filter_count_max,       '-cmin',  '-cmax',  'no log entries can match'         ],
        [ $highlight_duration_min, $highlight_duration_max, '-hdmin', '-hdmax', 'no log entries can be highlighted' ],
        [ $highlight_bytes_min,    $highlight_bytes_max,    '-hbmin', '-hbmax', 'no log entries can be highlighted' ],
        [ $highlight_count_min,    $highlight_count_max,    '-hcmin', '-hcmax', 'no log entries can be highlighted' ],
    ) {
        my ($min, $max, $min_opt, $max_opt, $consequence) = @$range;
        if (defined $min && defined $max && $min > $max) {
            print STDERR "Warning: $min_opt $min is greater than $max_opt $max - the range is unsatisfiable, $consequence\n";
        }
    }

    # --help, --explain, and --version are handled by
    # dispatch_informational_options() before GetOptions runs; $show_help,
    # $explain_arg, and $print_version are populated here but no longer read.

    foreach my $pattern (@ARGV) {									# do in process file globbing for common experience across environments (Windows doesn't glob in the shell, passes in the parameters)
        push @in_files, glob($pattern);
    }

	@in_files = grep { -f $_ } @in_files;								# only accept files in list to be read (remove anything else in the globbed directory list)

    do { print_usage( "unable to open any files" ); exit 2; } unless @in_files;
    do { print_usage( "invalid sort type used" ); exit 1; } unless grep { $_ eq $sort_type } qw(
        occurrences total duration time bytes size mean_bytes impact cv
        count count_occurrences count_total count_sum count_min count_mean count_avg count_max
        std_dev stddev min mean avg max
        p1 p5 p10 p25 p50 p75 p90 p95 p99 p999 p9999 p99999
        iqr skewness kurtosis bimodality_coef
    );

    if( $sort_type =~ /^duration|time$/i ) {
        $sort_key = "total_duration_num";
    } elsif( $sort_type =~ /^min$/i ) {
        $sort_key = "min";
    } elsif( $sort_type =~ /^mean|avg$/i ) {
        $sort_key = "mean";
    } elsif( $sort_type =~ /^max$/i ) {
        $sort_key = "max";
    } elsif( $sort_type =~ /^std_dev|stddev$/i ) {
        $sort_key = "std_dev";
    } elsif( $sort_type =~ /^occurrences|total$/i ) {
        $sort_key = "occurrences";
    } elsif( $sort_type =~ /^bytes|size$/i ) {
        $sort_key = "total_bytes";
    } elsif( $sort_type =~ /^impact$/i ) {
        $sort_key = "impact";
    } elsif( $sort_type =~ /^cv$/i ) {
        $sort_key = "cv";
    } elsif( $sort_type =~ /^count_occurrences|count_total$/i ) {
        $sort_key = "count_occurrences";
    } elsif( $sort_type =~ /^count|count_sum$/i ) {
        $sort_key = "count_sum";
    } elsif( $sort_type =~ /^count_min$/i ) {
        $sort_key = "count_min";
    } elsif( $sort_type =~ /^count_mean|count_avg$/i ) {
        $sort_key = "count_mean";
    } elsif( $sort_type =~ /^count_max$/i ) {
        $sort_key = "count_max";
    } elsif( $sort_type =~ /^mean_bytes$/i ) {
        $sort_key = "mean_bytes";
    } elsif( $sort_type =~ /^(p1|p5|p10|p25|p50|p75|p90|p95|p99|p999|p9999|p99999|iqr|skewness|kurtosis|bimodality_coef)$/i ) {
        # Identity mapping: percentile and distribution-shape metrics are stored on
        # %log_messages under the same key name they're invoked by on -so (#220, #222).
        $sort_key = lc $sort_type;
    }

    parse_udm_configs() if @udm_raw_args;

    # Validate UDM heatmap metric name (must run after parse_udm_configs)
    if ($heatmap_enabled && defined $heatmap_metric && !exists $heatmap_metric_map{$heatmap_metric}) {
        my $resolved = resolve_metric_operand($heatmap_metric);
        if ($resolved && $resolved->{kind} eq 'udm' && $resolved->{config}{agg_kind} eq 'counting') {
            # A per-line distribution over counting (string) values is meaningless
            print STDERR "Warning: Heatmap metric '$heatmap_metric' uses counting aggregation '$resolved->{config}{aggregation}' - heatmap disabled\n";
            $heatmap_enabled = 0;
        } elsif ($resolved && $resolved->{kind} eq 'udm') {
            $heatmap_udm_config = $resolved->{config};
            $heatmap_metric_map{$heatmap_metric} = { column => undef };
        } else {
            die "Error: Unknown heatmap metric '$heatmap_metric'. Available: " . join(', ', available_metric_names()) . "\n";
        }
    }

    # Validate UDM histogram metric names (must run after parse_udm_configs)
    if ($histogram_enabled && %histogram_metrics) {
        for my $metric (keys %histogram_metrics) {
            my $resolved = resolve_metric_operand($metric);
            next if $resolved && $resolved->{kind} eq 'builtin';
            my $match = $resolved ? $resolved->{config} : undef;
            # base_name resolution for disambiguated metrics (#104): register
            # the canonical name alongside the token the user supplied.
            $histogram_metrics{$match->{name}} = 1 if $match && $match->{name} ne $metric;
            if ($match && $match->{agg_kind} eq 'counting') {
                # A per-line distribution over counting (string) values is meaningless
                print STDERR "Warning: Histogram metric '$metric' uses counting aggregation '$match->{aggregation}' - skipping\n";
                delete $histogram_metrics{$metric};
                delete $histogram_metrics{$match->{name}};
            } elsif ($match) {
                push @histogram_udm_configs, $match;
                # Colors resolved from @column_layout in normalize_data_for_output()
            } else {
                die "Error: Unknown histogram metric '$metric'. Available: " . join(', ', available_metric_names()) . "\n";
            }
        }
    }

    # Bare -hg: include all UDM metrics (counting UDMs carry no per-line distribution)
    if ($histogram_enabled && !%histogram_metrics && @udm_configs) {
        @histogram_udm_configs = grep { $_->{agg_kind} ne 'counting' } @udm_configs;
        for my $cfg (@udm_configs) {
            # Colors resolved from @column_layout in normalize_data_for_output()
        }
    }

    # -os/--omit-stats is deprecated: it folds into the consumer-side display
    # toggle. -od/--omit-durations is the producer-side control (durations not
    # captured at all); -hst/--hide-stats is the consumer-side control (the
    # statistics panel is not displayed). Statistics capture/computation is
    # governed by the demand resolution below, not by this flag.
    if ($omit_stats) {
        print STDERR "Warning: -os/--omit-stats is deprecated: use -od/--omit-durations to keep durations from being captured, or -hst/--hide-stats to keep the statistics panel from being displayed\n";
        $hide_stats = 1;
    }

    # Duration-statistics demand resolution: each statistics store is captured
    # and computed only when at least one of its output surfaces is active.
    # Duration-based sort keys (-so min/mean/p50/...) order the messages table
    # and MESSAGES CSV rows, so they are subsumed by those surfaces' terms.
    # Heatmap and histogram consume durations through their own dedicated
    # stores and gates and create no demand here; -V sections report resolved
    # state truthfully whether or not statistics ran, so they create none either.
    $bucket_duration_stats_demand = ( !$omit_durations && (
           (!$hide_stats && !$heatmap_enabled)   # timeline latency-statistics column (heatmap replaces it)
        || $write_messages_to_csv                # STATS CSV statistics columns
    ) ) ? 1 : 0;
    $message_duration_stats_demand = ( !$omit_durations && (
           $top_n_messages > 0                   # messages-table statistics variant
        || $write_messages_to_csv                # MESSAGES CSV statistics columns
    ) ) ? 1 : 0;

    # Statistics-group demand (#305): layer per-group demand on top of the
    # store-level booleans above, from the consumer declarations in
    # @STAT_CONSUMERS. Must run after the -os deprecation fold and the
    # store-level resolution, before the runtime-config emission below.
    resolve_statistics_group_demand();

    # Verbose output: runtime-config section (Issues #19, #21, #56, #226, #231).
    # Extended in #231 to surface per-flag resolution under three sub-sections
    # (command-line, environment-variable, defaults) per the locked decision in
    # features/225-test-harness-coverage-gaps.md § #231. Emitted after every
    # option is resolved (heatmap/histogram validation, -os deprecation fold,
    # duration-statistics demand) so the section reports post-resolution values.
    emit_runtime_config_verbose();

    # Under --profile the calendar date is folded away: day/workday render
    # time-of-day only (%H:%M), week/workweek prefix the weekday (%a %H:%M).
    # The format ends at the minute here; the :%S append below adds second
    # precision within the folded period when -s/-ms is set, same as normal mode.
    if ($profile_mode) {
        $output_timestamp_format = $profile_modes{$profile_mode}{format};
    }

    $output_timestamp_format .= ":%S" if $print_seconds || $print_milliseconds;
    my %argv_hash = map { $_ => 1 } @ARGV;
    my $skip_next = 0;
    foreach my $arg (@ORIGINAL_ARGV) {
        if ($skip_next) {
            $skip_next = 0;
            next;
        }
        # Skip -o/--output and its value (redundant since we're creating the file)
        if ($arg =~ /^(-o|--output-csv|--output)$/) {
            next;  # -o is a flag with no value, just skip it
        }
        unless (exists $argv_hash{$arg}) {
            if ($write_messages_to_csv) {
                # Truncate long arguments (likely regex patterns) to configured max length
                my $truncated_arg = length($arg) > $csv_regex_arg_max_length
                    ? substr($arg, 0, $csv_regex_arg_max_length) . '...'
                    : $arg;
                $csv_file_args .= $truncated_arg;
            }
        }
    }

    return;
}

# Parse various possible formats for input of start and end times and set associated filter variables
sub calculate_start_end_filter_timestamps {
    my ( $log_epoch ) = @_;
    # Calculate midnight of log date: truncate to day boundary
    my $log_date = int($log_epoch / 86400) * 86400;

    foreach my $key (keys %filter_range) {
        my $value = $filter_range{$key};       # Get the value (either $filter_range_start or $filter_range_end)
        next unless length( $filter_range{$key} ) > 0;
        my $epoch_value;  # Variable to store the epoch time
        my $fractional_ms = 0;

        # Extract optional fractional seconds (supports . or , separator, 1-6 digits)
        if ($value =~ s/(\d{2}:\d{2}:\d{2})[.,](\d{1,6})/$1/) {
            my $frac_digits = $2;
            $fractional_ms = $frac_digits * (10 ** (3 - length($frac_digits)));
        }

        # Convert timestamp to epoch seconds using Time::Piece -- WARNING -- use of strptime can cause timezone problems, it appears to work here as I've manually set TZ to UTC on input
        if ( $value =~ /^\d{4}-\d{1,2}-\d{1,2} \d{1,2}:\d{2}:\d{2}/ ) {
            $epoch_value = Time::Piece->strptime( $value, "%Y-%m-%d %H:%M:%S" )->epoch;
        } elsif ( $value =~ /^\d{4}-\d{1,2}-\d{1,2} \d{1,2}:\d{2}/ ) {
            $epoch_value = Time::Piece->strptime( $value, "%Y-%m-%d %H:%M" )->epoch;
        } elsif ( $value =~ /^\d{4}-\d{1,2}-\d{1,2}/ ) {
            $epoch_value = Time::Piece->strptime( $value, "%Y-%m-%d" )->epoch;
        } elsif ( $value =~ /^\d{1,2}:\d{2}:\d{2}/ ) {
            my $tod = Time::Piece->strptime( $value, "%H:%M:%S" )->epoch;  # seconds since midnight
            $epoch_value = $log_date + $tod;
            $filter_range_tod{$key} = $tod + ($fractional_ms / 1000);
        } elsif ( $value =~ /^\d{1,2}:\d{2}/ ) {
            my $tod = Time::Piece->strptime( $value, "%H:%M" )->epoch;     # seconds since midnight
            $epoch_value = $log_date + $tod;
            $filter_range_tod{$key} = $tod + ($fractional_ms / 1000);
        } else {
            print "Warning: unhandled date/time format - option not taken into account\n";
        }

        # Add fractional milliseconds for precision filtering
        $filter_range_epoch{$key} = $epoch_value + ($fractional_ms / 1000) if defined( $epoch_value );
    }
    return 1;
}

sub adapt_to_terminal_settings {
    $terminal_width //= 80;                                             # Default to 80 if terminal width cannot be determined
    $terminal_height //= 24;                                            # Default to 24 if terminal height cannot be determined

    # Auto-adjust the bucket size based on the terminal height (larger terminal can handle more rows)
    # Skip if already set by command-line option (-bs)
    if( !$time_bucket_size ) {
        if( $terminal_height <= 30 ) {
            $time_bucket_size = 120;
        } elsif( $terminal_height <= 45 ) {
            $time_bucket_size = 90;
        } elsif( $terminal_height <= 65 ) {
            $time_bucket_size = 60;
        } elsif( $terminal_height <= 85 ) {
            $time_bucket_size = 30;
        } elsif( $terminal_height > 85 ) {
            $time_bucket_size = 10;
        } else {
            $time_bucket_size = 60;
        }
    }

    # Convert time_bucket_size to seconds based on the time precision mode
    if( $print_seconds ) {
        $bucket_size_seconds = $time_bucket_size;
    } elsif( $print_milliseconds ) {
        $bucket_size_seconds = $time_bucket_size / 1000;
    } else {
        $bucket_size_seconds = $time_bucket_size * 60;
    }

    $max_log_message_length = $terminal_width;		# this is the max that we can print without wrapping, depends on the summary table width, and terminal width
    return;
}

sub pause_for_keypress {
    my ($prompt) = @_;                              # Get the optional prompt message
    $prompt = "Press any key to continue (or Q to quit)..." unless defined $prompt;
    print "\033[0;44m$prompt\033[0m";

    ReadMode 4;                                     # Turn off line buffering
    my $key = ReadKey(0);
    ReadMode 0;                                     # Restore normal input mode

    if (defined $key) {
        if ($key eq "q" || $key eq "Q") {
            print "\r";
            print " " x length( $prompt );
            print "\r\033[0;35mExiting program.\033[0m\n";
            exit 0;
        } else {
            print "\r";
            print " " x length( $prompt );
            print "\r";
            return 1;                               # Return a value indicating "continue"
        }
    } else {
        print "\r";
        print " " x length( $prompt );
        print "\r";
        return 1;
    }
}

# Parse logs, bucket by time, and count log levels
sub read_and_process_logs {
