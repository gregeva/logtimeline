sub print_help {
    my $out = "";

    # Banner is incorporated into the pager-piped help output so the title
    # appears at the top of the less buffer (Issue #261). The standalone
    # print_title() in MAIN is suppressed when --help is invoked.
    $out .= get_title_string();

    my $intro = "LogTimeLine -- a command-line log analysis tool that aggregates timestamped log files into visual timelines. Filter, highlight, zoom, and switch between occurrence counts, latency statistics, heatmaps, histograms, and custom metrics to investigate system behavior over time.";
    $out .= help_wrap($intro, indent => 0, first_indent => 0) . "\n";

    # USAGE
    $out .= help_heading("USAGE");
    $out .= "    ltl [options] <logfile> [logfile2 ...]\n";

    # OPTIONS
    $out .= help_heading("OPTIONS");

    # Time & Buckets
    $out .= help_subheading("Time & Buckets");
    $out .= help_opt("-bs,  --bucket-size <N>",       "Set the width of each time bucket on the timeline (default unit: minutes; -s switches to seconds, -ms switches to milliseconds)");
