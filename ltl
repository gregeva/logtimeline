    # Memory rows (raw bytes)
    printf "MEMORY\trss_peak\t%d\n", $max_memory_usage;

    # Per-structure HWMs (only with -mem)
    if ($show_memory && %memory_high_water_marks) {
        for my $struct (sort keys %memory_high_water_marks) {
            printf "MEMORY\t%s\t%d\n", $struct, $memory_high_water_marks{$struct};
        }
        # Issue #356 (S3): rss_peak minus the sum of all structure high-water
        # marks, floored at zero (HWMs are captured at different instants).
        # Same value the -mem terminal breakdown renders as 'unattributed'.
        my $total_hwm = 0;
        $total_hwm += $_ for values %memory_high_water_marks;
        my $unattributed = $max_memory_usage - $total_hwm;
        $unattributed = 0 if $unattributed < 0;
        printf "MEMORY\tunattributed\t%d\n", $unattributed;
    }

    # Final-state memory snapshot (only with -mem) — shows where memory ended up after consolidation
    if ($show_memory) {
        require Devel::Size;
        printf "MEMORY_FINAL\tlog_messages\t%d\n", Devel::Size::total_size(\%log_messages);
        printf "MEMORY_FINAL\tlog_analysis\t%d\n", Devel::Size::total_size(\%log_analysis);
        printf "MEMORY_FINAL\tconsolidation_clusters\t%d\n", Devel::Size::total_size(\%consolidation_clusters);
        printf "MEMORY_FINAL\tconsolidation_patterns\t%d\n", Devel::Size::total_size(\%consolidation_patterns);
        printf "MEMORY_FINAL\tconsolidation_key_message\t%d\n", Devel::Size::total_size(\%consolidation_key_message);
        printf "MEMORY_FINAL\tconsolidation_unmatched\t%d\n", Devel::Size::total_size(\%consolidation_unmatched);
        printf "MEMORY_FINAL\tconsolidation_ngram_index\t%d\n", Devel::Size::total_size(\%consolidation_ngram_index);
        printf "MEMORY_FINAL\tconsolidation_key_trigrams\t%d\n", Devel::Size::total_size(\%consolidation_key_trigrams);
        printf "MEMORY_FINAL\tconsolidation_key_trigrams_norm\t%d\n", Devel::Size::total_size(\%consolidation_key_trigrams_norm);
    }

    # Hash entry counts for key structures
    my $log_messages_entries = 0;
    for my $cat (keys %log_messages) { $log_messages_entries += scalar keys %{$log_messages{$cat}}; }
    printf "COUNTS\tlog_messages_entries\t%d\n", $log_messages_entries;
    printf "COUNTS\tlog_occurrences_entries\t%d\n", scalar keys %log_occurrences;
    printf "COUNTS\tlog_stats_entries\t%d\n", scalar keys %log_stats;

