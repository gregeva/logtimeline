# Pattern file functions (Issue #19)
sub read_pattern_file {
    my ($filename, $filter_type) = @_;
    my @patterns;

    # Use File::Spec for cross-platform path handling
    my $canonical_filename = File::Spec->canonpath($filename);

    # Validate file exists
    unless (-e $canonical_filename) {
        print STDERR "Warning: Pattern file not found: $filename\n";
        $pattern_file_status{$filter_type}{$filename} = { status => 'error', count => 0 };
        return ();
    }

    # Check file size
    my $size = -s $canonical_filename;
    if ($size > $pattern_file_max_size) {
        print STDERR "Warning: Pattern file exceeds maximum size (10KB): $filename\n";
        $pattern_file_status{$filter_type}{$filename} = { status => 'error', count => 0 };
        return ();
    }

    # Check for binary (null bytes in first 8KB)
    my $fh;
    unless (open $fh, '<:raw', $canonical_filename) {
        print STDERR "Warning: Cannot read pattern file: $filename ($!)\n";
        $pattern_file_status{$filter_type}{$filename} = { status => 'error', count => 0 };
        return ();
    }
    my $header;
    read($fh, $header, 8192);
    if (defined $header && $header =~ /\x00/) {
        close $fh;
        print STDERR "Warning: Pattern file appears to be binary: $filename\n";
        $pattern_file_status{$filter_type}{$filename} = { status => 'error', count => 0 };
        return ();
    }
    close $fh;

    # Read file as text
    unless (open $fh, '<:encoding(UTF-8)', $canonical_filename) {
        print STDERR "Warning: Cannot read pattern file: $filename ($!)\n";
        $pattern_file_status{$filter_type}{$filename} = { status => 'error', count => 0 };
        return ();
    }
    while (<$fh>) {
        s/\r?\n$//;               # Remove line endings (handles LF, CRLF)
        next if /^#/;             # Skip comment lines
        next if /^$/;             # Skip empty lines
        next if /^\s+$/;          # Skip whitespace-only lines
        # Whitespace within content is preserved - no trimming
        push @patterns, $_;
    }
    close $fh;

    if (@patterns == 0) {
        print STDERR "Warning: Pattern file is empty: $filename\n";
        $pattern_file_status{$filter_type}{$filename} = { status => 'empty', count => 0 };
        return ();
    }

    # Warn if pattern count exceeds limit (but use all patterns)
    if (@patterns > $pattern_file_max_patterns) {
        print STDERR "Warning: Pattern file contains " . scalar(@patterns) .
                     " patterns (exceeds recommended limit of $pattern_file_max_patterns): $filename\n";
    }

    $pattern_file_status{$filter_type}{$filename} = { status => 'ok', count => scalar(@patterns) };
    return @patterns;
}

sub build_merged_regex {
    my ($cli_regex, @file_patterns) = @_;

    # Escape file patterns using quotemeta
    my @escaped = map { quotemeta($_) } @file_patterns;

    # Build merged regex
    my $file_regex = join('|', @escaped);

    my $merged;
    if (defined $cli_regex && $cli_regex ne '') {
        $merged = "$cli_regex|$file_regex";
    } else {
        $merged = $file_regex;
    }

    # Warn if merged regex exceeds length threshold
    if (length($merged) > $pattern_regex_max_length) {
        print STDERR "Warning: Merged regex pattern is " . length($merged) .
                     " characters (exceeds recommended limit of $pattern_regex_max_length)\n";
    }

    return $merged;
}

# AND operator (&) support for filter patterns (Issue #117)
# Supports && as escape for literal &
# & binds tighter than | : A&B|C&D = (A AND B) OR (C AND D)
#
# Performance: lookahead chains (?=.*A)(?=.*B) are 5-8x slower than independent
# regex matches because each lookahead scans the full line from position 0.
# Instead, AND terms are compiled as separate qr// and matched independently.

# Parse a pattern string containing & and | operators into OR groups of AND terms.
# Returns arrayref of arrayrefs: [ [term1, term2], [term3] ] for "term1&term2|term3"
sub parse_and_or_pattern {
    my ($pattern) = @_;

    # Replace escaped && with placeholder before splitting
    my $placeholder = "\x00";
    $pattern =~ s/&&/$placeholder/g;

    # Split on | to get OR groups
    my @or_groups = split(/\|/, $pattern, -1);

    my @result;
    for my $group (@or_groups) {
        # Split on & to get AND terms
        my @terms = split(/&/, $group, -1);

        # Restore literal & from placeholder in each term
        @terms = map { s/\Q$placeholder\E/&/gr } @terms;

        push @result, \@terms;
    }

    return \@result;
}

# Build a compiled matcher from CLI args and optional file patterns.
# Returns: { regex => "string for display", matcher => compiled_form }
# compiled_form is either:
#   - a single qr// when no AND operators are present (fast path)
#   - arrayref of arrayrefs of qr// for AND/OR groups
sub build_filter_matcher {
    my ($args_ref, $files_ref, $filter_type) = @_;

    my $has_and = 0;
    my @parsed_groups;  # arrayrefs of AND term arrayrefs

    # Parse CLI args for AND/OR structure
    for my $arg (@$args_ref) {
        my $groups = parse_and_or_pattern($arg);
        for my $group (@$groups) {
            push @parsed_groups, $group;
            $has_and = 1 if @$group > 1;
        }
    }

    # Add file patterns (literal, no AND support)
    if ($files_ref && @$files_ref) {
        for my $file (@$files_ref) {
            my @patterns = read_pattern_file($file, $filter_type);
            for my $pat (@patterns) {
                push @parsed_groups, [ quotemeta($pat) ];
            }
        }
    }

    return undef unless @parsed_groups;

    # Build display string: join all groups with | for verbose/defined checks
    my $regex_str = join('|', map {
        @$_ == 1 ? $_->[0] : join('&', @$_)
    } @parsed_groups);

    my $matcher;
    if ($has_and) {
        # AND present: compile each term separately for independent matching
        $matcher = [ map {
            [ map { qr/$_/ } @$_ ]
        } @parsed_groups ];
    } else {
        # No AND: single compiled regex (fast path, identical to pre-#117 behavior)
        my $combined = join('|', map { $_->[0] } @parsed_groups);
        $matcher = qr/$combined/;
    }

    return { regex => $regex_str, matcher => $matcher };
}

# Match a line against a compiled filter matcher.
# Returns true if the line matches (any OR group has all AND terms match).
sub match_filter {
    my ($line, $filter) = @_;
    my $matcher = $filter->{matcher};

    # Fast path: single compiled regex
    if (ref $matcher eq 'Regexp') {
        return $line =~ $matcher;
    }

    # AND/OR path: check each OR group
    for my $group (@$matcher) {
        my $all_match = 1;
        for my $term (@$group) {
            unless ($line =~ $term) {
                $all_match = 0;
                last;
            }
        }
        return 1 if $all_match;
    }
    return 0;
}

sub get_pattern_file_indicator {
    my ($filter_type, $filename) = @_;
    return '' unless exists $pattern_file_status{$filter_type}{$filename};
    my $status = $pattern_file_status{$filter_type}{$filename}{status};
    return '' if $status eq 'ok';
    return '!' if $status eq 'empty';
    return '!!' if $status eq 'error';
    return '';
}

# User-defined metrics parsing (Issue #22)
sub parse_udm_configs {
    my $number = qr/-?\d+(?:\.\d+)?/;
    my %time_units = map { $_ => 1 } qw( ns us ms s m h );
    my %byte_units = map { $_ => 1 } qw( B b kB KB MB GB TB KiB MiB GiB TiB );
    my %si_units = ( 'k' => 1000, 'K' => 1000, 'M' => 1000**2, 'G' => 1000**3, 'T' => 1000**4 );
    my %udm_agg_aliases = ( avg => 'mean', dcount => 'distinct', unique => 'distinct' );
    my %counting_aggs = map { $_ => 1 } qw( count distinct ratio rate drate );

    # Case normalization: map lowercase variants to canonical forms
    my %byte_unit_canonical = map { lc($_) => $_ } keys %byte_units;
    my %time_unit_canonical = map { lc($_) => $_ } keys %time_units;
    $time_unit_canonical{'min'} = 'm';

    foreach my $raw_arg (@udm_raw_args) {
        my $arg = $raw_arg;
        my ($custom_pattern, $name, $unit, $function);
        my @patterns;

        # Extract trailing /pattern/ if present (right-to-left parsing)
        if ($arg =~ s{:(/.*/)$}{}) {
            my $pat_str = $1;
            $pat_str =~ s{^/|/$}{}g;  # Strip delimiters
            eval { $custom_pattern = qr/$pat_str/ };
            if ($@) {
                print STDERR "Warning: Invalid regex in -udm '$raw_arg': $@\n";
                next;
            }
            @patterns = ($custom_pattern);
        }

        # Split remaining on : to get name, unit, function, token key
        my @fields = split(/:/, $arg, 4);
        $name = $fields[0];
        $unit = (defined $fields[1] && $fields[1] ne '') ? $fields[1] : undef;
        $function = (defined $fields[2] && $fields[2] ne '') ? $fields[2] : undef;
        my $token_key = (defined $fields[3] && $fields[3] ne '') ? $fields[3] : undef;

        unless (defined $name && $name ne '') {
            print STDERR "Warning: -udm requires a metric name: '$raw_arg'\n";
            next;
        }

        if (defined $token_key && defined $custom_pattern) {
            print STDERR "Warning: -udm '$raw_arg' supplies both a token key and a /pattern/ - use one or the other, skipping\n";
            next;
        }

        # Parse function field into transform and aggregation
        my ($transform, $aggregation);
        if (defined $function) {
            # Normalize aggregation aliases, including inside combined forms
            $function =~ s/^(\w+)/exists $udm_agg_aliases{$1} ? $udm_agg_aliases{$1} : $1/e;
            if ($function =~ /^(count|distinct|ratio|rate|drate)\(/) {
                print STDERR "Warning: Counting aggregation '$1' cannot be combined with a transform in -udm '$raw_arg', skipping\n";
                next;
            } elsif ($function =~ /^(sum|min|max|mean)\((delta|idelta)\)$/) {
                $aggregation = $1;
                $transform = $2;
            } elsif ($function =~ /^(delta|idelta)$/) {
                $transform = $1;
                $aggregation = 'sum';
            } elsif ($function =~ /^(sum|min|max|mean|count|distinct|ratio|rate|drate)$/) {
                $aggregation = $1;
            } else {
                print STDERR "Warning: Invalid function '$function' in -udm '$raw_arg' (valid: sum, min, max, mean, count, distinct, ratio, rate, drate, delta, idelta, or combined e.g. max(delta))\n";
                next;
            }
        }
        $aggregation //= 'sum';
        my $agg_kind = $counting_aggs{$aggregation} ? 'counting' : 'numeric';

        # Counting aggregations operate on raw extracted strings: units do not apply
        if ($agg_kind eq 'counting' && defined $unit) {
            print STDERR "Warning: Unit '$unit' ignored for counting aggregation '$aggregation' in -udm '$raw_arg'\n";
            $unit = undef;
        }

        # Normalize unit case: SI units checked case-sensitively first
        # (m = minutes, M = mega), then lowercase lookups for time/byte
        if (defined $unit) {
            if (exists $si_units{$unit}) {
                # Case-sensitive match — $unit stays as-is
            } else {
                my $lc = lc($unit);
                if (exists $time_unit_canonical{$lc}) {
                    $unit = $time_unit_canonical{$lc};
                } elsif (exists $byte_unit_canonical{$lc}) {
                    $unit = $byte_unit_canonical{$lc};
                }
            }
        }

        # Determine unit type, converter, and formatter
        my ($unit_type, $converter, $formatter);
        if (defined $unit && exists $time_units{$unit}) {
            $unit_type = 'time';
            $converter = sub { convert_duration_to_ms($_[0], $unit) };
            $formatter = \&format_time;
        } elsif (defined $unit && exists $si_units{$unit}) {
            $unit_type = 'number';
            my $multiplier = $si_units{$unit};
            $converter = sub { $_[0] * $multiplier };
            $formatter = \&format_number;
        } elsif (defined $unit && exists $byte_units{$unit}) {
            $unit_type = 'bytes';
            $converter = sub { convert_bytes($_[0], $unit) };
            $formatter = \&format_bytes;
        } elsif (defined $unit) {
            print STDERR "Warning: Unknown unit '$unit' in -udm '$raw_arg', treating as raw number\n";
            $unit_type = 'raw';
            $converter = undef;
            $formatter = \&format_number;
        } else {
            $unit_type = 'raw';
            $converter = undef;
            $formatter = \&format_number;
        }

        # Build default patterns if no custom pattern provided; the token key
        # (when given) is the extraction anchor, leaving the name as pure label
        if (!@patterns) {
            my $escaped_key = quotemeta($token_key // $name);
            if ($agg_kind eq 'counting') {
                # Token capture: any run of characters that cannot end a field
                push @patterns, qr/\b${escaped_key}\s*[=:]\s*([^\s,;"'\])]+)/;
            } else {
                push @patterns, qr/\b${escaped_key}\s*[=:]\s*(${number})/;
                push @patterns, qr/(${number})\s*[=:]?\s*${escaped_key}\b/;
            }
        }

        push @udm_configs, {
            name        => $name,
            base_name   => $name,
            unit        => $unit,
            function    => $function,
            transform   => $transform,
            aggregation => $aggregation,
            agg_kind    => $agg_kind,
            token_key   => $token_key,
            patterns    => \@patterns,
            unit_type   => $unit_type,
            converter   => $converter,
            formatter   => $formatter,
        };
    }

    # Disambiguate duplicate metric names by appending :aggregation (#99)
    my %name_counts;
    $name_counts{$_->{name}}++ for @udm_configs;
    for my $config (@udm_configs) {
        if ($name_counts{$config->{name}} > 1) {
            $config->{name} = "$config->{base_name}:$config->{aggregation}";
        }
    }

    push @graph_user_defined_metrics, $_->{name} for @udm_configs;

    # Add UDM metric names to graph columns
    push @graph_columns, map { "udm_$_->{name}" } @udm_configs;
}

# CSV header detection and column mapping for UDM (Issue #22)
sub detect_and_parse_csv_header {
    my ($header_line) = @_;

    # Auto-detect separator: count candidate separators
    my $comma_count = () = $header_line =~ /,/g;
    my $semi_count  = () = $header_line =~ /;/g;
    my $tab_count   = () = $header_line =~ /\t/g;

    my %sep_counts = ( ',' => $comma_count, ';' => $semi_count, "\t" => $tab_count );
    my ($best_sep) = sort { $sep_counts{$b} <=> $sep_counts{$a} || ($a cmp $b) } keys %sep_counts;

    # Override with user-specified separator
    if (defined $csv_separator_override) {
        $best_sep = $csv_separator_override eq '\t' ? "\t" : $csv_separator_override;
    } elsif ($sep_counts{$best_sep} < 1) {
        return 0;  # Not a CSV file
    }

    $csv_separator = $best_sep;

    # Split header into column names
    my @headers = split(/\Q$csv_separator\E/, $header_line, -1);
    %csv_col_index = ();
    for my $i (0 .. $#headers) {
        my $col = $headers[$i];
        $col =~ s/^\s+|\s+$//g;
        $csv_col_index{lc($col)} = $i;
    }

    # Find timestamp column
    if (exists $csv_col_index{'timestamp'}) {
        $csv_timestamp_col = $csv_col_index{'timestamp'};
    } else {
        $csv_timestamp_col = 0;  # Fall back to first column
    }

    # Map UDM configs to column indices
    @csv_udm_col_indices = ();
    for my $i (0 .. $#udm_configs) {
        my $col_name = lc($udm_configs[$i]->{base_name});
        if (exists $csv_col_index{$col_name}) {
            $csv_udm_col_indices[$i] = $csv_col_index{$col_name};
        } else {
            $csv_udm_col_indices[$i] = -1;
            print STDERR "Warning: UDM metric '$udm_configs[$i]->{base_name}' not found in CSV headers\n";
        }
    }

    # Map message columns from -ucm
    @csv_message_col_indices = ();
    for my $name (@udm_csv_message_col_names) {
        # Support space-separated column names in a single -ucm argument
        for my $col_name (split(/\s+/, $name)) {
            if (exists $csv_col_index{lc($col_name)}) {
                push @csv_message_col_indices, $csv_col_index{lc($col_name)};
            } else {
                print STDERR "Warning: CSV message column '$col_name' not found in headers\n";
            }
        }
    }

    $csv_detected = 1;
    return 1;
}

# Duration unit autodetection functions (Issue #17)
sub convert_duration_to_ms {
    my ($value, $unit) = @_;
    return undef unless defined $value;
    return $value * 1000         if $unit eq 's';
    return $value                if $unit eq 'ms';
    return $value / 1000         if $unit eq 'us';
    return $value / 1000000      if $unit eq 'ns';
    return $value * 60000        if $unit eq 'm';
    return $value * 3600000      if $unit eq 'h';
    return $value;  # default: assume milliseconds
}

sub detect_light_terminal_background {
    # Detect if terminal has a light background using OSC 11 query
    # Returns 1 if light background detected, 0 otherwise
    # Uses xterm-compatible escape sequence: \e]11;?\e\\
    # Terminal responds with: \e]11;rgb:RRRR/GGGG/BBBB\e\\
    #
    # References:
    # - https://jwodder.github.io/kbits/posts/term-fgbg/
    # - https://dystroy.org/blog/terminal-light/
    #
    # Note: On Windows, OSC 11 query is not reliably supported (only works in
    # Windows Terminal 1.22+, not in legacy conhost or cmd.exe). The stty command
    # used for terminal raw mode is also Unix-only. Users on Windows should use
    # the -lbg flag explicitly if they have a light background terminal.

    # Skip auto-detection on Windows - use -lbg flag instead
    return 0 if $^O eq 'MSWin32';

    return 0 unless -t STDIN && -t STDOUT;  # Only works on interactive terminals

    my $response = '';
    my $is_light = 0;

    eval {
        # Save terminal settings
        my $old_settings = `stty -g 2>/dev/null`;
        chomp $old_settings if $old_settings;

        # Set terminal to raw mode with timeout
        system('stty', '-icanon', '-echo', 'min', '0', 'time', '1') == 0 or die "stty failed";

        # Send OSC 11 query (background color)
        # Using BEL (0x07) as terminator for wider compatibility
        print STDOUT "\e]11;?\a";
        STDOUT->flush();

        # Read response with timeout (using select)
        my $rin = '';
        vec($rin, fileno(STDIN), 1) = 1;

        my $timeout = 0.1;  # 100ms timeout
        my $start = time();

        while ((time() - $start) < $timeout) {
            if (select(my $rout = $rin, undef, undef, 0.01)) {
                my $char;
                if (sysread(STDIN, $char, 1)) {
                    $response .= $char;
                    # Response ends with BEL (0x07) or ST (\e\\)
                    last if $response =~ /\a$/ || $response =~ /\e\\$/;
                }
            }
        }

        # Restore terminal settings
        system('stty', $old_settings) if $old_settings;

        # Parse response: expect format like \e]11;rgb:RRRR/GGGG/BBBB\a
        if ($response =~ /rgb:([0-9a-fA-F]+)\/([0-9a-fA-F]+)\/([0-9a-fA-F]+)/) {
            my ($r, $g, $b) = ($1, $2, $3);

            # Normalize to 0-1 range (values can be 2 or 4 hex digits)
            my $max_val = (length($r) == 4) ? 65535 : 255;
            my $r_norm = hex($r) / $max_val;
            my $g_norm = hex($g) / $max_val;
            my $b_norm = hex($b) / $max_val;

            # Calculate luma (perceived brightness)
            # Using ITU-R BT.709 coefficients
            my $luma = 0.2126 * $r_norm + 0.7152 * $g_norm + 0.0722 * $b_norm;

            # Light background if luma > 0.5
            $is_light = ($luma > 0.5) ? 1 : 0;
        }
    };

    # If anything fails, default to dark background (0)
    return $is_light;
}

sub get_memory_usage {
    my $memory_usage;

    if ($^O eq 'darwin') {                                      # macOS
        # Use ps command - reliable and avoids Proc::ProcessTable SIGTRAP crashes
        my $rss = `ps -o rss= -p $$`;
        chomp $rss;
        $memory_usage = $rss * 1024 if $rss;                    # ps returns KB, convert to bytes
    } elsif ($^O eq 'linux') {                                  # Linux
        # Read /proc/self/statm directly - always available, no dependencies
        if (open my $fh, '<', '/proc/self/statm') {
            my $line = <$fh>;
            close $fh;
            my @fields = split /\s+/, $line;
            if (defined $fields[1]) {
                # Field 1 is RSS in pages, multiply by system page size
                require POSIX;
                my $page_size = POSIX::sysconf(&POSIX::_SC_PAGESIZE);
                $memory_usage = $fields[1] * $page_size;
            }
        }
    } elsif ($^O eq 'MSWin32') {                                # Windows
        # Memory tracking disabled by default on Windows — use -mem to opt in.
        # Direct kernel32.dll syscall via Win32::API — replaces Win32::Process::Info
        # which used WMI (extremely slow, ~15-20s per call). See #143.
        return 0 unless $show_memory;
        eval {
            require Win32::API;
            my $get_current = Win32::API->new('kernel32', 'GetCurrentProcess', [], 'N');
            my $handle = $get_current->Call();
            # PROCESS_MEMORY_COUNTERS struct: cb(DWORD) + PageFaultCount(DWORD) + 8 SIZE_T fields
            my $is_64bit = length(pack('P', 0)) == 8;
            my $struct_size = $is_64bit ? 72 : 40;
            my $buf = "\0" x $struct_size;
            substr($buf, 0, 4, pack('V', $struct_size));
            my $get_mem_info = Win32::API->new('kernel32', 'K32GetProcessMemoryInfo', ['N', 'P', 'N'], 'I');
            if ($get_mem_info->Call($handle, $buf, $struct_size)) {
                # WorkingSetSize: after cb(4) + PageFaultCount(4) + PeakWorkingSetSize(SIZE_T)
                my $offset = $is_64bit ? 24 : 16;
                $memory_usage = $is_64bit ? unpack('Q', substr($buf, $offset, 8))
                                          : unpack('V', substr($buf, $offset, 4));
            }
        };
        if ($@) {
            warn "Failed to get memory usage on Windows: $@";
        }
    }

    return $memory_usage // 0;
}

# ==================================================================================
# FUZZY MESSAGE CONSOLIDATION (Issue #96)
# Consolidates similar log messages to reduce noise in the top-N message summary.
# Operates on the full $log_key (including [level] [thread] [object] prefix).
# Grouping key partitions by $log_level to prevent cross-level merges.
# See features/fuzzy-message-consolidation.md for design and debugging guide.
# ==================================================================================

sub group_similar_messages {
    print "\rConsolidating similar messages..." unless $disable_progress;

    # Final pass (#150): two-pass architecture operating directly on %log_messages.
    # Pass 1: sorted iteration with sliding window — S3 pattern matching + S4 pairwise discovery.
    # Pass 2: conditional cleanup sweep if Pass 1 created new patterns.
    # No data duplication — keys stay in %log_messages until absorbed.
    # Bounded resources — trigrams built and freed per sliding window (1000 keys).
    if ($consolidation_final_pass) {
        # Save streaming S2/S5 before resetting (needed for verbose output)
        for my $cat_gk (keys %consolidation_unmatched) {
            my ($category_part) = split(/\|/, $cat_gk, 2);
            my ($s2, $s5) = (0, 0);
            for my $key (keys %{$consolidation_unmatched{$cat_gk}}) {
                my $occ = $log_messages{$category_part}{$key}{occurrences} // 1;
                if ($occ >= $consolidation_occurrence_ceiling) { $s2++; } else { $s5++; }
            }
            $consolidation_cat_stats{$cat_gk}{streaming_s2} = $s2;
            $consolidation_cat_stats{$cat_gk}{streaming_s5} = $s5;
        }

        # Reset transient working structures (final pass uses sliding window, not streaming buffers)
        %consolidation_unmatched = ();
        %consolidation_key_message = ();
        %consolidation_key_message_cat_gk = ();
        %consolidation_key_generation = ();
        %consolidation_key_checkpoint_count = ();
        %consolidation_ngram_index = ();
        %consolidation_key_trigrams = ();
        %consolidation_key_trigrams_norm = ();
        %consolidation_posting_size = ();
        %consolidation_category_unmatched_count = ();
        %consolidation_absorption_ema = ();
        # Preserved: %consolidation_patterns, %consolidation_clusters, %consolidation_pattern_generation, %consolidation_cat_stats

        # Swap threshold for final pass (used by find_consolidation_candidates and try_consolidation_merge_into_existing)
        my $saved_threshold = $consolidation_threshold;
        $consolidation_threshold = $consolidation_final_threshold;

        $consolidation_phase = 'final_pass';
        my $fp_total_new_patterns = 0;
        my $fp_window_capacity = 1000;

        # Pass 1: sorted iteration with sliding window
        for my $category (sort keys %log_messages) {
            # Collect and sort keys by message body (strip [$grouping_key] prefix)
            my @sorted_keys = sort {
                my ($msg_a) = $a =~ /^\[[^\]]+\]\s*(.*)/s;
                my ($msg_b) = $b =~ /^\[[^\]]+\]\s*(.*)/s;
                (($msg_a // $a) cmp ($msg_b // $b)) || ($a cmp $b)
            } keys %{$log_messages{$category}};

            my @window;
            my $window_cat_gk = "";

            # Helper to flush the current window through S4
            my $flush_window = sub {
                return if scalar @window < 2 || $window_cat_gk eq "";
                my ($discovered, $s4_pair, $s4_rescan, $fc, $absorbed, $cross_merges) =
                    process_final_pass_window($window_cat_gk, \@window);
                $consolidation_cat_stats{$window_cat_gk}{fp_p1_windows} = ($consolidation_cat_stats{$window_cat_gk}{fp_p1_windows} // 0) + 1;
                $consolidation_cat_stats{$window_cat_gk}{fp_p1_s4_pairwise} = ($consolidation_cat_stats{$window_cat_gk}{fp_p1_s4_pairwise} // 0) + $s4_pair;
                $consolidation_cat_stats{$window_cat_gk}{fp_p1_s4_rescan} = ($consolidation_cat_stats{$window_cat_gk}{fp_p1_s4_rescan} // 0) + $s4_rescan;
                $consolidation_cat_stats{$window_cat_gk}{fp_p1_fc_calls} = ($consolidation_cat_stats{$window_cat_gk}{fp_p1_fc_calls} // 0) + $fc;
                $consolidation_cat_stats{$window_cat_gk}{fp_p1_patterns} = ($consolidation_cat_stats{$window_cat_gk}{fp_p1_patterns} // 0) + $discovered;
                $consolidation_cat_stats{$window_cat_gk}{fp_p1_cross_merges} = ($consolidation_cat_stats{$window_cat_gk}{fp_p1_cross_merges} // 0) + $cross_merges;
                $fp_total_new_patterns += $discovered;
                @window = ();
            };

            for my $log_key (@sorted_keys) {
                next unless exists $log_messages{$category}{$log_key};  # may have been deleted by window processing

                my $capped_msg = substr($log_key, 0, $consolidation_message_length_cap);
                my ($grouping_key) = $log_key =~ /^\[([^\]]+)\]/;
                $grouping_key //= "";
                my $cat_gk = "$category|$grouping_key";

                $consolidation_cat_stats{$cat_gk}{fp_keys_seen} = ($consolidation_cat_stats{$cat_gk}{fp_keys_seen} // 0) + 1;

                # Flush window when grouping key changes (patterns are per cat_gk)
                if ($cat_gk ne $window_cat_gk && @window) {
                    $flush_window->();
                }
                $window_cat_gk = $cat_gk;

                # S3: test against existing compiled patterns
                my $entry = match_consolidation_patterns($category, $grouping_key, $capped_msg);
                if ($entry) {
                    my $cluster = $consolidation_clusters{$cat_gk}{$entry->{canonical}};
                    if ($cluster) {
                        merge_log_message_entry_into_cluster($cluster, $category, $log_key);   # #287: bin-state-aware
                        delete $log_messages{$category}{$log_key};
                        $consolidation_cat_stats{$cat_gk}{fp_p1_s3} = ($consolidation_cat_stats{$cat_gk}{fp_p1_s3} // 0) + 1;
                        next;
                    }
                }

                # S2: ceiling filter — skip S4 for high-occurrence keys (user-configurable scope control)
                my $occ = $log_messages{$category}{$log_key}{occurrences} // 1;
                if ($occ >= $consolidation_final_ceiling) {
                    $consolidation_cat_stats{$cat_gk}{fp_p1_s2_ceiling} = ($consolidation_cat_stats{$cat_gk}{fp_p1_s2_ceiling} // 0) + 1;
                    next;
                }

                # S3 miss, below ceiling → add to sliding window
                push @window, [$log_key, $capped_msg];

                # Window full → run S4 pairwise discovery
                if (scalar @window >= $fp_window_capacity) {
                    $flush_window->();
                }
            }

            # Process remaining window
            $flush_window->();
        }

        # Pass 2: conditional cleanup sweep — only if Pass 1 created new patterns
        if ($fp_total_new_patterns > 0) {
            for my $category (sort keys %log_messages) {
                for my $log_key (sort keys %{$log_messages{$category}}) {
                    my $capped_msg = substr($log_key, 0, $consolidation_message_length_cap);
                    my ($grouping_key) = $log_key =~ /^\[([^\]]+)\]/;
                    $grouping_key //= "";
                    my $cat_gk = "$category|$grouping_key";

                    my $entry = match_consolidation_patterns($category, $grouping_key, $capped_msg);
                    if ($entry) {
                        my $cluster = $consolidation_clusters{$cat_gk}{$entry->{canonical}};
                        if ($cluster) {
                            merge_log_message_entry_into_cluster($cluster, $category, $log_key);   # #287: bin-state-aware
                            delete $log_messages{$category}{$log_key};
                            $consolidation_cat_stats{$cat_gk}{fp_p2_s3} = ($consolidation_cat_stats{$cat_gk}{fp_p2_s3} // 0) + 1;
                        }
                    }
                }
            }
        }

        # Restore threshold and phase
        $consolidation_threshold = $saved_threshold;
        $consolidation_phase = 'streaming';
    }

    # Inject consolidated clusters back into %log_messages
    for my $cat_gk (sort keys %consolidation_clusters) {
        my ($category, $grouping_key) = split(/\|/, $cat_gk, 2);

        for my $canonical (sort keys %{$consolidation_clusters{$cat_gk}}) {
            my $cluster = $consolidation_clusters{$cat_gk}{$canonical};
            next unless $cluster->{occurrences} > 0;

            # Canonical form is already the full log_key (includes [level] [thread] [object] prefix)
            my $canonical_log_key = substr($canonical, 0, (($write_messages_to_csv == 1 || $group_similar_sensitivity ne "none") ? 350 : $max_log_message_length));

            # Create the %log_messages entry with all merged stats
            $log_messages{$category}{$canonical_log_key} = {
                occurrences       => $cluster->{occurrences},
                is_consolidated   => 1,
            };

            my $entry = $log_messages{$category}{$canonical_log_key};

            # Copy duration stats
            if (defined $cluster->{total_duration}) {
                $entry->{total_duration}     = $cluster->{total_duration};
                $entry->{total_duration_num} = $cluster->{total_duration_num};
                $entry->{sum_of_squares}     = $cluster->{sum_of_squares};
                $entry->{durations}          = $cluster->{durations} // [];
                $entry->{min}                = $cluster->{min} if defined $cluster->{min};
                $entry->{max}                = $cluster->{max} if defined $cluster->{max};

                # Issue #287: move the cluster's bin-path state into %log_messages
                # and %log_messages_counters keyed by the canonical log_key. The
                # cluster has already absorbed every constituent key's bin state
                # (via merge_log_message_entry_into_cluster + merge_bin_state);
                # this is where it lands in the global stores so the consumer-
                # side dispatch at calculate_all_statistics sees a single keyed
                # entry, indistinguishable from a non-consolidated key.
                if ($message_stats_capture_mode eq 'bin') {
                    $entry->{duration_count} = $cluster->{duration_count} if defined $cluster->{duration_count};
                    $entry->{_running_mean}  = $cluster->{_running_mean}  if defined $cluster->{_running_mean};
                    $entry->{m2_sum}         = $cluster->{m2_sum}         if defined $cluster->{m2_sum};
                    $entry->{m3_sum}         = $cluster->{m3_sum}         if defined $cluster->{m3_sum};
                    $entry->{m4_sum}         = $cluster->{m4_sum}         if defined $cluster->{m4_sum};
                    if ($cluster->{bin_entry}) {
                        $log_messages_counters{"$category\x1f$canonical_log_key"} = $cluster->{bin_entry};
                    }
                }
            }

            # Copy bytes stats
            $entry->{total_bytes} = $cluster->{total_bytes} if defined $cluster->{total_bytes};

            # Copy count stats
            if (defined $cluster->{count_sum}) {
                $entry->{count_sum}         = $cluster->{count_sum};
                $entry->{count_occurrences} = $cluster->{count_occurrences};
                $entry->{count_min}         = $cluster->{count_min};
                $entry->{count_max}         = $cluster->{count_max};
            }

            # Copy UDM stats
            foreach my $config (@udm_configs) {
                my $name = $config->{name};
                if ($config->{agg_kind} eq 'counting') {
                    # Counting UDMs carry per-message occurrences only (Issue #313)
                    $entry->{"udm_${name}_occurrences"} = $cluster->{"udm_${name}_occurrences"}
                        if defined $cluster->{"udm_${name}_occurrences"};
                    next;
                }
                my $sum_key = "udm_${name}_sum";
                next unless defined $cluster->{$sum_key};
                $entry->{$sum_key} = $cluster->{$sum_key};
                $entry->{"udm_${name}_occurrences"} = $cluster->{"udm_${name}_occurrences"};
                $entry->{"udm_${name}_min"} = $cluster->{"udm_${name}_min"};
                $entry->{"udm_${name}_max"} = $cluster->{"udm_${name}_max"};
            }

            # Recompute impact
            if (defined $entry->{total_duration} && $entry->{occurrences} > 0 && $entry->{total_duration} > 0) {
                my $mean = $entry->{total_duration} / $entry->{occurrences};
                $entry->{impact} = log($mean ** $impact_time_exponent * $entry->{occurrences});
            }
        }
    }

    unless ($disable_progress) {
        print "\r$colors{'bright-green'}Consolidating similar messages completed.$colors{'NC'}";
        print " " x ( $terminal_width - length( "Consolidating similar messages completed." ) );
    }
    print "\n";
}

# Returns hashref of all 3-character substrings from capped message
sub get_consolidation_trigrams {
    my ($str) = @_;
    my $capped = substr($str, 0, $consolidation_message_length_cap);
    my %trigrams;
    for my $i (0 .. length($capped) - 3) {
        $trigrams{substr($capped, $i, 3)} = 1;
    }
    return \%trigrams;
}

# Sorensen-Dice similarity coefficient between two trigram sets (0-100)
sub dice_coefficient {
    my ($trig_a, $trig_b) = @_;
    my $size_a = scalar keys %$trig_a;
    my $size_b = scalar keys %$trig_b;
    return 0 if $size_a == 0 || $size_b == 0;

    my $intersection = 0;
    if ($size_a <= $size_b) {
        for my $t (keys %$trig_a) {
            $intersection++ if exists $trig_b->{$t};
        }
    } else {
        for my $t (keys %$trig_b) {
            $intersection++ if exists $trig_a->{$t};
        }
    }

    return int((2 * $intersection * 100) / ($size_a + $size_b));
}

# Build ngram index for a set of keys within a consolidation category
sub build_consolidation_ngram_index {
    my ($cat_gk, $log_keys_ref) = @_;
    my $indexed = 0;
    for my $log_key (@$log_keys_ref) {
        my $msg = $consolidation_key_message{$log_key};
        next unless defined $msg;
        # Reuse existing trigrams for surviving keys (#135: avoid recomputing across checkpoints)
        my $trigrams = $consolidation_key_trigrams{$log_key};
        if (!$trigrams) {
            $trigrams = get_consolidation_trigrams($msg);
            $consolidation_key_trigrams{$log_key} = $trigrams;
            # Build UUID-normalized trigrams for Dice scoring
            if ($msg =~ $uuid_re) {
                (my $normalized = $msg) =~ s/$uuid_re/<UUID>/g;
                $consolidation_key_trigrams_norm{$log_key} = get_consolidation_trigrams($normalized);
            }
        }
        for my $trig (keys %$trigrams) {
            $consolidation_ngram_index{$cat_gk}{$trig}{$log_key} = 1;
        }
        $indexed++;
    }
    # Cache posting list sizes for discriminative trigram selection
    delete $consolidation_posting_size{$cat_gk};
    for my $trig (keys %{$consolidation_ngram_index{$cat_gk}}) {
        $consolidation_posting_size{$cat_gk}{$trig} = scalar keys %{$consolidation_ngram_index{$cat_gk}{$trig}};
    }
    return $indexed;
}

# Find candidate keys similar to source_key using discriminative trigram pre-filter + Dice verification
sub find_consolidation_candidates {
    my ($cat_gk, $source_key, $threshold_pct, $max_candidates) = @_;
    $max_candidates //= 50;
    my $source_trigrams = $consolidation_key_trigrams{$source_key};
    return () unless defined $source_trigrams;

    my $source_size = scalar keys %$source_trigrams;
    return () if $source_size == 0;

    # Length pre-filter: Dice >= T% requires |B| >= |A|*T/(200-T)
    my $min_cand_size = int($source_size * $threshold_pct / (200 - $threshold_pct));
    my $max_cand_size = int($source_size * (200 - $threshold_pct) / $threshold_pct) + 1;

    # Phase 1: top-K most discriminative trigrams (smallest posting lists)
    my $ps = $consolidation_posting_size{$cat_gk};
    my @disc_trigrams = sort { (($ps->{$a} // 0) <=> ($ps->{$b} // 0)) || ($a cmp $b) }
                        grep { exists $consolidation_ngram_index{$cat_gk}{$_} }
                        keys %$source_trigrams;
    my $topk_actual = min($consolidation_discriminative_topk, scalar @disc_trigrams);
    splice(@disc_trigrams, $topk_actual) if @disc_trigrams > $topk_actual;

    my $loose_min = max(1, int($consolidation_prefilter_ratio * $topk_actual));

    my %candidate_hits;
    for my $trig (@disc_trigrams) {
        for my $cand_key (keys %{$consolidation_ngram_index{$cat_gk}{$trig}}) {
            next if $cand_key eq $source_key;
            $candidate_hits{$cand_key}++;
        }
    }

    # Phase 2: Full Dice verification using UUID-normalized trigrams when available
    my $source_trig_dice = $consolidation_key_trigrams_norm{$source_key} // $source_trigrams;
    my $source_size_dice = scalar keys %$source_trig_dice;
    my $min_dice_size = int($source_size_dice * $threshold_pct / (200 - $threshold_pct));
    my $max_dice_size = int($source_size_dice * (200 - $threshold_pct) / $threshold_pct) + 1;

    my @results;
    for my $cand_key (keys %candidate_hits) {
        next if $candidate_hits{$cand_key} < $loose_min;

        my $cand_trigrams = $consolidation_key_trigrams{$cand_key};
        next unless defined $cand_trigrams;

        my $cand_size = scalar keys %$cand_trigrams;
        next if $cand_size < $min_cand_size || $cand_size > $max_cand_size;

        my $cand_trig_dice = $consolidation_key_trigrams_norm{$cand_key} // $cand_trigrams;
        my $cand_size_dice = scalar keys %$cand_trig_dice;
        next if $cand_size_dice < $min_dice_size || $cand_size_dice > $max_dice_size;

        my $score = dice_coefficient($source_trig_dice, $cand_trig_dice);
        if ($score >= $threshold_pct) {
            push @results, { key => $cand_key, score => $score };
        }
    }

    @results = sort { $b->{score} <=> $a->{score} || $a->{key} cmp $b->{key} } @results;
    splice(@results, $max_candidates) if @results > $max_candidates;
    return @results;
}

# Pure Perl banded edit distance with backtrace — returns mask arrayref (1=keep, 0=variable)
sub compute_mask {
    my ($str_a, $str_b) = @_;
    my @a = split //, $str_a;
    my @b = split //, $str_b;
    my $la = scalar @a;
    my $lb = scalar @b;

    # Strip common prefix/suffix
    my $prefix = 0;
    my $min_len = $la < $lb ? $la : $lb;
    while ($prefix < $min_len && $a[$prefix] eq $b[$prefix]) { $prefix++; }
    my $suffix = 0;
    while ($suffix < ($min_len - $prefix) &&
           $a[$la - 1 - $suffix] eq $b[$lb - 1 - $suffix]) { $suffix++; }

    my @mask = (0) x $la;
    for my $i (0 .. $prefix - 1) { $mask[$i] = 1; }
    for my $i (0 .. $suffix - 1) { $mask[$la - 1 - $i] = 1; }

    my $mid_a = $la - $prefix - $suffix;
    my $mid_b = $lb - $prefix - $suffix;

    if ($mid_a > 0 && $mid_b > 0) {
        my $m = $mid_a;
        my $n = $mid_b;
        my $k = int(($m > $n ? $m : $n) * 0.6) + 2;
        my $big = $m + $n + 1;

        my @dir;
        my @prev = map { $_ } (0 .. $n);
        $dir[0] = [(0) x ($n + 1)];
        for my $j (1 .. min($n, $k)) { $dir[0][$j] = 2; }

        for my $i (1 .. $m) {
            my $j_min = $i - $k; $j_min = 1 if $j_min < 1;
            my $j_max = $i + $k; $j_max = $n if $j_max > $n;
            my @curr = ($big) x ($n + 1);
            $curr[0] = $i;
            $dir[$i] = [(0) x ($n + 1)];

            for my $j ($j_min .. $j_max) {
                if ($a[$prefix + $i - 1] eq $b[$prefix + $j - 1]) {
                    $curr[$j] = $prev[$j - 1];
                    $dir[$i][$j] = 0;
                } else {
                    my $sc = $prev[$j - 1] + 1;
                    my $dc = $prev[$j] + 1;
                    my $ic = $curr[$j - 1] + 1;
                    if ($sc <= $dc && $sc <= $ic) {
                        $curr[$j] = $sc;
                        $dir[$i][$j] = 0;
                    } elsif ($dc <= $ic) {
                        $curr[$j] = $dc;
                        $dir[$i][$j] = 1;
                    } else {
                        $curr[$j] = $ic;
                        $dir[$i][$j] = 2;
                    }
                }
            }
            @prev = @curr;
        }

        # Backtrace
        my ($i, $j) = ($m, $n);
        while ($i > 0 && $j > 0) {
            my $d = $dir[$i][$j];
            if ($d == 0) {
                $mask[$prefix + $i - 1] = 1 if $a[$prefix + $i - 1] eq $b[$prefix + $j - 1];
                $i--; $j--;
            } elsif ($d == 1) {
                $i--;
            } else {
                $j--;
            }
        }
    }

    return \@mask;
}

# Remove spurious keep regions: short runs between variable, and variable-dominated spans
sub coalesce_mask {
    my ($mask) = @_;
    my @m = @$mask;
    my $len = scalar @m;

    # Pass 1: Remove very short keep runs (<3 chars) between variable regions
    my $i = 0;
    while ($i < $len) {
        if ($m[$i] == 1) {
            my $start = $i;
            while ($i < $len && $m[$i] == 1) { $i++; }
            my $run_len = $i - $start;

            if ($run_len < 3) {
                my $has_var_before = ($start == 0) ? 0 : ($m[$start-1] == 0);
                my $has_var_after  = ($i >= $len)  ? 0 : ($m[$i] == 0);
                if ($has_var_before && $has_var_after) {
                    for my $k ($start .. $start + $run_len - 1) {
                        $m[$k] = 0;
                    }
                }
            }
        } else {
            $i++;
        }
    }

    # Pass 2: variable-dominated spans — collapse keeps where keep/total < 40%
    $i = 0;
    while ($i < $len) {
        if ($m[$i] == 0) {
            my $span_start = $i;
            my $j = $i;
            while ($j < $len) {
                if ($m[$j] == 1) {
                    my $keep_start = $j;
                    while ($j < $len && $m[$j] == 1) { $j++; }
                    my $keep_len = $j - $keep_start;
                    if ($keep_len >= 10) {
                        $j = $keep_start;
                        last;
                    }
                } else {
                    $j++;
                }
            }
            my $span_end = $j;
            my $span_len = $span_end - $span_start;

            if ($span_len >= 5) {
                my $keep_count = 0;
                for my $k ($span_start .. $span_end - 1) {
                    $keep_count++ if $m[$k] == 1;
                }
                if ($keep_count / $span_len < 0.40) {
                    for my $k ($span_start .. $span_end - 1) {
                        $m[$k] = 0;
                    }
                }
            }

            $i = $span_end;
        } else {
            $i++;
        }
    }

    return \@m;
}

# Derive canonical form: keep positions retain chars, variable regions become *
sub derive_canonical {
    my ($reference_string, $mask) = @_;
    my @chars = split //, $reference_string;
    my $result = '';
    my $in_variable = 0;

    for my $i (0 .. $#chars) {
        if ($mask->[$i]) {
            if ($chars[$i] eq '*') {
                if (!$in_variable) {
                    $result .= '*';
                    $in_variable = 1;
                }
            } else {
                $in_variable = 0;
                $result .= $chars[$i];
            }
        } else {
            if (!$in_variable) {
                $result .= '*';
                $in_variable = 1;
            }
        }
    }

    return $result;
}

# Derive compiled regex: keep positions become \Q..\E literals, variable regions become .+?
sub derive_regex {
    my ($reference_string, $mask) = @_;
    my @chars = split //, $reference_string;
    my $pattern = '^';
    my $literal_buf = '';
    my $in_variable = 0;

    for my $i (0 .. $#chars) {
        if ($mask->[$i]) {
            if ($chars[$i] eq '*') {
                if (length $literal_buf) {
                    $pattern .= quotemeta($literal_buf);
                    $literal_buf = '';
                }
                if (!$in_variable) {
                    $in_variable = 1;
                }
            } else {
                if ($in_variable) {
                    $pattern .= '.+?';
                    $in_variable = 0;
                }
                $literal_buf .= $chars[$i];
            }
        } else {
            if (length $literal_buf) {
                $pattern .= quotemeta($literal_buf);
                $literal_buf = '';
            }
            if (!$in_variable) {
                $in_variable = 1;
            }
        }
    }

    if ($in_variable) {
        $pattern .= '.+?';
    }
    if (length $literal_buf) {
        $pattern .= quotemeta($literal_buf);
    }

    $pattern .= '$';
    return qr/$pattern/;
}

# Linear scan of compiled patterns for a consolidation category
# Returns pattern entry on match, undef otherwise. Hot-sorts on match.
sub match_consolidation_patterns {
    my ($category, $grouping_key, $msg) = @_;
    my $cat_gk = "$category|$grouping_key";
    return undef unless exists $consolidation_patterns{$cat_gk};
    my $patterns = $consolidation_patterns{$cat_gk};
    for my $i (0 .. $#$patterns) {
        if ($msg =~ $patterns->[$i]{pattern}) {
            my $entry = $patterns->[$i];
            $entry->{match_count}++;
            # Hot-sort: bubble matched entry up by one position
            if ($i > 0 && $entry->{match_count} > $patterns->[$i-1]{match_count}) {
                ($patterns->[$i], $patterns->[$i-1]) = ($patterns->[$i-1], $patterns->[$i]);
            }
            return $entry;
        }
    }
    return undef;
}

# Merge stats from source entry into target (for consolidation cluster merging)
# Handles all ltl %log_messages fields: occurrences, duration, bytes, count, UDM
# Issue #287: merge two #189-shape counter-store entries. Used during fuzzy
# consolidation (#96) when two clusters' or a cluster + key's bin partitions
# need to combine. Target and source are each {partition, bins, overflow,
# underflow} hashrefs; target is mutated to hold the merged state. When their
# partitions have different (min, max, bin_count) extents, both are rebinned
# via geometric-midpoint projection (partition_rebin / #189 R12) into the
# union geometry first, so the per-bin add is well-defined.
sub merge_bin_counter_entries {
    my ($target, $source) = @_;
    if (!$target->{partition}) {
        # Target empty — adopt source wholesale.
        $target->{partition} = $source->{partition};
        $target->{bins}      = $source->{bins} // [];
        $target->{overflow}  = $source->{overflow}  // 0;
        $target->{underflow} = $source->{underflow} // 0;
        return;
    }
    return unless $source->{partition};

    my $tp = $target->{partition};
    my $sp = $source->{partition};

    # Compute the union geometry. partition_extend's doubling history can
    # leave the two partitions with non-congruent (min, max) even when their
    # observation streams overlapped, so we cannot just per-bin add directly
    # — we rebin both into a shared union geometry first.
    my $union_min = $tp->{min} < $sp->{min} ? $tp->{min} : $sp->{min};
    my $union_max = $tp->{max} > $sp->{max} ? $tp->{max} : $sp->{max};
    my $bpd       = $tp->{bpd};
    my $union_decades   = log($union_max / $union_min) / log(10);
    my $union_bin_count = int($bpd * $union_decades);
    $union_bin_count = 1 if $union_bin_count < 1;

    if ($tp->{min} != $union_min || $tp->{max} != $union_max || $tp->{bin_count} != $union_bin_count) {
        my ($new_p, $new_bins) = partition_rebin($tp, $target->{bins}, $union_min, $union_max, $union_bin_count);
        $target->{partition} = $new_p;
        $target->{bins}      = $new_bins;
    }

    my $source_bins_aligned;
    if ($sp->{min} != $union_min || $sp->{max} != $union_max || $sp->{bin_count} != $union_bin_count) {
        my (undef, $new_bins) = partition_rebin($sp, $source->{bins}, $union_min, $union_max, $union_bin_count);
        $source_bins_aligned = $new_bins;
    } else {
        $source_bins_aligned = $source->{bins};
    }

    for my $i (0 .. $union_bin_count - 1) {
        my $sc = $source_bins_aligned->[$i] // 0;
        next if $sc == 0;
        $target->{bins}->[$i] = ($target->{bins}->[$i] // 0) + $sc;
    }
    $target->{overflow}  += ($source->{overflow}  // 0);
    $target->{underflow} += ($source->{underflow} // 0);
}

# Issue #287: merge the bin-path state (Welford-Pébay sidecars + bin-counter
# entry) of $source into $target. $source carries its bin-counter entry on
# $source->{bin_entry}; callers at the %log_messages-source merge sites
# attach it from %log_messages_counters before invoking this function (see
# merge_log_message_entry_into_cluster). For cluster-source merges,
# $cluster->{bin_entry} is already attached.
#
# Sidecar merge uses Chan-Welford-Pébay parallel-merge formulas (Pébay 2008,
# SAND2008-6212) — the order matters: M4 uses M2 and M3 from both sides,
# M3 uses M2 from both sides, M2 uses only n/mean. See feature file
# § Algorithm appendix for the formulas.
sub merge_bin_state {
    my ($target, $source) = @_;
    my $n_a = $target->{duration_count} // 0;
    my $n_b = $source->{duration_count} // 0;
    return if $n_b == 0;

    if ($n_a == 0) {
        # Target empty — adopt source sidecars wholesale. The moment sidecars
        # exist on entries only under shape-group demand (#305): the capture
        # sites never update them otherwise, so the merge skips them
        # symmetrically rather than writing zero-valued fields.
        $target->{duration_count} = $n_b;
        $target->{_running_mean}  = $source->{_running_mean};
        if ($message_stats_demand_shape) {
            $target->{m2_sum}         = $source->{m2_sum} // 0;
            $target->{m3_sum}         = $source->{m3_sum} // 0;
            $target->{m4_sum}         = $source->{m4_sum} // 0;
        }
    } else {
        my $n_ab    = $n_a + $n_b;
        my $mean_a  = $target->{_running_mean};
        my $mean_b  = $source->{_running_mean};
        my $delta   = $mean_b - $mean_a;
        if ($message_stats_demand_shape) {
            my $M2_a    = $target->{m2_sum} // 0;
            my $M2_b    = $source->{m2_sum} // 0;
            my $M3_a    = $target->{m3_sum} // 0;
            my $M3_b    = $source->{m3_sum} // 0;
            my $M4_a    = $target->{m4_sum} // 0;
            my $M4_b    = $source->{m4_sum} // 0;
            my $d2      = $delta * $delta;
            my $d3      = $d2 * $delta;
            my $d4      = $d2 * $d2;
            # Order: M4 (reads M2 and M3), M3 (reads M2), M2, mean. All read OLD
            # state before any field is overwritten.
            my $M4_ab = $M4_a + $M4_b
                      + $d4 * $n_a * $n_b * ($n_a*$n_a - $n_a*$n_b + $n_b*$n_b) / ($n_ab * $n_ab * $n_ab)
                      + 6 * $d2 * ($n_a*$n_a * $M2_b + $n_b*$n_b * $M2_a) / ($n_ab * $n_ab)
                      + 4 * $delta * ($n_a * $M3_b - $n_b * $M3_a) / $n_ab;
            my $M3_ab = $M3_a + $M3_b
                      + $d3 * $n_a * $n_b * ($n_a - $n_b) / ($n_ab * $n_ab)
                      + 3 * $delta * ($n_a * $M2_b - $n_b * $M2_a) / $n_ab;
            my $M2_ab = $M2_a + $M2_b + $d2 * $n_a * $n_b / $n_ab;
            $target->{m2_sum}         = $M2_ab;
            $target->{m3_sum}         = $M3_ab;
            $target->{m4_sum}         = $M4_ab;
        }
        my $mean_ab = $mean_a + $delta * $n_b / $n_ab;
        $target->{duration_count} = $n_ab;
        $target->{_running_mean}  = $mean_ab;
    }

    # Bin-counter entry merge (only meaningful when source observed at least
    # one positive duration — counter_update is gated on $duration > 0).
    if ($source->{bin_entry}) {
        $target->{bin_entry} //= { partition => undef, bins => [], overflow => 0, underflow => 0 };
        merge_bin_counter_entries($target->{bin_entry}, $source->{bin_entry});
    }
}

sub merge_consolidation_stats {
    my ($target, $source) = @_;
    $target->{occurrences} += ($source->{occurrences} // 0);

    # Duration stats
    if (defined $source->{total_duration}) {
        $target->{total_duration} = ($target->{total_duration} // 0) + $source->{total_duration};
        $target->{total_duration_num} = ($target->{total_duration_num} // 0) + ($source->{total_duration_num} // 0);
        $target->{sum_of_squares} = ($target->{sum_of_squares} // 0) + ($source->{sum_of_squares} // 0);
        $target->{min} = $source->{min} if defined $source->{min} && (!defined $target->{min} || $source->{min} < $target->{min});
        $target->{max} = $source->{max} if defined $source->{max} && (!defined $target->{max} || $source->{max} > $target->{max});
        push @{$target->{durations}}, @{$source->{durations}} if $source->{durations} && @{$source->{durations}};
    }

    # Bytes stats
    $target->{total_bytes} = ($target->{total_bytes} // 0) + $source->{total_bytes} if defined $source->{total_bytes};

    # Count stats
    if (defined $source->{count_sum}) {
        $target->{count_sum} = ($target->{count_sum} // 0) + $source->{count_sum};
        $target->{count_occurrences} = ($target->{count_occurrences} // 0) + ($source->{count_occurrences} // 0);
        $target->{count_min} = $source->{count_min} if defined $source->{count_min} && (!defined $target->{count_min} || $source->{count_min} < $target->{count_min});
        $target->{count_max} = $source->{count_max} if defined $source->{count_max} && (!defined $target->{count_max} || $source->{count_max} > $target->{count_max});
    }

    # UDM stats
    foreach my $config (@udm_configs) {
        my $name = $config->{name};
        if ($config->{agg_kind} eq 'counting') {
            # Counting UDMs carry per-message occurrences only (Issue #313)
            $target->{"udm_${name}_occurrences"} = ($target->{"udm_${name}_occurrences"} // 0) + $source->{"udm_${name}_occurrences"}
                if defined $source->{"udm_${name}_occurrences"};
            next;
        }
        my $sum_key = "udm_${name}_sum";
        next unless defined $source->{$sum_key};
        $target->{$sum_key} = ($target->{$sum_key} // 0) + $source->{$sum_key};
        $target->{"udm_${name}_occurrences"} = ($target->{"udm_${name}_occurrences"} // 0) + ($source->{"udm_${name}_occurrences"} // 0);
        my $smin = $source->{"udm_${name}_min"};
        $target->{"udm_${name}_min"} = $smin if defined $smin && (!defined $target->{"udm_${name}_min"} || $smin < $target->{"udm_${name}_min"});
        my $smax = $source->{"udm_${name}_max"};
        $target->{"udm_${name}_max"} = $smax if defined $smax && (!defined $target->{"udm_${name}_max"} || $smax > $target->{"udm_${name}_max"});
    }

    # Issue #287: under -mdm bin, also merge the Welford-Pébay sidecars and
    # the #189-shape bin-counter entry. Callers at %log_messages-source
    # merge sites attach $source->{bin_entry} from %log_messages_counters
    # before calling (see merge_log_message_entry_into_cluster); cluster-
    # source merges already carry $source->{bin_entry} on the cluster
    # hashref; stats_source-source merges build it inline at the producer
    # site. The raw min/max copies above already happened — merge_bin_state
    # only updates the duration_count, _running_mean, m2/m3/m4 sidecars
    # and the bin counter.
    if ($message_stats_capture_mode && $message_stats_capture_mode eq 'bin') {
        merge_bin_state($target, $source);
    }
}

# Issue #287: wrapper for the seven consolidation sites that merge a
# %log_messages entry into a cluster. Under -mdm bin, attaches the
# corresponding %log_messages_counters entry to the source hashref so
# merge_consolidation_stats can fold it into the cluster's bin state,
# then releases the global counter-store slot (the %log_messages entry
# is deleted by the caller).
sub merge_log_message_entry_into_cluster {
    my ($cluster, $category, $log_key) = @_;
    my $source = $log_messages{$category}{$log_key};
    if ($message_stats_capture_mode && $message_stats_capture_mode eq 'bin') {
        my $key = "$category\x1f$log_key";
        $source->{bin_entry} = $log_messages_counters{$key};
        merge_consolidation_stats($cluster, $source);
        delete $log_messages_counters{$key};
        delete $source->{bin_entry};
    } else {
        merge_consolidation_stats($cluster, $source);
    }
}

# Process a single key through the consolidation pipeline (S1 match → accumulate → trigger checkpoint)
# Used by both streaming (parsing) and final pass (group_similar_messages) paths.
# Returns: 1 if S1 matched (key absorbed into cluster), 0 if not (key stored for checkpoint processing)
sub consolidation_process_key {
    my ($log_key, $category, $cat_gk, $capped_msg, $stats_source) = @_;
    my ($c, $grouping_key) = split(/\|/, $cat_gk, 2);

    # Phase-appropriate counter prefix
    my $pfx = ($consolidation_phase eq 'final_pass') ? 'fp_' : '';

    $consolidation_total_keys_seen++;
    $consolidation_cat_stats{$cat_gk}{"${pfx}keys_seen"}++;

    # S1: try matching against existing compiled patterns
    my $entry = match_consolidation_patterns($category, $grouping_key, $capped_msg);
    if ($entry) {
        my $cluster = $consolidation_clusters{$cat_gk}{$entry->{canonical}};
        if ($cluster) {
            merge_consolidation_stats($cluster, $stats_source);
            $consolidation_cat_stats{$cat_gk}{"${pfx}s1_inline"}++;
            return 1;
        }
    }

    # Not matched by S1 — store for checkpoint processing
    $consolidation_key_message{$log_key} = $capped_msg;
    $consolidation_key_message_cat_gk{$log_key} = $cat_gk;
    $consolidation_unmatched{$cat_gk}{$log_key} = 1;
    $consolidation_key_generation{$log_key} = $consolidation_pattern_generation{$cat_gk} // 0;
    $consolidation_key_checkpoint_count{$log_key} = 0;
    $consolidation_category_unmatched_count{$category}++;

    # Check trigger per category — fire checkpoints for all groups in this category
    if (($consolidation_category_unmatched_count{$category} // 0) >= $consolidation_trigger) {
        for my $ck (sort keys %consolidation_unmatched) {
            next unless $ck =~ /^\Q$category\E\|/;
            next if scalar(keys %{$consolidation_unmatched{$ck}}) < 2;
            my ($cc, $gk) = split(/\|/, $ck, 2);
            run_consolidation_checkpoint($cc, $gk);
        }
        $consolidation_category_unmatched_count{$category} = 0;
    }

    return 0;
}

# Try to merge new pattern into an existing similar pattern (merge-first strategy)
sub try_consolidation_merge_into_existing {
    my ($cat_gk, $new_canonical, $new_regex, $new_mask, $new_cluster) = @_;
    return undef unless exists $consolidation_patterns{$cat_gk};

    my $new_trigrams = get_consolidation_trigrams($new_canonical);

    for my $entry (@{$consolidation_patterns{$cat_gk}}) {
        my $existing = $consolidation_clusters{$cat_gk}{$entry->{canonical}};
        next unless $existing;

        my $existing_trigrams = get_consolidation_trigrams($entry->{canonical});
        my $score = dice_coefficient($new_trigrams, $existing_trigrams);

        if ($score >= $consolidation_threshold) {
            my $raw_mask = compute_mask($entry->{canonical}, $new_canonical);
            my $mask = coalesce_mask($raw_mask);
            my $merged_canonical = derive_canonical($entry->{canonical}, $mask);
            my $merged_regex = derive_regex($entry->{canonical}, $mask);

            next unless ($entry->{canonical} =~ $merged_regex) && ($new_canonical =~ $merged_regex);

            merge_consolidation_stats($existing, $new_cluster);
            $existing->{match_count} += $new_cluster->{match_count};

            my $old_canonical = $entry->{canonical};
            $existing->{canonical} = $merged_canonical;
            $existing->{pattern} = $merged_regex;
            $existing->{mask} = $mask;
            $entry->{canonical} = $merged_canonical;
            $entry->{cluster_key} = $merged_canonical;
            $entry->{pattern} = $merged_regex;
            $entry->{match_count} = $existing->{match_count};

            if ($old_canonical ne $merged_canonical) {
                $consolidation_clusters{$cat_gk}{$merged_canonical} = $existing;
                delete $consolidation_clusters{$cat_gk}{$old_canonical};
            }

            return ($merged_regex, $entry, $existing);
        }
    }
    return ();
}

# Extract partitioning key from a message for re-scan bucketing
# Simplified for IQ-01: operates on $message only, uses first word or first 20 chars
sub extract_consolidation_bucket_key {
    my ($msg) = @_;
    if ($msg =~ /^(\S+)/) {
        return substr($1, 0, 30);
    }
    return substr($msg, 0, 20);
}

# Partition an array of keys into buckets by their bucket key
sub partition_consolidation_keys {
    my ($keys_ref) = @_;
    my %buckets;
    for my $key (@$keys_ref) {
        my $bk = extract_consolidation_bucket_key($consolidation_key_message{$key} // $key);
        push @{$buckets{$bk}}, $key;
    }
    return \%buckets;
}

# Core pairwise discovery engine for one consolidation category
sub run_consolidation_pass {
    my ($cat_gk, $unmatched_ref, $pass_num) = @_;
    my @unmatched_keys = @$unmatched_ref;
    my $initial_count = scalar @unmatched_keys;

    return (0, 0, 0, 0, 0, 0, 0, {}, 0, 0) if $initial_count < 2;

    # Extract the ltl category (plain/highlight) from the composite key
    my ($category) = split(/\|/, $cat_gk, 2);

    # Separate keys by occurrence ceiling
    my @discovery_candidates;
    my @ceiling_keys;
    for my $key (@unmatched_keys) {
        my $occ = $log_messages{$category}{$key}{occurrences} // 1;
        if ($occ >= $consolidation_occurrence_ceiling) {
            push @ceiling_keys, $key;
        } else {
            push @discovery_candidates, $key;
        }
    }
    my $ceiling_skipped = scalar @ceiling_keys;

    my %consumed;
    my $gate2_absorbed = 0;
    my $fc_calls = 0;
    my $messages_absorbed = 0;
    my $rescan_absorbed = 0;

    return (0, 0, $ceiling_skipped, 0, 0, 0, scalar @discovery_candidates, {}, 0, 0, 0) if scalar @discovery_candidates < 2;

    # Gate 2 (S3): match discovery candidates against existing compiled patterns
    # Skip keys that entered at the current pattern generation — they already failed S1
    # against the same patterns S3 would test (#135: S3 match rate was 0% on first checkpoint)
    my $current_gen = $consolidation_pattern_generation{$cat_gk} // 0;
    my ($c, $gk) = split(/\|/, $cat_gk, 2);
    my @gate2_survivors;
    my $s3_tested = 0;
    my $s3_skipped = 0;
    for my $key (@discovery_candidates) {
        my $key_gen = $consolidation_key_generation{$key} // 0;
        if ($key_gen >= $current_gen) {
            # Key entered at or after current generation — already tested against all patterns
            push @gate2_survivors, $key;
            $s3_skipped++;
            next;
        }
        $s3_tested++;
        my $msg = $consolidation_key_message{$key};
        my $entry = match_consolidation_patterns($c, $gk, $msg);
        if ($entry) {
            $consumed{$key} = 1;
            my $cluster = $consolidation_clusters{$cat_gk}{$entry->{canonical}};
            if ($cluster && exists $log_messages{$category}{$key}) {
                merge_log_message_entry_into_cluster($cluster, $category, $key);   # #287: bin-state-aware
                $messages_absorbed++;
            }
            $gate2_absorbed++;
        } else {
            push @gate2_survivors, $key;
        }
    }

    if (scalar @gate2_survivors < 2) {
        my @remaining = grep { !$consumed{$_} } @unmatched_keys;
        @$unmatched_ref = @remaining;
        return (0, $messages_absorbed, $ceiling_skipped, 0, $gate2_absorbed, $fc_calls, scalar @gate2_survivors, \%consumed, $s3_tested, $s3_skipped);
    }

    # Build n-gram index for gate2 survivors
    my $index_limit = min($consolidation_trigger, scalar @gate2_survivors);
    my @index_batch = @gate2_survivors[0 .. $index_limit - 1];

    delete $consolidation_ngram_index{$cat_gk};
    build_consolidation_ngram_index($cat_gk, \@index_batch);

    my $patterns_discovered = 0;
    my $merges_into_existing = 0;
    my $keys_searched = 0;
    my $max_search = min(500, scalar @index_batch);
    my $cap_hit = 0;

    my $current_pattern_count = exists $consolidation_patterns{$cat_gk} ? scalar @{$consolidation_patterns{$cat_gk}} : 0;

    # Build partitioned buckets for fast re-scan
    my %buckets;
    for my $key (@unmatched_keys) {
        my $bk = extract_consolidation_bucket_key($consolidation_key_message{$key} // $key);
        push @{$buckets{$bk}}, $key;
    }

    for my $key (@index_batch) {
        last if $keys_searched >= $max_search;
        next if $consumed{$key};

        $keys_searched++;
        $fc_calls++;
        my @matches = find_consolidation_candidates($cat_gk, $key, $consolidation_threshold);

        for my $match (@matches) {
            next if $consumed{$match->{key}};

            my $msg_a = substr($consolidation_key_message{$key} // '', 0, $consolidation_message_length_cap);
            my $msg_b = substr($consolidation_key_message{$match->{key}} // '', 0, $consolidation_message_length_cap);

            my $raw_mask = compute_mask($msg_a, $msg_b);
            my $mask = coalesce_mask($raw_mask);
            my $canonical = derive_canonical($msg_a, $mask);
            my $regex = derive_regex($msg_a, $mask);

            next unless ($msg_a =~ $regex) && ($msg_b =~ $regex);

            $consumed{$key} = 1;
            $consumed{$match->{key}} = 1;

            my $new_cluster = {
                canonical   => $canonical,
                pattern     => $regex,
                mask        => $mask,
                occurrences => 0,
                match_count => 0,
            };

            for my $src_key ($key, $match->{key}) {
                if (exists $log_messages{$category}{$src_key}) {
                    merge_log_message_entry_into_cluster($new_cluster, $category, $src_key);   # #287: bin-state-aware
                    $new_cluster->{match_count}++;
                    $messages_absorbed++;
                }
            }

            my $scan_regex = $regex;
            my $scan_cluster = $new_cluster;
            my $scan_entry;
            my ($merged_regex, $merged_entry, $merged_cluster) = try_consolidation_merge_into_existing($cat_gk, $canonical, $regex, $mask, $new_cluster);
            if ($merged_regex) {
                $merges_into_existing++;
                $patterns_discovered++;
                $scan_regex = $merged_regex;
                $scan_entry = $merged_entry;
                $scan_cluster = $merged_cluster;
            } else {
                # Optional hard cap (--consolidation-max-patterns N, default 0 = unlimited)
                if ($consolidation_max_patterns > 0 && $current_pattern_count >= $consolidation_max_patterns) {
                    $consolidation_clusters{$cat_gk}{$canonical} = $new_cluster;
                    $patterns_discovered++;
                    last;
                }

                $consolidation_clusters{$cat_gk}{$canonical} = $new_cluster;
                $scan_entry = {
                    pattern     => $regex,
                    cluster_key => $canonical,
                    canonical   => $canonical,
                    match_count => $new_cluster->{match_count},
                };
                push @{$consolidation_patterns{$cat_gk}}, $scan_entry;
                $current_pattern_count++;
                $patterns_discovered++;
            }

            # Interleaved re-scan with partitioning
            my $pattern_bk = extract_consolidation_bucket_key($scan_entry ? $scan_entry->{canonical} : $canonical);
            my $bucket_keys = $buckets{$pattern_bk};
            if ($bucket_keys) {
                my @surviving;
                for my $ukey (@$bucket_keys) {
                    if ($consumed{$ukey}) { next; }
                    my $umsg = $consolidation_key_message{$ukey};
                    unless (defined $umsg) { push @surviving, $ukey; next; }
                    if ($umsg =~ $scan_regex) {
                        $consumed{$ukey} = 1;
                        if (exists $log_messages{$category}{$ukey}) {
                            merge_log_message_entry_into_cluster($scan_cluster, $category, $ukey);   # #287: bin-state-aware
                            $scan_cluster->{match_count}++;
                            $scan_entry->{match_count} = $scan_cluster->{match_count} if $scan_entry;
                            $messages_absorbed++;
                            $rescan_absorbed++;
                        }
                    } else {
                        push @surviving, $ukey;
                    }
                }
                $buckets{$pattern_bk} = \@surviving;
            }

            last;
        }
    }

    my @remaining = grep { !$consumed{$_} } @unmatched_keys;
    @$unmatched_ref = @remaining;

    return ($patterns_discovered, $messages_absorbed, $ceiling_skipped, $cap_hit, $gate2_absorbed, $fc_calls, scalar @gate2_survivors, \%consumed, $s3_tested, $s3_skipped, $rescan_absorbed);
}

# Final pass sliding window: S4 pairwise discovery on a bounded set of keys.
# Operates directly on %log_messages — no %consolidation_unmatched accumulation.
# Trigrams are built for the window and freed after processing.
sub process_final_pass_window {
    my ($cat_gk, $window_ref) = @_;
    my @window = @$window_ref;
    my $window_size = scalar @window;
    return (0, 0, 0, 0, 0, 0) if $window_size < 2;

    my ($category) = split(/\|/, $cat_gk, 2);

    # Populate working structures for window keys only
    my @key_list;
    for my $entry (@window) {
        my ($log_key, $capped_msg) = @$entry;
        $consolidation_key_message{$log_key} = $capped_msg;
        push @key_list, $log_key;
    }

    # Build trigram index for window
    delete $consolidation_ngram_index{$cat_gk};
    build_consolidation_ngram_index($cat_gk, \@key_list);

    # Build window-local partition buckets for re-scan
    my %buckets;
    for my $log_key (@key_list) {
        my $bk = extract_consolidation_bucket_key($consolidation_key_message{$log_key} // $log_key);
        push @{$buckets{$bk}}, $log_key;
    }

    my %consumed;
    my $patterns_discovered = 0;
    my $messages_absorbed = 0;
    my $rescan_absorbed = 0;
    my $fc_calls = 0;
    my $keys_searched = 0;
    my $max_search = min(500, $window_size);
    my $current_pattern_count = exists $consolidation_patterns{$cat_gk} ? scalar @{$consolidation_patterns{$cat_gk}} : 0;

    for my $log_key (@key_list) {
        last if $keys_searched >= $max_search;
        next if $consumed{$log_key};

        $keys_searched++;
        $fc_calls++;
        my @matches = find_consolidation_candidates($cat_gk, $log_key, $consolidation_threshold);

        for my $match (@matches) {
            next if $consumed{$match->{key}};

            my $msg_a = substr($consolidation_key_message{$log_key} // '', 0, $consolidation_message_length_cap);
            my $msg_b = substr($consolidation_key_message{$match->{key}} // '', 0, $consolidation_message_length_cap);

            my $raw_mask = compute_mask($msg_a, $msg_b);
            my $mask = coalesce_mask($raw_mask);
            my $canonical = derive_canonical($msg_a, $mask);
            my $regex = derive_regex($msg_a, $mask);

            next unless ($msg_a =~ $regex) && ($msg_b =~ $regex);

            $consumed{$log_key} = 1;
            $consumed{$match->{key}} = 1;

            my $new_cluster = {
                canonical   => $canonical,
                pattern     => $regex,
                mask        => $mask,
                occurrences => 0,
                match_count => 0,
            };

            for my $src_key ($log_key, $match->{key}) {
                if (exists $log_messages{$category}{$src_key}) {
                    merge_log_message_entry_into_cluster($new_cluster, $category, $src_key);   # #287: bin-state-aware
                    $new_cluster->{match_count}++;
                    $messages_absorbed++;
                }
            }

            my $scan_regex = $regex;
            my $scan_cluster = $new_cluster;
            my $scan_entry;
            my ($merged_regex, $merged_entry, $merged_cluster) = try_consolidation_merge_into_existing($cat_gk, $canonical, $regex, $mask, $new_cluster);
            if ($merged_regex) {
                $patterns_discovered++;
                $scan_regex = $merged_regex;
                $scan_entry = $merged_entry;
                $scan_cluster = $merged_cluster;
            } else {
                if ($consolidation_max_patterns > 0 && $current_pattern_count >= $consolidation_max_patterns) {
                    $consolidation_clusters{$cat_gk}{$canonical} = $new_cluster;
                    $patterns_discovered++;
                    last;
                }

                $consolidation_clusters{$cat_gk}{$canonical} = $new_cluster;
                $scan_entry = {
                    pattern     => $regex,
                    cluster_key => $canonical,
                    canonical   => $canonical,
                    match_count => $new_cluster->{match_count},
                };
                push @{$consolidation_patterns{$cat_gk}}, $scan_entry;
                $current_pattern_count++;
                $patterns_discovered++;
            }

            # Interleaved re-scan within window partition buckets
            my $pattern_bk = extract_consolidation_bucket_key($scan_entry ? $scan_entry->{canonical} : $canonical);
            my $bucket_keys = $buckets{$pattern_bk};
            if ($bucket_keys) {
                my @surviving;
                for my $ukey (@$bucket_keys) {
                    if ($consumed{$ukey}) { next; }
                    my $umsg = $consolidation_key_message{$ukey};
                    unless (defined $umsg) { push @surviving, $ukey; next; }
                    if ($umsg =~ $scan_regex) {
                        $consumed{$ukey} = 1;
                        if (exists $log_messages{$category}{$ukey}) {
                            merge_log_message_entry_into_cluster($scan_cluster, $category, $ukey);   # #287: bin-state-aware
                            $scan_cluster->{match_count}++;
                            $scan_entry->{match_count} = $scan_cluster->{match_count} if $scan_entry;
                            $messages_absorbed++;
                            $rescan_absorbed++;
                        }
                    } else {
                        push @surviving, $ukey;
                    }
                }
                $buckets{$pattern_bk} = \@surviving;
            }

            last;
        }
    }

    # Cross-cluster merge if patterns discovered
    my $cross_merges = 0;
    if ($patterns_discovered > 0) {
        $cross_merges = merge_consolidation_overlapping_patterns($cat_gk);
    }

    # Delete consumed keys from %log_messages
    for my $key (keys %consumed) {
        delete $log_messages{$category}{$key};
    }

    # Capture transient structure HWMs before they're freed (#171)
    measure_memory_structures();

    # Cleanup: free window working structures
    for my $log_key (@key_list) {
        delete $consolidation_key_message{$log_key};
        delete $consolidation_key_trigrams{$log_key};
        delete $consolidation_key_trigrams_norm{$log_key};
    }
    delete $consolidation_ngram_index{$cat_gk};
    delete $consolidation_posting_size{$cat_gk};

    return ($patterns_discovered, $messages_absorbed - $rescan_absorbed, $rescan_absorbed, $fc_calls, $messages_absorbed, $cross_merges);
}

# Cross-cluster merge: merge overlapping patterns where a more general pattern's regex
# matches a more specific pattern's canonical form. The more general pattern absorbs
# the more specific one(s), merging all accumulated statistics.
sub merge_consolidation_overlapping_patterns {
    my ($cat_gk) = @_;
    return 0 unless exists $consolidation_patterns{$cat_gk};
    my @patterns = @{$consolidation_patterns{$cat_gk}};
    return 0 if @patterns < 2;

    my $merges = 0;
    my %removed;

    for my $i (0 .. $#patterns) {
        next if $removed{$i};
        my $pattern_a = $patterns[$i];
        my $cluster_a = $consolidation_clusters{$cat_gk}{$pattern_a->{canonical}};
        next unless $cluster_a;

        for my $j ($i + 1 .. $#patterns) {
            next if $removed{$j};
            my $pattern_b = $patterns[$j];
            my $cluster_b = $consolidation_clusters{$cat_gk}{$pattern_b->{canonical}};
            next unless $cluster_b;

            # Test both directions: which pattern's regex matches the other's canonical?
            # The pattern whose regex matches is more general and absorbs the other.
            my ($general, $general_cluster, $general_idx, $specific, $specific_cluster, $specific_idx);

            if ($pattern_a->{canonical} =~ $pattern_b->{pattern}) {
                # B's regex matches A's canonical — B is more general, absorbs A
                ($general, $general_cluster, $general_idx) = ($pattern_b, $cluster_b, $j);
                ($specific, $specific_cluster, $specific_idx) = ($pattern_a, $cluster_a, $i);
            } elsif ($pattern_b->{canonical} =~ $pattern_a->{pattern}) {
                # A's regex matches B's canonical — A is more general, absorbs B
                ($general, $general_cluster, $general_idx) = ($pattern_a, $cluster_a, $i);
                ($specific, $specific_cluster, $specific_idx) = ($pattern_b, $cluster_b, $j);
            } else {
                next;  # No subsumption in either direction
            }

            if ($ENV{LTL_MERGE_DEBUG}) {
                printf STDERR "[MERGE_DEBUG] %s absorbs %s (occ %d + %d)\n",
                    substr($general->{canonical}, 0, 80),
                    substr($specific->{canonical}, 0, 80),
                    $general_cluster->{occurrences} // 0,
                    $specific_cluster->{occurrences} // 0;
            }

            merge_consolidation_stats($general_cluster, $specific_cluster);
            $general_cluster->{match_count} += $specific_cluster->{match_count};
            delete $consolidation_clusters{$cat_gk}{$specific->{canonical}};
            $removed{$specific_idx} = 1;
            $merges++;

            # If A was absorbed (specific_idx == i), stop checking A against further patterns
            last if $specific_idx == $i;
        }
    }

    if ($merges > 0) {
        $consolidation_patterns{$cat_gk} = [ grep { exists $consolidation_clusters{$cat_gk}{$_->{canonical}} } @patterns ];
    }

    return $merges;
}

# Adaptive eviction: derive max survival count from rolling average absorption rate.
# The curve is exponentially aggressive — only very high absorption rates justify
# multiple survivals. Calibrated against empirical data from 5 file types (#135).
# This curve may need tuning over time as more data types are encountered.
sub get_consolidation_max_survivals {
    my ($absorption_ema) = @_;
    return 0 if $absorption_ema < 0.05;  # < 5%:  evict immediately
    return 1 if $absorption_ema < 0.50;  # 5-50%: one retry
    return 2 if $absorption_ema < 0.90;  # 50-90%: two retries
    return 3 if $absorption_ema < 0.95;  # 90-95%: three retries
    return 4 if $absorption_ema < 0.99;  # 95-99%: four retries
    return 5;                            # >= 99%: five retries (power-law data)
}

# Fire a consolidation checkpoint for one category/grouping_key pair
sub run_consolidation_checkpoint {
    my ($category, $grouping_key) = @_;
    my $cat_gk = "$category|$grouping_key";
    my $is_final_pass = ($consolidation_phase eq 'final_pass');
    my $pfx = $is_final_pass ? 'fp_' : '';

    $consolidation_cat_stats{$cat_gk}{"${pfx}checkpoints"}++;
    my $cp_num = $consolidation_cat_stats{$cat_gk}{"${pfx}checkpoints"};

    my @unmatched = sort keys %{$consolidation_unmatched{$cat_gk}};
    my $pre_count = scalar @unmatched;
    return if $pre_count < 2;

    # Fast-path eviction: if EMA indicates all keys should be evicted immediately,
    # skip the expensive checkpoint pass entirely (#135).
    # Disabled during final pass — eviction is not applicable (bounded set, last chance to consolidate).
    if (!$is_final_pass) {
        my $current_max_survivals = exists $consolidation_absorption_ema{$cat_gk}
            ? get_consolidation_max_survivals($consolidation_absorption_ema{$cat_gk})
            : undef;  # first checkpoint — no EMA yet, must run the pass

        if (defined $current_max_survivals && $current_max_survivals == 0 && $cp_num > 2) {
            # All surviving keys would be evicted — skip run_consolidation_pass entirely
            my $evicted = 0;
            for my $key (@unmatched) {
                $consolidation_key_checkpoint_count{$key} = ($consolidation_key_checkpoint_count{$key} // 0) + 1;
                # Evict: remove from consolidation working set, keep in %log_messages
                delete $consolidation_key_message{$key};
                delete $consolidation_key_message_cat_gk{$key};
                delete $consolidation_key_trigrams{$key};
                delete $consolidation_key_trigrams_norm{$key};
                delete $consolidation_key_generation{$key};
                delete $consolidation_key_checkpoint_count{$key};
                delete $consolidation_unmatched{$cat_gk}{$key};
                $evicted++;
                $consolidation_category_unmatched_count{$category}-- if ($consolidation_category_unmatched_count{$category} // 0) > 0;
            }
            $consolidation_cat_stats{$cat_gk}{evicted} = ($consolidation_cat_stats{$cat_gk}{evicted} // 0) + $evicted;
            $consolidation_cat_stats{$cat_gk}{absorption_ema} = $consolidation_absorption_ema{$cat_gk};
            $consolidation_cat_stats{$cat_gk}{max_survivals} = 0;
            return;
        }
    }

    my ($discovered, $absorbed, $ceiling_skipped, $cap_hit, $g2_absorbed, $fc_calls, $g2_survivors, $consumed_ref, $s3_tested, $s3_skipped, $rescan_absorbed) =
        run_consolidation_pass($cat_gk, \@unmatched, $cp_num);

    # Capture transient structure HWMs before they're freed (#171)
    measure_memory_structures();

    my $post_count = scalar @unmatched;

    # Update per-category accumulators (phase-appropriate counters)
    $consolidation_cat_stats{$cat_gk}{"${pfx}s3_checkpoint"} += $g2_absorbed;
    $consolidation_cat_stats{$cat_gk}{"${pfx}s3_calls"}      += $s3_tested;
    $consolidation_cat_stats{$cat_gk}{"${pfx}s3_skipped"}    += $s3_skipped;
    $consolidation_cat_stats{$cat_gk}{"${pfx}s4_pairwise"}   += ($absorbed - $g2_absorbed - ($rescan_absorbed // 0));
    $consolidation_cat_stats{$cat_gk}{"${pfx}s4_rescan"}     += ($rescan_absorbed // 0);
    $consolidation_cat_stats{$cat_gk}{"${pfx}fc_calls"}      += $fc_calls;
    $consolidation_cat_stats{$cat_gk}{"${pfx}patterns_discovered"} += $discovered;
    $consolidation_cat_stats{$cat_gk}{"${pfx}patterns_final"} = exists $consolidation_patterns{$cat_gk} ? scalar @{$consolidation_patterns{$cat_gk}} : 0;

    # Delete absorbed keys — targeted O(consumed) instead of O(all_keys) (#135)
    $consolidation_cat_stats{$cat_gk}{"${pfx}cleanup_keys_scanned"} += scalar keys %$consumed_ref;
    for my $key (keys %$consumed_ref) {
        delete $log_messages{$category}{$key};
        delete $consolidation_key_message{$key};
        delete $consolidation_key_message_cat_gk{$key};
        delete $consolidation_key_trigrams{$key};
        delete $consolidation_key_trigrams_norm{$key};
        delete $consolidation_key_generation{$key};
        delete $consolidation_key_checkpoint_count{$key};
    }

    # Free index structures (per-checkpoint, not per-key)
    delete $consolidation_ngram_index{$cat_gk};
    delete $consolidation_posting_size{$cat_gk};

    # Cross-cluster merge and pattern generation bump
    if ($discovered > 0) {
        my $cross_merges = merge_consolidation_overlapping_patterns($cat_gk);
        $consolidation_cat_stats{$cat_gk}{"${pfx}cross_cluster_merges"} += $cross_merges;
        $consolidation_cat_stats{$cat_gk}{"${pfx}patterns_final"} = exists $consolidation_patterns{$cat_gk} ? scalar @{$consolidation_patterns{$cat_gk}} : 0;
        $consolidation_pattern_generation{$cat_gk} = ($consolidation_pattern_generation{$cat_gk} // 0) + 1;
    }

    # Adaptive eviction (#135): update EMA, increment checkpoint counts, evict stale keys
    # Disabled during final pass — the final pass is the last chance to consolidate,
    # and the working set is bounded (no new keys arrive). Eviction here would
    # permanently lose keys with no subsequent pass to catch them.
    my $absorption_rate = $pre_count > 0 ? $absorbed / $pre_count : 0;
    if (exists $consolidation_absorption_ema{$cat_gk}) {
        $consolidation_absorption_ema{$cat_gk} = $consolidation_eviction_ema_alpha * $absorption_rate
            + (1 - $consolidation_eviction_ema_alpha) * $consolidation_absorption_ema{$cat_gk};
    } else {
        $consolidation_absorption_ema{$cat_gk} = $absorption_rate;  # first checkpoint initializes directly
    }

    if ($is_final_pass) {
        # Final pass: all survivors stay — rebuild unmatched from non-consumed keys
        my %survivors;
        for my $key (@unmatched) {
            next if exists $consumed_ref->{$key};
            $survivors{$key} = 1;
        }
        %{$consolidation_unmatched{$cat_gk}} = %survivors;
    } else {
        # Streaming: evict keys exceeding adaptive survival threshold
        my $max_survivals = get_consolidation_max_survivals($consolidation_absorption_ema{$cat_gk});
        $consolidation_cat_stats{$cat_gk}{absorption_ema} = $consolidation_absorption_ema{$cat_gk};
        $consolidation_cat_stats{$cat_gk}{max_survivals} = $max_survivals;

        my $evicted = 0;
        my %survivors;
        for my $key (@unmatched) {
            next if exists $consumed_ref->{$key};  # already deleted above
            $consolidation_key_checkpoint_count{$key} = ($consolidation_key_checkpoint_count{$key} // 0) + 1;
            if ($consolidation_key_checkpoint_count{$key} > $max_survivals) {
                # Evict: remove from consolidation working set, keep in %log_messages
                delete $consolidation_key_message{$key};
                delete $consolidation_key_message_cat_gk{$key};
                delete $consolidation_key_trigrams{$key};
                delete $consolidation_key_trigrams_norm{$key};
                delete $consolidation_key_generation{$key};
                delete $consolidation_key_checkpoint_count{$key};
                $evicted++;
                $consolidation_category_unmatched_count{$category}-- if ($consolidation_category_unmatched_count{$category} // 0) > 0;
            } else {
                $survivors{$key} = 1;
            }
        }

        # Rebuild %consolidation_unmatched from survivors only
        %{$consolidation_unmatched{$cat_gk}} = %survivors;
        $consolidation_cat_stats{$cat_gk}{evicted} = ($consolidation_cat_stats{$cat_gk}{evicted} // 0) + $evicted;
    }
}

